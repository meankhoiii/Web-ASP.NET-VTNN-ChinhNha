@using ChinhNha.Application.DTOs.Customers
@model CustomerProfileDto

@{
    ViewData["Title"] = "Thông Tin Tài Khoản";
}

<style>
    .profile-container {
        background-color: #E8F5E9;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .profile-card {
        background: white;
        border: 2px solid #2E7D32;
        border-radius: 10px;
        padding: 2rem;
    }

    .form-section {
        margin-bottom: 2rem;
    }

    .form-label {
        font-weight: bold;
        color: #1B5E20;
        margin-bottom: 0.5rem;
    }

    .profile-input {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 0.75rem;
    }

    .profile-input:focus {
        border-color: #2E7D32;
        box-shadow: 0 0 0 0.2rem rgba(46, 125, 50, 0.25);
    }

    .submit-btn {
        background-color: #2E7D32;
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .submit-btn:hover {
        background-color: #1B5E20;
        transform: translateY(-2px);
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 1rem 0;
        border-bottom: 1px solid #eee;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #666;
        font-weight: 500;
    }

    .info-value {
        font-weight: bold;
        color: #1B5E20;
    }
</style>

<div class="container my-5">
    <div class="profile-container">
        <h1 class="fw-bold mb-4">
            <i class="bi bi-person-check"></i> Thông Tin Tài Khoản
        </h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="profile-card">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="fw-bold mb-4">Thông Tin Cá Nhân</h4>

                    <div class="form-section">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control profile-input" value="@Model.Email" disabled />
                        <small class="text-muted">Không thể thay đổi địa chỉ email</small>
                    </div>

                    <form method="post" action="/Customer/UpdateProfile">
                        @Html.AntiForgeryToken()

                        <div class="form-section">
                            <label for="fullName" class="form-label">Họ và Tên</label>
                            <input type="text" id="fullName" name="fullName" class="form-control profile-input" value="@Model.FullName" required />
                        </div>

                        <div class="form-section">
                            <label for="phone" class="form-label">Số Điện Thoại</label>
                            <input type="tel" id="phone" name="phone" class="form-control profile-input" value="@Model.Phone" />
                        </div>

                        <button type="submit" class="submit-btn">
                            <i class="bi bi-check-lg"></i> Cập Nhật Thông Tin
                        </button>
                    </form>
                </div>

                <div class="col-md-6">
                    <h4 class="fw-bold mb-4">Chi Tiết Tài Khoản</h4>

                    <div class="info-row">
                        <span class="info-label">Ngày Tham Gia:</span>
                        <span class="info-value">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Lần Đăng Nhập Cuối:</span>
                        <span class="info-value">
                            @if (Model.LastLoginAt.HasValue)
                            {
                                @Model.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">Chưa cập nhật</span>
                            }
                        </span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Trạng Thái:</span>
                        <span class="info-value">
                            <span class="badge bg-success">Hoạt Động</span>
                        </span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Tổng Đơn Hàng:</span>
                        <span class="info-value">@Model.TotalOrders</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Tổng Chi Tiêu:</span>
                        <span class="info-value">@Model.TotalSpent.ToString("N0")₫</span>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <div class="row">
                <div class="col-md-6">
                    <a href="/Customer/Dashboard" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Quay Lại Dashboard
                    </a>
                </div>
                <div class="col-md-6 text-end">
                    <a href="/Account/ChangePassword" class="btn btn-warning">
                        <i class="bi bi-lock"></i> Đổi Mật Khẩu
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
