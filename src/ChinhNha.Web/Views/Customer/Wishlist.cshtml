@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<style>
    .wishlist-wrap {
        background: #f8fff8;
        border: 2px solid #c8e6c9;
        border-radius: 12px;
        padding: 1.25rem;
    }

    .wishlist-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .wishlist-table th {
        background: #e8f5e9;
        color: #1b5e20;
        font-weight: 700;
    }

    .wishlist-img {
        width: 56px;
        height: 56px;
        object-fit: contain;
        border-radius: 8px;
        border: 1px solid #ddd;
        background: #fff;
    }

    .wishlist-action-btn {
        min-width: 120px;
    }

    .wishlist-mobile-card {
        display: none;
    }

    @@media (max-width: 767.98px) {
        .wishlist-wrap {
            padding: 1rem;
        }

        .wishlist-header {
            align-items: stretch;
        }

        .wishlist-header .d-flex {
            width: 100%;
        }

        .wishlist-header .btn {
            flex: 1 1 0;
        }

        .wishlist-desktop {
            display: none;
        }

        .wishlist-mobile-card {
            display: block;
            border: 1px solid #dfe6df;
            border-radius: 12px;
            padding: 0.9rem;
            background: #fff;
            margin-bottom: 0.85rem;
        }

        .wishlist-mobile-top {
            display: flex;
            gap: 0.75rem;
            align-items: flex-start;
            margin-bottom: 0.85rem;
        }

        .wishlist-mobile-card .wishlist-img {
            width: 64px;
            height: 64px;
            flex-shrink: 0;
        }

        .wishlist-mobile-meta {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.5rem;
            font-size: 0.92rem;
            margin-bottom: 0.85rem;
        }

        .wishlist-mobile-actions {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.5rem;
        }

        .wishlist-action-btn {
            min-width: 0;
            width: 100%;
        }
    }
</style>

<div class="container my-4 my-md-5">
    <div class="wishlist-wrap">
        <div class="wishlist-header">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-heart-fill text-danger me-2"></i>Danh sách yêu thích</h2>
                <small class="text-muted">Theo dõi sản phẩm bạn quan tâm và phát hiện giá giảm nhanh.</small>
            </div>
            <div class="d-flex align-items-center gap-2">
                <a class="btn btn-outline-success btn-sm" href="/Product"><i class="bi bi-shop me-1"></i>Tiếp tục mua sắm</a>
                <button class="btn btn-success btn-sm" type="button" onclick="loadWishlist()"><i class="bi bi-arrow-repeat me-1"></i>Tải lại</button>
            </div>
        </div>

        <div id="wishlistAlert"></div>

        <div class="table-responsive wishlist-desktop">
            <table class="table table-hover align-middle wishlist-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-end">Giá hiện tại</th>
                        <th class="text-end">Biến động giá</th>
                        <th class="text-center">Ưu tiên</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody id="wishlistBody">
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Đang tải dữ liệu...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div id="wishlistMobileBody" class="wishlist-mobile-list"></div>
    </div>
</div>

@section Scripts {
    <script>
        function fmtPrice(value) {
            if (value == null) return '-';
            return new Intl.NumberFormat('vi-VN').format(value) + 'đ';
        }

        function renderAlert(message, type) {
            const holder = document.getElementById('wishlistAlert');
            holder.innerHTML = '<div class="alert alert-' + type + ' py-2">' + message + '</div>';
        }

        async function markPurchased(productId) {
            const res = await fetch('/api/Wishlist/product/' + productId + '/purchased', {
                method: 'POST',
                credentials: 'include'
            });

            if (!res.ok) {
                renderAlert('Không thể cập nhật trạng thái đã mua.', 'danger');
                return;
            }

            renderAlert('Đã đánh dấu sản phẩm là đã mua.', 'success');
            await loadWishlist();
        }

        async function removeItem(productId) {
            if (typeof removeFromWishlist !== 'function') {
                return;
            }

            if (!confirm('Bạn chắc chắn muốn xóa sản phẩm này khỏi wishlist?')) {
                return;
            }

            const result = await removeFromWishlist(productId);
            if (result && result.success) {
                renderAlert('Đã xóa sản phẩm khỏi wishlist.', 'success');
                await loadWishlist();
            } else {
                renderAlert('Không thể xóa sản phẩm khỏi wishlist.', 'danger');
            }
        }

        function renderRows(items) {
            const body = document.getElementById('wishlistBody');
            const mobileBody = document.getElementById('wishlistMobileBody');
            if (!items || items.length === 0) {
                body.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Wishlist đang trống. <a href="/Product">Khám phá sản phẩm ngay</a>.</td></tr>';
                mobileBody.innerHTML = '<div class="text-center text-muted py-4">Wishlist đang trống. <a href="/Product">Khám phá sản phẩm ngay</a>.</div>';
                return;
            }

            body.innerHTML = items.map(function (item) {
                const currentPrice = item.productSalePrice ?? item.productPrice;
                const priceChange = item.priceChange;
                let priceChangeHtml = '<span class="text-muted">-</span>';
                if (priceChange != null) {
                    if (priceChange < 0) {
                        priceChangeHtml = '<span class="text-success fw-bold">' + fmtPrice(priceChange) + '</span>';
                    } else if (priceChange > 0) {
                        priceChangeHtml = '<span class="text-danger fw-bold">+' + fmtPrice(priceChange) + '</span>';
                    } else {
                        priceChangeHtml = '<span class="text-muted">0đ</span>';
                    }
                }

                const purchasedBadge = item.purchasedAt
                    ? '<span class="badge text-bg-success">Đã mua</span>'
                    : '<span class="badge text-bg-warning">Đang theo dõi</span>';

                return '<tr>'
                    + '<td>'
                    + '<div class="d-flex align-items-center gap-2">'
                    + '<img class="wishlist-img" src="' + (item.productImage || '/images/no-image.png') + '" alt="' + (item.productName || '') + '" onerror="this.src=\'/images/no-image.png\'" />'
                    + '<div>'
                        + '<div class="fw-semibold">' + (item.productName || 'Sản phẩm') + '</div>'
                        + '<small class="text-muted">Thêm lúc: ' + new Date(item.addedAt).toLocaleString('vi-VN') + '</small>'
                    + '</div></div></td>'
                    + '<td class="text-end fw-bold">' + fmtPrice(currentPrice) + '</td>'
                    + '<td class="text-end">' + priceChangeHtml + '</td>'
                    + '<td class="text-center">' + (item.priority || 3) + '/5</td>'
                    + '<td class="text-center">' + purchasedBadge + '</td>'
                    + '<td class="text-end">'
                    + '<div class="d-flex justify-content-end flex-wrap gap-2">'
                        + '<a class="btn btn-outline-primary btn-sm wishlist-action-btn" href="/Product?searchQuery=' + encodeURIComponent(item.productName || '') + '">Xem SP</a>'
                        + (item.purchasedAt ? '' : '<button class="btn btn-outline-success btn-sm wishlist-action-btn" type="button" onclick="markPurchased(' + item.productId + ')">Đã mua</button>')
                        + '<button class="btn btn-outline-danger btn-sm wishlist-action-btn" type="button" onclick="removeItem(' + item.productId + ')">Xóa</button>'
                    + '</div></td>'
                    + '</tr>';
            }).join('');

            mobileBody.innerHTML = items.map(function (item) {
                const currentPrice = item.productSalePrice ?? item.productPrice;
                const priceChange = item.priceChange;
                let priceChangeHtml = '<span class="text-muted">-</span>';
                if (priceChange != null) {
                    if (priceChange < 0) {
                        priceChangeHtml = '<span class="text-success fw-bold">' + fmtPrice(priceChange) + '</span>';
                    } else if (priceChange > 0) {
                        priceChangeHtml = '<span class="text-danger fw-bold">+' + fmtPrice(priceChange) + '</span>';
                    } else {
                        priceChangeHtml = '<span class="text-muted">0đ</span>';
                    }
                }

                const purchasedBadge = item.purchasedAt
                    ? '<span class="badge text-bg-success">Đã mua</span>'
                    : '<span class="badge text-bg-warning">Đang theo dõi</span>';

                return '<div class="wishlist-mobile-card">'
                    + '<div class="wishlist-mobile-top">'
                    + '<img class="wishlist-img" src="' + (item.productImage || '/images/no-image.png') + '" alt="' + (item.productName || '') + '" onerror="this.src=\'/images/no-image.png\'" />'
                    + '<div class="flex-grow-1">'
                        + '<div class="fw-semibold mb-1">' + (item.productName || 'Sản phẩm') + '</div>'
                        + '<div class="small text-muted mb-2">Thêm lúc: ' + new Date(item.addedAt).toLocaleString('vi-VN') + '</div>'
                    + purchasedBadge
                    + '</div></div>'
                    + '<div class="wishlist-mobile-meta">'
                        + '<div><div class="text-muted small">Giá hiện tại</div><div class="fw-bold">' + fmtPrice(currentPrice) + '</div></div>'
                        + '<div><div class="text-muted small">Biến động</div><div>' + priceChangeHtml + '</div></div>'
                        + '<div><div class="text-muted small">Ưu tiên</div><div class="fw-semibold">' + (item.priority || 3) + '/5</div></div>'
                        + '<div><div class="text-muted small">Trạng thái</div><div>' + purchasedBadge + '</div></div>'
                    + '</div>'
                    + '<div class="wishlist-mobile-actions">'
                        + '<a class="btn btn-outline-primary btn-sm wishlist-action-btn" href="/Product?searchQuery=' + encodeURIComponent(item.productName || '') + '">Xem SP</a>'
                        + (item.purchasedAt ? '' : '<button class="btn btn-outline-success btn-sm wishlist-action-btn" type="button" onclick="markPurchased(' + item.productId + ')">Đã mua</button>')
                        + '<button class="btn btn-outline-danger btn-sm wishlist-action-btn" type="button" onclick="removeItem(' + item.productId + ')">Xóa</button>'
                    + '</div>'
                    + '</div>';
            }).join('');
        }

        async function loadWishlist() {
            const body = document.getElementById('wishlistBody');
            const mobileBody = document.getElementById('wishlistMobileBody');
            body.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Đang tải dữ liệu...</td></tr>';
            mobileBody.innerHTML = '<div class="text-center text-muted py-4">Đang tải dữ liệu...</div>';

            try {
                const res = await fetch('/api/Wishlist', { credentials: 'include' });
                if (res.status === 401) {
                    window.location.href = '/Account/Login';
                    return;
                }
                if (!res.ok) {
                    renderAlert('Không thể tải dữ liệu wishlist.', 'danger');
                    body.innerHTML = '<tr><td colspan="6" class="text-center text-danger py-4">Lỗi tải dữ liệu.</td></tr>';
                    return;
                }

                const data = await res.json();
                renderRows(data);
                if (typeof updateWishlistCount === 'function') {
                    updateWishlistCount();
                }
            } catch {
                renderAlert('Có lỗi kết nối khi tải wishlist.', 'danger');
                body.innerHTML = '<tr><td colspan="6" class="text-center text-danger py-4">Không kết nối được máy chủ.</td></tr>';
            }
        }

        document.addEventListener('DOMContentLoaded', loadWishlist);
    </script>
}
