@using ChinhNha.Web.Models
@model CartViewModel

@{
    ViewData["Title"] = "Giỏ hàng";
}

<style>
    .cart-header { background-color: #f8f9fa; font-weight: 600; padding: 1rem; border-radius: 10px; }
    .cart-item { border-bottom: 1px solid #eee; padding: 1.5rem 0; }
    .cart-img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; background-color: #f8f9fa; }
    .qty-input { width: 60px; text-align: center; border: 1px solid #ddd; border-radius: 5px; }
    .btn-checkout { background-color: #2E7D32; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-weight: 600; width: 100%; transition: all 0.3s; }
    .btn-checkout:hover { background-color: #1B5E20; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(46, 125, 50, 0.2); }
    .order-summary { background-color: #f8f9fa; border-radius: 15px; padding: 2rem; position: sticky; top: 100px; }
</style>

<div class="container mb-5">
    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

    @if (Model.Cart != null && Model.Cart.Items.Any())
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="cart-header d-none d-md-flex row text-muted mb-3">
                    <div class="col-6">Sản phẩm</div>
                    <div class="col-2 text-center">Đơn giá</div>
                    <div class="col-2 text-center">Số lượng</div>
                    <div class="col-2 text-end">Tổng</div>
                </div>

                @foreach (var item in Model.Cart.Items)
                {
                    <div class="cart-item row align-items-center">
                        <div class="col-md-6 col-12 mb-3 mb-md-0 d-flex align-items-center gap-3">
                            <form method="post" action="/Cart/RemoveFromCart" class="m-0">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button type="submit" class="btn btn-link text-danger p-0" title="Xóa"><i class="bi bi-trash3"></i></button>
                            </form>
                            <div>
                                <img src="@item.ProductImageUrl" alt="@item.ProductName" class="cart-img" onerror="this.src='data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2280%22%20height%3D%2280%22%20viewBox%3D%220%200%2080%2080%22%3E%3Crect%20fill%3D%22%23f8f9fa%22%20width%3D%2280%22%20height%3D%2280%22%2F%3E%3Ctext%20fill%3D%22%239ca3af%22%20font-family%3D%22sans-serif%22%20font-size%3D%2224%22%20dy%3D%228.4%22%20font-weight%3D%22bold%22%20x%3D%2250%25%22%20y%3D%2250%25%22%20text-anchor%3D%22middle%22%3E%F0%9F%8C%BE%3C%2Ftext%3E%3C%2Fsvg%3E'" />
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold">@item.ProductName</h6>
                                <small class="text-muted">Mã: SP-@item.VariantId</small>
                            </div>
                        </div>
                        <div class="col-md-2 col-4 text-md-center">
                            <span class="d-md-none text-muted small">Đơn giá: </span>
                            <span class="fw-medium">@item.UnitPrice.ToString("N0")₫</span>
                        </div>
                        <div class="col-md-2 col-4 text-center">
                            <input type="number" class="qty-input" value="@item.Quantity" min="1" readonly />
                        </div>
                        <div class="col-md-2 col-4 text-end">
                            <span class="text-success fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0"))₫</span>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="order-summary shadow-sm">
                    <h4 class="fw-bold mb-4">Tóm tắt đơn hàng</h4>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Tạm tính (@Model.Cart.Items.Sum(x => x.Quantity) sản phẩm)</span>
                        <span class="fw-medium">@Model.Cart.Items.Sum(x => x.UnitPrice * x.Quantity).ToString("N0")₫</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí giao hàng</span>
                        <span class="fw-medium">Liên hệ</span>
                    </div>
                    
                    <hr class="my-4" />
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Tổng cộng</span>
                        <span class="fw-bold fs-4 text-success">@Model.Cart.Items.Sum(x => x.UnitPrice * x.Quantity).ToString("N0")₫</span>
                    </div>

                    <a href="/Checkout" class="btn btn-checkout mb-3">TIẾN HÀNH THANH TOÁN</a>
                    <a href="/Product" class="btn btn-outline-secondary w-100" style="border-radius: 10px;">Tiếp tục mua hàng</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5">
            <i class="bi bi-cart-x text-muted mb-4" style="font-size: 5rem;"></i>
            <h3 class="fw-bold mb-3">Giỏ hàng trống</h3>
            <p class="text-muted mb-4">Bạn chưa chọn sản phẩm nào để thêm vào giỏ hàng.</p>
            <a href="/Product" class="btn btn-checkout d-inline-block" style="width: auto;">Mua sắm ngay</a>
        </div>
    }
</div>
