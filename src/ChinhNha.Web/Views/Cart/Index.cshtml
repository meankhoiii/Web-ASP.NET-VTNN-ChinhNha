@using ChinhNha.Web.Models
@model CartViewModel

@{
    ViewData["Title"] = "Giỏ Hàng Của Bà Con";
}

<style>
    /* Farmer-friendly UI for Cart */
    .cart-container {
        background-color: #fff;
        border: 2px solid var(--green-main);
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 30px;
    }

    .cart-title {
        background: linear-gradient(135deg, var(--green-main), var(--green-dark));
        color: white;
        padding: 12px 18px;
        font-size: clamp(1.4rem, 4vw, 1.8rem);
        font-weight: 900;
        text-transform: uppercase;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .cart-item-row {
        border-bottom: 2px dashed var(--border-color);
        padding-bottom: 16px;
        margin-bottom: 16px;
    }

    .item-img {
        width: 100px;
        height: 100px;
        object-fit: contain;
        border: 2px solid #ccc;
        background: #f9f9f9;
    }

    .item-name {
        font-size: clamp(1.2rem, 3vw, 1.4rem);
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 5px;
        line-height: 1.3;
    }

    .item-sku {
        font-size: clamp(0.95rem, 2.5vw, 1.1rem);
        color: var(--text-muted);
        font-weight: bold;
    }

    .item-price {
        font-size: clamp(1.1rem, 3vw, 1.3rem);
        color: var(--price-red);
        font-weight: bold;
    }

    .item-total {
        font-size: clamp(1.3rem, 3.5vw, 1.5rem);
        color: var(--price-red);
        font-weight: 900;
    }

    .qty-input {
        width: 70px;
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        text-align: center;
        font-weight: bold;
        border: 2px solid var(--border-color);
        padding: 5px;
        border-radius: 4px;
    }

    .qty-stepper {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .qty-btn {
        width: 40px;
        height: 40px;
        border: 2px solid var(--green-main);
        background-color: #f4fff4;
        color: var(--text-main);
        border-radius: 6px;
        font-size: 1.2rem;
        font-weight: 900;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .qty-btn:hover {
        background-color: #e8f5e9;
    }

    .btn-delete {
        background-color: var(--bg-main);
        color: var(--price-red);
        border: 2px solid var(--price-red);
        font-size: clamp(0.9rem, 2.5vw, 1.1rem);
        font-weight: bold;
        padding: 5px 12px;
        border-radius: 4px;
    }
    .btn-delete:hover {
        background-color: var(--price-red);
        color: white;
    }

    .summary-box {
        background-color: var(--bg-card);
        border: 3px solid var(--green-main);
        padding: 30px;
        border-radius: 8px;
    }

    .summary-total-label {
        font-size: clamp(1.2rem, 3.5vw, 1.5rem);
        font-weight: 900;
        color: var(--text-main);
    }

    .summary-total-value {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        font-weight: 900;
        color: var(--price-red);
    }

    .btn-checkout {
        background-color: var(--orange-cta);
        color: #fff;
        border: 2px solid #BF360C;
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        font-weight: 900;
        padding: 15px;
        border-radius: 8px;
        width: 100%;
        text-transform: uppercase;
        display: block;
        text-align: center;
        text-decoration: none;
    }
    .btn-checkout:hover {
        background-color: #BF360C;
        color: #fff;
    }
</style>

<div class="row">
    <div class="col-lg-8">
        <div class="cart-container">
            <h2 class="cart-title"><i class="bi bi-cart-check-fill me-2"></i> GIỎ HÀNG GỒM CÓ</h2>

            @if (Model.Cart != null && Model.Cart.Items.Any())
            {
                <div class="d-none d-md-flex text-muted fw-bold fs-4 mb-3 border-bottom border-dark pb-2">
                    <div class="col-5">Tên Sản Phẩm</div>
                    <div class="col-2 text-center">Đơn Giá</div>
                    <div class="col-2 text-center">Số Lượng</div>
                    <div class="col-3 text-end">Thành Tiền</div>
                </div>

                @foreach (var item in Model.Cart.Items)
                {
                    <div class="row cart-item-row align-items-center">
                        <div class="col-md-5 d-flex align-items-center gap-3 mb-3 mb-md-0">
                            <img src="@item.ProductImageUrl" alt="@item.ProductName" class="item-img" onerror="this.src='/images/no-image.png'" />
                            <div>
                                <div class="item-name">@item.ProductName</div>
                                <div class="item-sku">Mã hàng: SP-@item.VariantId</div>
                                <form method="post" action="/Cart/RemoveFromCart" class="mt-2 text-start">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn-delete"><i class="bi bi-trash-fill me-1"></i> XÓA BỎ</button>
                                </form>
                            </div>
                        </div>
                        <div class="col-md-2 text-center d-flex d-md-block justify-content-between mb-2 mb-md-0">
                            <span class="d-md-none fw-bold fs-4">Đơn Giá: </span>
                            <span class="item-price">@item.UnitPrice.ToString("N0")đ</span>
                        </div>
                        <div class="col-md-2 text-center d-flex d-md-block justify-content-between mb-2 mb-md-0">
                            <span class="d-md-none fw-bold fs-4">Số Lượng: </span>
                            <form method="post" action="/Cart/UpdateQuantity" class="qty-stepper m-0">
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button type="submit" name="quantity" value="@(Math.Max(1, item.Quantity - 1))" class="qty-btn" aria-label="Giảm số lượng">-</button>
                                <input type="number" class="qty-input" value="@item.Quantity" min="1" readonly aria-label="Số lượng hiện tại" />
                                <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="qty-btn" aria-label="Tăng số lượng">+</button>
                            </form>
                        </div>
                        <div class="col-md-3 text-end d-flex d-md-block justify-content-between">
                            <span class="d-md-none fw-bold fs-4">Cộng: </span>
                            <span class="item-total">@((item.UnitPrice * item.Quantity).ToString("N0"))đ</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
                    <h2 class="mt-3 font-weight-bold text-danger">GIỎ HÀNG CHƯA CÓ GÌ!</h2>
                    <p class="fs-4 text-dark mt-2 mb-4">Bà con hãy quay lại Cửa hàng để chọn mua vật tư nông nghiệp nhé.</p>
                    <a href="/Product" class="btn btn-primary fs-3 px-5 py-3"><i class="bi bi-arrow-left-circle-fill me-2"></i> TRỞ LẠI CỬA HÀNG</a>
                </div>
            }
        </div>
    </div>

    @if (Model.Cart != null && Model.Cart.Items.Any())
    {
        <div class="col-lg-4">
            <div class="summary-box shadow">
                <h3 class="fw-bold mb-4 fs-2 border-bottom border-dark pb-2"><i class="bi bi-receipt"></i> TỔNG KẾT ĐƠN HÀNG</h3>
                
                <div class="d-flex justify-content-between mb-3 fs-4">
                    <span>Số lượng:</span>
                    <span class="fw-bold">@Model.Cart.Items.Sum(x => x.Quantity) bao/chai</span>
                </div>
                
                <div class="d-flex justify-content-between mb-3 fs-4 border-bottom border-2 pb-3">
                    <span>Tiền vận chuyển:</span>
                    <span class="fw-bold text-success">Liên hệ thỏa thuận</span>
                </div>
                
                <div class="d-flex justify-content-between mt-4 mb-4 align-items-center">
                    <span class="summary-total-label">TỔNG TIỀN:</span>
                    <span class="summary-total-value">@Model.Cart.Items.Sum(x => x.UnitPrice * x.Quantity).ToString("N0")đ</span>
                </div>

                <div class="alert alert-warning fs-5 fw-bold text-dark border-warning">
                    <i class="bi bi-info-circle-fill text-danger me-1"></i> Nhấn nút màu vàng dưới đây để gửi đơn hàng cho phía đại lý.
                </div>

                <a href="/Checkout" class="btn-checkout"><i class="bi bi-pen-fill me-2"></i> ĐIỀN THÔNG TIN ĐẶT HÀNG</a>
                
                <div class="text-center mt-4">
                    <a href="/Product" class="fs-4 fw-bold text-success text-decoration-underline"><i class="bi bi-bag-plus-fill me-1"></i> Mua thêm sản phẩm khác</a>
                </div>
            </div>
        </div>
    }
</div>
