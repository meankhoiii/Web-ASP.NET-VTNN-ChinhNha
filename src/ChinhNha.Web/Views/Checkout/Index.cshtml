@using ChinhNha.Web.Models
@model CheckoutViewModel

@{
    ViewData["Title"] = "Điền thông tin nhận phân bón";
}

<style>
    .form-label {
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        font-weight: bold;
        color: var(--green-main);
        margin-bottom: 8px;
    }
    
    .form-control {
        border: 3px solid var(--green-main) !important;
        font-size: clamp(1rem, 3vw, 1.3rem) !important; /* iOS already fixed globally but keep logic */
        padding: 12px !important;
        border-radius: 8px !important;
        background-color: var(--bg-card);
    }
    .form-control:focus {
        border-color: var(--orange-cta) !important;
        box-shadow: 0 0 0 4px rgba(230, 81, 0, 0.2) !important;
    }

    .checkout-section {
        background-color: #fff;
        border: 3px solid var(--green-main);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
    }

    .section-title {
        background: linear-gradient(135deg, var(--green-main), var(--green-dark));
        color: white;
        padding: 12px 15px;
        font-size: clamp(1.3rem, 4vw, 1.8rem);
        font-weight: 900;
        text-transform: uppercase;
        margin-top: -20px;
        margin-left: -20px;
        margin-right: -20px;
        margin-bottom: 20px;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
        text-align: center;
    }

    .btn-checkout {
        background-color: var(--orange-cta);
        color: #fff;
        border: 4px solid #BF360C;
        font-size: clamp(1.3rem, 4vw, 1.8rem);
        font-weight: 900;
        padding: 15px;
        border-radius: 12px;
        width: 100%;
        text-transform: uppercase;
        display: block;
        text-align: center;
        box-shadow: 0 5px 0 #BF360C;
        transition: transform 0.1s, box-shadow 0.1s;
    }
    .btn-checkout:active {
        box-shadow: 0 0 0 #BF360C;
        transform: translateY(5px);
    }

    .payment-option {
        border: 3px solid #ccc;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        background-color: #f9f9f9;
        cursor: pointer;
    }
    .payment-option.active {
        border-color: var(--green-main);
        background-color: var(--bg-main);
    }
    .payment-radio {
        width: 25px;
        height: 25px;
        accent-color: var(--green-main);
    }
    .payment-label {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        font-weight: bold;
        color: var(--text-main);
        margin-left: 15px;
        cursor: pointer;
    }

    .order-totals {
        font-size: clamp(1.1rem, 3vw, 1.5rem);
        font-weight: bold;
    }
    .order-totals .total-amount {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        color: var(--price-red);
        font-weight: 900;
    }
</style>

<div class="row">
    <div class="col-12 mb-4">
        <a href="/Cart" class="btn btn-outline-dark fs-4 fw-bold"><i class="bi bi-arrow-left-circle-fill me-2"></i> TRỞ VỀ GIỎ HÀNG</a>
    </div>
</div>

<form asp-action="Index" method="post" id="checkoutForm">
    <div class="row">
        <div class="col-lg-7">
            <div class="checkout-section">
                <h2 class="section-title"><i class="bi bi-truck me-2"></i> THÔNG TIN NHẬN HÀNG</h2>
                
                <div asp-validation-summary="ModelOnly" class="alert alert-danger fs-5 fw-bold mb-3"></div>

                <div class="mb-4">
                    <label asp-for="ReceiverName" class="form-label">Tên người nhận (Họ & Tên):</label>
                    <input asp-for="ReceiverName" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" />
                    <span asp-validation-for="ReceiverName" class="text-danger fw-bold fs-5 mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ReceiverPhone" class="form-label">Điện thoại liên lạc:</label>
                    <input asp-for="ReceiverPhone" class="form-control" placeholder="Bắt buộc để nhà xe gọi giao hàng" />
                    <span asp-validation-for="ReceiverPhone" class="text-danger fw-bold fs-5 mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ShippingAddress" class="form-label">Địa chỉ rẫy / Nhà chi tiết:</label>
                    <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Ghi rõ xã, huyện, tỉnh để tính cước xe rẻ nhất..."></textarea>
                    <span asp-validation-for="ShippingAddress" class="text-danger fw-bold fs-5 mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Note" class="form-label">Ghi chú cho Đại lý (nếu có):</label>
                    <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ví dụ: Giao sáng thứ 7..."></textarea>
                </div>
            </div>

            <div class="checkout-section">
                <h2 class="section-title"><i class="bi bi-cash-coin me-2"></i> CÁCH THỨC THANH TOÁN</h2>
                
                <label class="payment-option d-flex align-items-center active" for="codPayment">
                    <input class="payment-radio" type="radio" asp-for="PaymentMethod" value="COD" id="codPayment" checked onchange="document.querySelectorAll('.payment-option').forEach(e => e.classList.remove('active')); this.parentElement.classList.add('active');">
                    <span class="payment-label">TRẢ TIỀN KHI NHẬN HÀNG (TIỀN MẶT)</span>
                </label>
                
                <label class="payment-option d-flex align-items-center" for="vnpayPayment">
                    <input class="payment-radio" type="radio" asp-for="PaymentMethod" value="VNPay" id="vnpayPayment" onchange="document.querySelectorAll('.payment-option').forEach(e => e.classList.remove('active')); this.parentElement.classList.add('active');">
                    <div>
                        <span class="payment-label">CHUYỂN KHOẢN TRƯỚC (QUA THẺ ATM / VNPAY)</span>
                        <div class="fs-5 text-muted mt-2 fw-bold" style="margin-left: 40px;">Hệ thống sẽ chuyển qua trang ngân hàng để nhập thẻ.</div>
                    </div>
                </label>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="checkout-section bg-light border-danger border-4">
                <h2 class="section-title bg-danger"><i class="bi bi-clipboard-check-fill me-2"></i> PHIẾU ĐẶT HÀNG CỦA BẠN</h2>
                
                <div class="mb-4 bg-white p-3 border border-2 rounded" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var item in Model.Cart.Items)
                    {
                        <div class="d-flex align-items-start mb-3 border-bottom pb-2">
                            <img src="@item.ProductImageUrl" class="cart-item-img me-3 border" style="width: 80px; height: 80px; object-fit: contain;" onerror="this.src='/images/no-image.png'" />
                            <div class="flex-grow-1">
                                <h4 class="mb-1 fw-bold text-dark">@item.ProductName</h4>
                                <div class="fs-4 text-danger fw-bold">@item.UnitPrice.ToString("N0")đ x @item.Quantity</div>
                                <div class="fs-5 text-muted fw-bold">Thành tiền: @((item.UnitPrice * item.Quantity).ToString("N0"))đ</div>
                            </div>
                        </div>
                    }
                </div>
                
                <div class="order-totals">
                    <div class="d-flex justify-content-between mb-3 text-dark">
                        <span>Tiền Phân Bón:</span>
                        <span>@Model.Cart.Items.Sum(x => x.UnitPrice * x.Quantity).ToString("N0")đ</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-3 text-dark border-bottom border-dark border-2 pb-3">
                        <span>Cước phí chở hàng:</span>
                        <span class="text-danger text-decoration-underline">Đại lý sẽ gọi báo giá cước</span>
                    </div>
                    
                    <div class="d-flex justify-content-between mb-4 mt-3">
                        <span class="fs-2 text-danger">TỔNG CỘNG:</span>
                        <span class="total-amount">@Model.Cart.Items.Sum(x => x.UnitPrice * x.Quantity).ToString("N0")đ</span>
                    </div>

                    <button type="submit" class="btn-checkout"><i class="bi bi-send-check-fill me-2"></i> XÁC NHẬN GỬI ĐƠN</button>
                    <div class="text-center mt-3 fs-5 fw-bold text-muted">
                        Sau khi gửi đơn, Đại lý sẽ gọi điện thoại xác nhận trong vòng 15 phút.
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
