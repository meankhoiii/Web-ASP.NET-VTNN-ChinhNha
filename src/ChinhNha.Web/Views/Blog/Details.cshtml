@model ChinhNha.Application.DTOs.Blogs.BlogPostDto
@{
    ViewData["Title"] = Model.MetaTitle ?? Model.Title;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">Trang chủ</a></li>
                    <li class="breadcrumb-item"><a href="/tin-tuc" class="text-success text-decoration-none">Tin tức</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Html.Raw(Model.Title.Length > 30 ? Model.Title.Substring(0, 30) + "..." : Model.Title)</li>
                </ol>
            </nav>

            <div class="blog-header mb-4 border-bottom pb-4">
                <span class="badge bg-success bg-opacity-10 text-success mb-3 px-3 py-2 rounded-pill fs-6 fw-normal">@Model.CategoryName</span>
                <h1 class="fw-bold mb-3 display-4 lh-tight">@Model.Title</h1>
                
                <div class="d-flex align-items-center text-muted">
                    <div class="me-4"><i class="bi bi-clock me-1"></i> Đăng lúc: @Model.PublishedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                    <div><i class="bi bi-person-circle me-1"></i> Đăng bởi: @(Model.AuthorName ?? "Quản trị viên")</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
            {
                <div class="blog-hero-image mb-5 rounded-4 overflow-hidden shadow-sm">
                    <img src="@Model.FeaturedImageUrl" alt="@Model.Title" class="w-100 img-fluid" style="max-height: 500px; object-fit: cover; width: 100%;">
                </div>
            }

            <div class="blog-content fs-5 lh-lg text-dark fw-light">
                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <div class="lead fw-normal fst-italic text-secondary mb-4 border-start border-success border-4 ps-3">
                        @Model.Summary
                    </div>
                }
                
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-5 pt-4 border-top text-center">
                <div class="d-flex justify-content-center gap-3">
                    <span class="fw-bold me-2 align-self-center">Chia sẻ:</span>
                    <a href="#" class="btn btn-outline-primary rounded-circle" style="width:40px;height:40px;line-height:26px;"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="btn btn-outline-info rounded-circle" style="width:40px;height:40px;line-height:26px;"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="btn btn-outline-success rounded-circle" style="width:40px;height:40px;line-height:26px;"><i class="bi bi-link-45deg"></i></a>
                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    .blog-content img {
        max-width: 100%;
        height: auto;
        border-radius: 0.5rem;
        margin: 1.5rem 0;
        box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,.075);
    }
    .blog-content h2, .blog-content h3 {
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
    }
    .lh-tight {
        line-height: 1.2 !important;
    }
</style>
