@model IEnumerable<ChinhNha.Application.DTOs.Blogs.BlogPostDto>
@{
    ViewData["Title"] = "Tin tức & Kiến thức Nông nghiệp";
}

<div class="container py-5">
    <div class="row mb-5 text-center">
        <div class="col-lg-8 mx-auto">
            <h1 class="fw-bold text-success mb-3">Tin tức & Kiến thức</h1>
            <p class="lead text-muted">Cập nhật những thông tin mới nhất về kỹ thuật nông nghiệp, xu hướng thị trường và mẹo chăm sóc cây trồng.</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var p in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm blog-card rounded-4 overflow-hidden">
                    <a href="/tin-tuc/@p.Slug" class="text-decoration-none">
                        <div class="blog-img-wrapper" style="height: 220px; overflow: hidden;">
                            <img src="@(p.FeaturedImageUrl ?? "/images/bg-home.jpg")" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="@p.Title">
                        </div>
                    </a>
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="mb-2">
                            <span class="badge bg-success bg-opacity-10 text-success me-2">@p.CategoryName</span>
                            <small class="text-muted"><i class="bi bi-clock me-1"></i> @p.PublishedAt?.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h5 class="card-title fw-bold mb-3">
                            <a href="/tin-tuc/@p.Slug" class="text-dark text-decoration-none text-truncate-2">@p.Title</a>
                        </h5>
                        <p class="card-text text-muted mb-4 flex-grow-1 text-truncate-3">@p.Summary</p>
                        <a href="/tin-tuc/@p.Slug" class="btn btn-outline-success border-2 rounded-pill fw-bold align-self-start mt-auto">Xem chi tiết <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted fs-5"><i class="bi bi-journal-x fs-1 d-block mb-3"></i> Tạm thời chưa có bài viết nào được xuất bản.</div>
            </div>
        }
    </div>
</div>

<style>
    .blog-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .blog-img-wrapper img {
        transition: transform 0.5s ease;
    }
    .blog-card:hover .blog-img-wrapper img {
        transform: scale(1.05);
    }
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
