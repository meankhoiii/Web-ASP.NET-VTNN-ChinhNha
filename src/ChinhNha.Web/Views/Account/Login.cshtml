@model ChinhNha.Web.Models.Account.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chính Nha Phân Bón</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        
        body {
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 40%, #388E3C 70%, #66BB6A 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        
        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 24px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 440px;
            animation: slideUp 0.5s ease-out;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .logo-wrap { text-align: center; margin-bottom: 2rem; }
        .logo-icon {
            width: 72px; height: 72px;
            border-radius: 20px;
            background: linear-gradient(135deg, #2E7D32, #66BB6A);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 2rem; margin-bottom: 1rem;
            box-shadow: 0 8px 24px rgba(46, 125, 50, 0.3);
        }
        
        .auth-title  { font-size: 1.8rem; font-weight: 800; color: #1a1a2e; margin-bottom: 0.25rem; }
        .auth-subtitle { color: #6c757d; font-size: 0.95rem; }

        .form-label { font-weight: 600; color: #374151; margin-bottom: 0.4rem; font-size: 0.9rem; }
        
        .input-group-icon {
            position: relative;
        }
        .input-group-icon i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            z-index: 10;
            font-size: 1.1rem;
        }
        .input-group-icon .form-control {
            padding-left: 42px;
            height: 50px;
            border-radius: 12px;
            border: 2px solid #e5e7eb;
            font-size: 0.95rem;
            transition: all 0.3s;
        }
        .input-group-icon .form-control:focus {
            border-color: #2E7D32;
            box-shadow: 0 0 0 4px rgba(46, 125, 50, 0.1);
        }

        .btn-auth {
            background: linear-gradient(135deg, #2E7D32, #388E3C);
            border: none;
            color: white;
            font-weight: 700;
            height: 52px;
            border-radius: 12px;
            font-size: 1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }
        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(46, 125, 50, 0.35);
            color: white;
        }

        .divider { text-align: center; position: relative; margin: 1.5rem 0; }
        .divider::before {
            content: '';
            position: absolute;
            top: 50%; left: 0;
            width: 100%; height: 1px;
            background: #e5e7eb;
        }
        .divider span {
            background: white; padding: 0 12px;
            position: relative; color: #9ca3af; font-size: 0.85rem;
        }

        .link-green { color: #2E7D32; font-weight: 600; text-decoration: none; }
        .link-green:hover { text-decoration: underline; color: #1B5E20; }

        .form-check-label { font-size: 0.9rem; color: #4b5563; }
        .form-check-input:checked { background-color: #2E7D32; border-color: #2E7D32; }

        .back-link { text-align: center; margin-bottom: 1.5rem; }
        .back-link a { color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.9rem; }
        .back-link a:hover { color: white; }
    </style>
</head>
<body>
    <div>
        <div class="back-link">
            <a href="/"><i class="bi bi-arrow-left me-1"></i>Quay về trang chủ</a>
        </div>
        
        <div class="auth-card">
            <div class="logo-wrap">
                <div class="logo-icon">🌿</div>
                <h1 class="auth-title">Chào mừng trở lại</h1>
                <p class="auth-subtitle">Đăng nhập vào tài khoản của bạn</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-envelope"></i>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label"></label>
                        <a href="#" class="link-green small">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group-icon">
                        <i class="bi bi-lock" id="passIcon"></i>
                        <input asp-for="Password" id="passwordInput" class="form-control pe-5" placeholder="••••••••" autocomplete="current-password" style="padding-right: 44px !important;" />
                        <button type="button" onclick="togglePass()" class="btn p-0 border-0" 
                                style="position:absolute; right:14px; top:50%; transform:translateY(-50%); z-index:10; color:#9ca3af;">
                            <i class="bi bi-eye" id="eyeIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" id="rememberMe" />
                    <label asp-for="RememberMe" class="form-check-label" for="rememberMe"></label>
                </div>

                <button type="submit" class="btn btn-auth w-100 mb-4">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                </button>

                <div class="divider"><span>chưa có tài khoản?</span></div>

                <div class="text-center mt-3">
                    <a asp-action="Register" class="btn btn-outline-success w-100 py-3" style="border-radius: 12px; font-weight: 600;">
                        <i class="bi bi-person-plus me-2"></i>Tạo tài khoản mới
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePass() {
            const inp = document.getElementById('passwordInput');
            const eye = document.getElementById('eyeIcon');
            if (inp.type === 'password') {
                inp.type = 'text';
                eye.className = 'bi bi-eye-slash';
            } else {
                inp.type = 'password';
                eye.className = 'bi bi-eye';
            }
        }
    </script>
</body>
</html>
