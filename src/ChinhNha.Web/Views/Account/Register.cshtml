@model ChinhNha.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] - VTNN Chính Nha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        
        body {
            background-color: #E8F5E9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        
        .auth-card {
            background: #ffffff;
            border: 4px solid #2E7D32;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            width: 100%;
            max-width: 500px;
        }

        .logo-wrap { text-align: center; margin-bottom: 2rem; }
        .logo-icon {
            font-size: 3rem;
            color: #2E7D32;
            margin-bottom: 0.5rem;
        }
        
        .auth-title {
            font-size: clamp(1.8rem, 5vw, 2.2rem);
            font-weight: 900;
            color: #111;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }
        .auth-subtitle {
            color: #555;
            font-size: clamp(1.1rem, 3vw, 1.3rem);
            font-weight: 600;
        }

        .form-label {
            font-weight: 700;
            color: #2E7D32;
            margin-bottom: 0.5rem;
            font-size: clamp(1.2rem, 3vw, 1.4rem);
        }
        
        .input-group-icon {
            position: relative;
        }
        .input-group-icon i.icon-prefix {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #2E7D32;
            z-index: 10;
            font-size: 1.5rem;
        }
        .input-group-icon .form-control {
            padding-left: 50px;
            height: 60px;
            border-radius: 8px;
            border: 3px solid #C8E6C9;
            font-size: clamp(1.1rem, 3vw, 1.3rem);
            font-weight: 600;
            background-color: #fefaef;
        }
        .input-group-icon .form-control:focus {
            border-color: #E65100;
            box-shadow: 0 0 0 4px rgba(230, 81, 0, 0.2);
            outline: none;
        }

        .toggle-pw-btn {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 10;
            color: #555;
            background: none;
            border: none;
            padding: 5px;
            font-size: 1.5rem;
        }

        .btn-auth {
            background-color: #E65100;
            border: 3px solid #BF360C;
            color: white;
            font-weight: 900;
            height: 65px;
            border-radius: 8px;
            font-size: clamp(1.3rem, 4vw, 1.6rem);
            text-transform: uppercase;
            box-shadow: 0 4px 0 #BF360C;
            transition: all 0.1s;
        }
        .btn-auth:active {
            box-shadow: 0 0 0 #BF360C;
            transform: translateY(4px);
        }
        .btn-auth:hover {
            background-color: #BF360C;
            color: white;
        }

        .divider {
            text-align: center;
            margin: 2rem 0 1.5rem 0;
            border-bottom: 2px dashed #C8E6C9;
            line-height: 0.1em;
        }
        .divider span {
            background: #fff;
            padding: 0 15px;
            color: #555;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .btn-register {
            background-color: #fff;
            color: #2E7D32;
            border: 3px solid #2E7D32;
            font-weight: 900;
            height: 60px;
            border-radius: 8px;
            font-size: clamp(1.2rem, 3.5vw, 1.4rem);
            text-transform: uppercase;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
        }
        .btn-register:hover {
            background-color: #E8F5E9;
            color: #2E7D32;
        }

        .back-link {
            text-align: center;
            margin-bottom: 1.5rem;
        }
        .back-link a {
            color: #2E7D32;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 700;
            background: #fff;
            padding: 10px 20px;
            border-radius: 30px;
            border: 2px solid #2E7D32;
            display: inline-block;
        }

        .pwd-strength { height: 8px; border-radius: 4px; transition: all 0.3s; margin-top: 10px; }
    </style>
</head>
<body>
    <div>
        <div class="back-link">
            <a href="/"><i class="bi bi-arrow-left-circle-fill me-2"></i>QUAY VỀ TRANG CHỦ</a>
        </div>
        
        <div class="auth-card">
            <div class="logo-wrap">
                <i class="bi bi-person-lines-fill logo-icon"></i>
                <h1 class="auth-title">TẠO TÀI KHOẢN MỚI</h1>
                <p class="auth-subtitle">Nhập thông tin để mở sổ tích điểm mua hàng</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger p-3 fw-bold fs-5 mb-3" role="alert"></div>

            <form asp-action="Register" method="post">
                
                <div class="mb-4">
                    <label asp-for="FullName" class="form-label">Tên của bà con (Họ & Tên gốc)</label>
                    <div class="input-group-icon">
                        <i class="bi bi-person-fill icon-prefix"></i>
                        <input asp-for="FullName" class="form-control" placeholder="VD: Nguyễn Văn Út..." autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger fw-bold fs-6 mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label">Địa chỉ Email (hoặc SĐT)</label>
                    <div class="input-group-icon">
                        <i class="bi bi-envelope-fill icon-prefix"></i>
                        <input asp-for="Email" class="form-control" placeholder="Để liên lạc và lấy lại mật khẩu..." autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger fw-bold fs-6 mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Tạo Mật khẩu (dễ nhớ một chút)</label>
                    <div class="input-group-icon">
                        <i class="bi bi-lock-fill icon-prefix"></i>
                        <input asp-for="Password" id="passwordReg" class="form-control" placeholder="Nhập ít nhất 6 chữ cái/số..." 
                               autocomplete="new-password" oninput="checkStrength(this.value)" style="padding-right: 50px !important;" />
                        <button type="button" onclick="togglePass('passwordReg', 'eyeIcon1')" class="toggle-pw-btn">
                            <i class="bi bi-eye-slash-fill" id="eyeIcon1"></i>
                        </button>
                    </div>
                    <div id="strengthBar" class="pwd-strength bg-secondary mt-2" style="width: 0%;"></div>
                    <div id="strengthText" class="text-muted fw-bold mt-1 fs-6"></div>
                    <span asp-validation-for="Password" class="text-danger fw-bold fs-6 mt-1 d-block"></span>
                </div>

                <div class="mb-5">
                    <label asp-for="ConfirmPassword" class="form-label">Nhập lại Mật khẩu 1 lần nữa</label>
                    <div class="input-group-icon">
                        <i class="bi bi-shield-check icon-prefix"></i>
                        <input asp-for="ConfirmPassword" id="passwordConfirm" class="form-control" placeholder="Nhập giống y chang phía trên..." autocomplete="new-password" style="padding-right: 50px !important;" />
                        <button type="button" onclick="togglePass('passwordConfirm', 'eyeIcon2')" class="toggle-pw-btn">
                            <i class="bi bi-eye-slash-fill" id="eyeIcon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger fw-bold fs-6 mt-1 d-block"></span>
                </div>

                <button type="submit" class="btn btn-auth w-100 mb-2">
                    <i class="bi bi-check-circle-fill me-2 fs-3"></i>ĐĂNG KÝ VÀ LƯU SỔ
                </button>

                <div class="divider"><span>BÀ CON ĐÃ CÓ MÃ RỒI?</span></div>

                <a asp-action="Login" class="btn btn-register w-100">
                    <i class="bi bi-box-arrow-in-right me-2 fs-3"></i> QUA TRANG ĐĂNG NHẬP
                </a>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePass(inputId, iconId) {
            const inp = document.getElementById(inputId);
            const eye = document.getElementById(iconId);
            if (inp.type === 'password') {
                inp.type = 'text';
                eye.className = 'bi bi-eye-fill text-success';
            } else {
                inp.type = 'password';
                eye.className = 'bi bi-eye-slash-fill';
            }
        }
        
        function checkStrength(val) {
            const bar  = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { w: '0%',   cls: 'bg-secondary', lbl: '' },
                { w: '25%',  cls: 'bg-danger',     lbl: '<i class="bi bi-flag-fill text-danger me-1"></i> Quá ngắn, dễ bị hack!' },
                { w: '50%',  cls: 'bg-warning',    lbl: '<i class="bi bi-exclamation-triangle-fill text-warning me-1"></i> Tạm được, cần thêm số vào' },
                { w: '75%',  cls: 'bg-info',       lbl: '<i class="bi bi-shield-check text-info me-1"></i> Tốt rồi đó bà con' },
                { w: '90%',  cls: 'bg-primary',    lbl: '<i class="bi bi-shield-lock-fill text-primary me-1"></i> Rất mạnh!' },
                { w: '100%', cls: 'bg-success',    lbl: '<i class="bi bi-shield-fill-check text-success me-1"></i> Tuyệt đối an toàn 💪' },
            ];
            const lvl = levels[Math.min(score, 5)];
            bar.style.width = lvl.w;
            bar.className   = `pwd-strength ${lvl.cls}`;
            text.innerHTML = lvl.lbl;
        }
    </script>
</body>
</html>
