@model ChinhNha.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chính Nha Phân Bón</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        
        body {
            background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 40%, #388E3C 70%, #66BB6A 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        
        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 24px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 460px;
            animation: slideUp 0.5s ease-out;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .logo-wrap { text-align: center; margin-bottom: 2rem; }
        .logo-icon {
            width: 72px; height: 72px;
            border-radius: 20px;
            background: linear-gradient(135deg, #2E7D32, #66BB6A);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 2rem; margin-bottom: 1rem;
            box-shadow: 0 8px 24px rgba(46, 125, 50, 0.3);
        }
        .auth-title  { font-size: 1.7rem; font-weight: 800; color: #1a1a2e; margin-bottom: 0.25rem; }
        .auth-subtitle { color: #6c757d; font-size: 0.9rem; }

        .form-label { font-weight: 600; color: #374151; margin-bottom: 0.4rem; font-size: 0.9rem; }

        .input-group-icon {
            position: relative;
        }
        .input-group-icon i.icon-prefix {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            z-index: 10;
            font-size: 1.1rem;
        }
        .input-group-icon .form-control {
            padding-left: 42px;
            height: 50px;
            border-radius: 12px;
            border: 2px solid #e5e7eb;
            font-size: 0.95rem;
            transition: all 0.3s;
        }
        .input-group-icon .form-control:focus {
            border-color: #2E7D32;
            box-shadow: 0 0 0 4px rgba(46, 125, 50, 0.1);
        }

        .btn-auth {
            background: linear-gradient(135deg, #2E7D32, #388E3C);
            border: none;
            color: white;
            font-weight: 700;
            height: 52px;
            border-radius: 12px;
            font-size: 1rem;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }
        .btn-auth:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(46, 125, 50, 0.35);
            color: white;
        }

        .divider { text-align: center; position: relative; margin: 1.5rem 0; }
        .divider::before {
            content: '';
            position: absolute;
            top: 50%; left: 0;
            width: 100%; height: 1px;
            background: #e5e7eb;
        }
        .divider span {
            background: white; padding: 0 12px;
            position: relative; color: #9ca3af; font-size: 0.85rem;
        }

        .pwd-strength { height: 4px; border-radius: 4px; transition: all 0.3s; margin-top: 8px; }

        .back-link { text-align: center; margin-bottom: 1.5rem; }
        .back-link a { color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.9rem; }
        .back-link a:hover { color: white; }
    </style>
</head>
<body>
    <div>
        <div class="back-link">
            <a href="/"><i class="bi bi-arrow-left me-1"></i>Quay về trang chủ</a>
        </div>
        
        <div class="auth-card">
            <div class="logo-wrap">
                <div class="logo-icon">🌱</div>
                <h1 class="auth-title">Tạo tài khoản</h1>
                <p class="auth-subtitle">Đăng ký để bắt đầu mua sắm tại Chính Nha</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2 mb-3" role="alert"></div>

            <form asp-action="Register" method="post">
                
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-person icon-prefix"></i>
                        <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn An" autocomplete="name" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-envelope icon-prefix"></i>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-lock icon-prefix"></i>
                        <input asp-for="Password" id="passwordReg" class="form-control" placeholder="Tối thiểu 6 ký tự" 
                               autocomplete="new-password" oninput="checkStrength(this.value)" />
                    </div>
                    <div id="strengthBar" class="pwd-strength bg-secondary mt-1" style="width: 0%;"></div>
                    <small id="strengthText" class="text-muted"></small>
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <div class="input-group-icon">
                        <i class="bi bi-shield-lock icon-prefix"></i>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" autocomplete="new-password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-auth w-100 mb-4">
                    <i class="bi bi-person-check me-2"></i>Đăng ký ngay
                </button>

                <div class="divider"><span>đã có tài khoản?</span></div>

                <div class="text-center mt-3">
                    <a asp-action="Login" class="btn btn-outline-secondary w-100 py-3" style="border-radius: 12px; font-weight: 600;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function checkStrength(val) {
            const bar  = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const levels = [
                { w: '0%',   cls: 'bg-secondary', lbl: '' },
                { w: '25%',  cls: 'bg-danger',     lbl: 'Rất yếu' },
                { w: '50%',  cls: 'bg-warning',    lbl: 'Yếu' },
                { w: '75%',  cls: 'bg-info',       lbl: 'Trung bình' },
                { w: '90%',  cls: 'bg-primary',    lbl: 'Mạnh' },
                { w: '100%', cls: 'bg-success',    lbl: 'Rất mạnh 💪' },
            ];
            const lvl = levels[Math.min(score, 5)];
            bar.style.width = lvl.w;
            bar.className   = `pwd-strength ${lvl.cls}`;
            text.textContent = lvl.lbl;
        }
    </script>
</body>
</html>
