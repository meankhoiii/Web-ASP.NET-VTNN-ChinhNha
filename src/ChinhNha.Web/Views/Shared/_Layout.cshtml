<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "VTNN Chính Nha — chuyên cung cấp vật tư nông nghiệp, phân bón chính hãng và tư vấn mùa vụ.")" />
    <meta property="og:title" content="@(ViewData["Title"] ?? "VTNN Chính Nha")" />
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? "VTNN Chính Nha — chuyên cung cấp vật tư nông nghiệp, phân bón chính hãng và tư vấn mùa vụ.")" />
    <meta property="og:type" content="website" />
    @if (ViewData["OgImage"] is string ogImage && !string.IsNullOrWhiteSpace(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    <title>@ViewData["Title"] - VTNN Chính Nha</title>
    <link rel="icon" type="image/png" href="/images/logo.png" />
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChinhNha.Web.styles.css" asp-append-version="true" />

    <style>
        /* ===== HEADER & NAV ===== */
        .header-top {
            background: #1B5E20;
            color: #fff;
            font-size: 0.95rem;
            padding: 8px 0;
            font-weight: 600;
        }
        .hotline-highlight {
            color: #F9A825;
            font-size: 1.1rem;
            font-weight: 900;
        }
        
        .main-navbar {
            background-color: #fff;
            border-bottom: 4px solid #2E7D32;
        }
        
        .navbar-brand-text {
            font-weight: 900;
            color: #2E7D32 !important;
            font-size: clamp(1.3rem, 4vw, 1.8rem);
            text-transform: uppercase;
            text-decoration: none !important;
        }
        
        .main-nav-link {
            font-weight: 700;
            color: #333;
            font-size: clamp(0.95rem, 2vw, 1.1rem);
            padding: 10px 14px !important;
            border-radius: 6px;
            text-decoration: none;
            display: block;
        }
        .main-nav-link:hover,
        .main-nav-link.active {
            color: #2E7D32 !important;
            background-color: #E8F5E9;
        }

        .header-action-btn {
            min-height: 46px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            padding: 10px 14px;
        }
        
        /* Giỏ hàng */
        .cart-box {
            background: #E8F5E9;
            border: 2px solid #A5D6A7;
            padding: 8px 14px;
            border-radius: 8px;
            font-weight: 700;
            color: #1B5E20;
            text-decoration: none !important;
            display: flex;
            align-items: center;
            gap: 8px;
            min-height: 48px;
            white-space: nowrap;
        }
        .cart-box:hover { border-color: #2E7D32; color: #1B5E20; }
        .cart-count {
            background: #B71C1C;
            color: #fff;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 700;
        }
        
        /* Mobile Nav collapse items */
        @@media (max-width: 991px) {
            .main-nav-link {
                padding: 14px 16px !important;
                font-size: 1.05rem;
                border-bottom: 1px solid #E0E0E0;
                border-radius: 0;
            }
            .navbar-nav { padding: 8px 0; }
        }

        /* Fix hamburger icon color on white bg */
        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%2846, 125, 50, 1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e") !important;
        }

        /* ===== FOOTER ===== */
        .footer-agri {
            background: #eeeeee;
            padding: 2rem 0;
            margin-top: 3rem;
            border-top: 5px solid #2E7D32;
            color: #111;
        }
        
        /* ===== FLOATING CALL BUTTON (mobile only) ===== */
        .floating-call {
            display: none;
        }
        @@media (max-width: 767px) {
            .floating-call {
                display: flex;
                position: fixed;
                bottom: calc(env(safe-area-inset-bottom, 0px) + 76px);
                right: 12px;
                z-index: 999;
                background: linear-gradient(135deg, #fffef7 0%, #eef8ea 100%);
                color: #1B5E20;
                border: 2px solid #7bc67e;
                border-radius: 50px;
                padding: 12px 18px;
                align-items: center;
                gap: 8px;
                font-weight: 900;
                font-size: 0.95rem;
                text-decoration: none;
                box-shadow: 0 10px 22px rgba(27, 94, 32, 0.18);
            }

            .floating-call i {
                color: #2E7D32;
            }
        }
    </style>
</head>
<body>
    <div class="header-top d-none d-md-block">
        <div class="container d-flex justify-content-between align-items-center">
            <span><i class="bi bi-geo-alt-fill me-1"></i> Đại lý Vật Tư NN Chính Nha</span>
            <span><i class="bi bi-telephone-fill me-1"></i> TƯ VẤN & MUA HÀNG: <span class="hotline-highlight">0352.787.350</span></span>
        </div>
    </div>

    <header class="main-navbar sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand-text d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="/images/logowithtext.webp" alt="VTNN Chính Nha" style="height:48px; width:auto;" />
                </a>
                
                <div class="d-flex align-items-center gap-2 d-lg-none ms-auto">
                    <a href="/Cart" class="cart-box header-action-btn py-1 px-2" title="Giỏ hàng">
                        <i class="bi bi-cart4 fs-4"></i>
                        <span class="cart-count">0</span>
                    </a>
                    <button class="navbar-toggler border-2 border-success" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" style="padding: 10px;">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 mt-2 mt-lg-0">
                        <li class="nav-item"><a class="main-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i> Trang chủ</a></li>
                        <li class="nav-item"><a class="main-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")" asp-area="" asp-controller="Product" asp-action="Index"><i class="bi bi-shop me-1"></i> Cửa hàng VTNN</a></li>
                        <li class="nav-item"><a class="main-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Blog" ? "active" : "")" href="/tin-tuc"><i class="bi bi-newspaper me-1"></i> Kỹ thuật mùa màng</a></li>
                        <li class="nav-item d-md-none">
                            <a href="tel:0352787350" class="main-nav-link text-danger"><i class="bi bi-telephone-fill me-2"></i> GỌI 0352.787.350 ĐẶT HÀNG</a>
                        </li>
                    </ul>
                    
                    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center gap-2 mt-2 mt-lg-0">
                        <a href="/Cart" class="cart-box header-action-btn d-none d-lg-flex" title="Giỏ hàng">
                            <i class="bi bi-cart4 fs-4"></i>
                            <span>GIỎ HÀNG</span>
                            <span class="cart-count">0</span>
                        </a>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-success border-2 header-action-btn" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-fill me-1"></i> @User.Identity.Name?.Split('@').First()
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end border-2 shadow">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item fs-5 py-2" href="/Admin/Dashboard"><i class="bi bi-shield-lock me-1"></i> Trang Quản Lý</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li><a class="dropdown-item fs-5 py-2" href="/Customer/Orders"><i class="bi bi-clock-history me-1"></i> Lịch sử mua hàng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item fs-5 py-2 text-danger fw-bold">Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-primary border-2 header-action-btn"><i class="bi bi-box-arrow-in-right me-1"></i> Đăng Nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Nút gọi nổi trên Mobile -->
    <a href="tel:0352787350" class="floating-call">
        <i class="bi bi-telephone-fill" style="font-size: 1.4rem;"></i> GỌI ĐẶT HÀNG
    </a>

    <div class="container mt-3 mt-md-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-agri">
        <div class="container">
            <div class="row">
                <div class="col-md-6 mb-4">
                    <h3 class="fw-bold mb-3" style="color: #2E7D32;">VẬT TƯ NÔNG NGHIỆP CHÍNH NHA</h3>
                    <p class="fs-5">Cung cấp các loại phân bón và vật tư nông nghiệp chính hãng. Uy tín 10 năm đồng hành cùng bà con nông dân.</p>
                    <div class="fs-5 mt-3">
                        <p><strong>Địa chỉ:</strong> 123 Đường Nông Nghiệp, TP. HCM</p>
                        <p><strong>Điện thoại:</strong> <a href="tel:0352787350" class="text-danger fw-bold" style="font-size:1.3rem; text-decoration:underline;">0352.787.350</a></p>
                        <p><strong>Zalo Tư Vấn:</strong> 0352.787.350</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 bg-white border rounded shadow-sm">
                        <h4 class="fw-bold mb-3 text-center">Bà con cần tư vấn loại cây/VTNN?</h4>
                        <p class="text-center text-muted fs-5">Để lại số điện thoại, chúng tôi sẽ gọi lại ngay!</p>
                        @Html.AntiForgeryToken()
                        <div class="input-group mt-3">
                            <input type="tel" id="footerCallbackPhone" class="form-control" placeholder="Nhập số điện thoại..." style="min-height:56px; font-size:1.2rem;" maxlength="15">
                            <button id="footerCallbackBtn" onclick="submitCallbackRequest()" class="btn fw-bold px-3 text-white" style="background-color: #E65100; border-color: #BF360C; font-size:1rem; white-space:normal; min-height:56px;">GỌI LẠI<br>NGAY</button>
                        </div>
                        <div id="footerCallbackMsg" class="mt-2 text-center fw-bold fs-5" style="display:none;"></div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- ===== CHATBOT WIDGET (Floating) ===== -->
    <div id="chatbot-widget">
        <!-- Toggle button -->
        <div id="chatbot-hint" class="chatbot-hint" style="display:none;">
            <i class="bi bi-robot"></i>
            <span id="chatbot-hint-text">Hỏi tôi về sản phẩm phù hợp</span>
        </div>
        <button id="chatbot-toggle" aria-label="Mở chatbot tư vấn AI"
                title="Tư vấn AI - Chính Nha">
            <i class="bi bi-robot fs-4"></i>
            <span class="chatbot-badge" id="chatbot-badge" style="display:none">1</span>
        </button>

        <!-- Chat panel -->
        <div id="chatbot-panel" class="shadow-lg" style="display:none">
            <div class="chatbot-header d-flex justify-content-between align-items-center p-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-robot text-white fs-5"></i>
                    <div>
                        <div class="fw-bold text-white small">Trợ lý AI Chính Nha</div>
                        <div class="text-white-50" style="font-size:0.72rem">Hỏi về sản phẩm, đơn hàng, giá cả...</div>
                    </div>
                </div>
                <button class="btn btn-sm text-white border-0 p-1" id="chatbot-close" aria-label="Đóng">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="chatbot-messages p-3" id="chatbot-messages">
                <div class="cb-bubble cb-assistant">👋 Xin chào! Tôi có thể giúp bạn tra cứu sản phẩm, kiểm tra đơn hàng hoặc tư vấn phân bón phù hợp với cây trồng. Hỏi tôi nhé!</div>
            </div>

            <div class="chatbot-quick-replies px-2 pb-2" id="chatbot-quick-replies">
                <button type="button" class="chatbot-chip" data-msg="Gợi ý cho tôi 3 sản phẩm bán chạy nhất">Sản phẩm bán chạy</button>
                <button type="button" class="chatbot-chip" data-msg="Tôi trồng lúa, nên dùng loại nào giai đoạn đẻ nhánh?">Tư vấn cho lúa</button>
                <button type="button" class="chatbot-chip" data-msg="Kiểm tra giúp tôi cách chọn phân bón hữu cơ phù hợp">Phân hữu cơ</button>
                <button type="button" class="chatbot-chip" data-msg="Cho tôi biết cách liên hệ tư vấn nhanh">Liên hệ tư vấn</button>
            </div>

            <div class="chatbot-typing d-none" id="chatbot-typing">
                <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
            </div>

            <div class="chatbot-input p-2">
                <div class="input-group input-group-sm">
                    <input type="text" id="chatbot-input" class="form-control border-0 bg-light"
                           placeholder="Nhập tin nhắn..." maxlength="400" />
                    <button class="btn btn-success px-3" id="chatbot-send">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <style>
        #chatbot-widget {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 1055;
            font-family: 'Roboto', sans-serif;
        }
        #chatbot-toggle {
            width: 56px; height: 56px;
            border-radius: 50%;
            background: #1B5E20;
            border: none;
            color: #fff;
            box-shadow: 0 4px 16px rgba(27,94,32,.45);
            cursor: pointer;
            position: relative;
            transition: transform .15s;
        }
        #chatbot-toggle:hover { transform: scale(1.08); }
        .chatbot-hint {
            position: absolute;
            right: 66px;
            bottom: 10px;
            background: #fff;
            color: #1B5E20;
            border: 1px solid #a5d6a7;
            border-radius: 14px;
            font-size: 0.82rem;
            font-weight: 700;
            line-height: 1.2;
            padding: 8px 10px;
            box-shadow: 0 8px 16px rgba(0,0,0,.12);
            white-space: nowrap;
            opacity: 0;
            transform: translateY(6px);
            transition: opacity .2s ease, transform .2s ease;
            pointer-events: none;
            display: flex;
            align-items: center;
            gap: 6px;
            max-width: 210px;
        }
        .chatbot-hint i {
            color: #2E7D32;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
        .chatbot-hint::after {
            content: '';
            position: absolute;
            right: -7px;
            top: 50%;
            transform: translateY(-50%);
            width: 0;
            height: 0;
            border-top: 7px solid transparent;
            border-bottom: 7px solid transparent;
            border-left: 7px solid #fff;
        }
        .chatbot-hint.show {
            opacity: 1;
            transform: translateY(0);
        }
        .chatbot-badge {
            position: absolute; top: 4px; right: 4px;
            background: #dc3545; color: #fff;
            font-size: 10px; font-weight: 700;
            width: 16px; height: 16px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
        }
        #chatbot-panel {
            position: absolute;
            bottom: 68px; right: 0;
            width: 340px;
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #dee2e6;
        }
        .chatbot-header { background: #1B5E20; }
        .chatbot-quick-replies {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            border-top: 1px solid #eef2f4;
            background: #fff;
        }
        .chatbot-chip {
            border: 1px solid #c8e6c9;
            background: #f7fbf6;
            color: #1B5E20;
            border-radius: 999px;
            font-size: 0.74rem;
            font-weight: 700;
            line-height: 1.2;
            padding: 6px 10px;
            cursor: pointer;
        }
        .chatbot-chip:hover {
            background: #e8f5e9;
            border-color: #81c784;
        }
        .chatbot-messages {
            height: 320px;
            overflow-y: auto;
            scroll-behavior: smooth;
        }
        .cb-bubble {
            max-width: 88%;
            padding: .5rem .85rem;
            border-radius: 12px;
            margin-bottom: .5rem;
            font-size: .87rem;
            line-height: 1.4;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .cb-user {
            background: #1B5E20;
            color: #fff;
            margin-left: auto;
            border-bottom-right-radius: 3px;
        }
        .cb-assistant {
            background: #f1f3f5;
            color: #212529;
            border-bottom-left-radius: 3px;
        }
        .chatbot-typing {
            padding: .4rem .75rem;
            display: flex !important;
            gap: 5px;
        }
        .typing-dot {
            width: 7px; height: 7px;
            background: #adb5bd;
            border-radius: 50%;
            animation: cb-typing 1.2s infinite;
        }
        .typing-dot:nth-child(2) { animation-delay: .2s; }
        .typing-dot:nth-child(3) { animation-delay: .4s; }
        @@keyframes cb-typing {
            0%,80%,100% { transform: scale(1); opacity:.5; }
            40% { transform: scale(1.35); opacity:1; }
        }
        @@media (max-width: 500px) {
            #chatbot-panel {
                width: min(340px, calc(100vw - 24px));
                right: 0;
                bottom: 72px;
            }

            #chatbot-widget {
                bottom: calc(env(safe-area-inset-bottom, 0px) + 146px);
                right: 12px;
            }

            .chatbot-hint {
                right: 0;
                bottom: 64px;
                width: 190px;
                max-width: 190px;
                white-space: normal;
                line-height: 1.3;
            }

            .chatbot-hint::after {
                right: 20px;
                top: auto;
                bottom: -7px;
                transform: none;
                border-left: 7px solid transparent;
                border-right: 7px solid transparent;
                border-top: 7px solid #fff;
                border-bottom: 0;
            }

            #chatbot-toggle {
                width: 54px;
                height: 54px;
            }
        }
    </style>

    <script>
    (function () {
        const toggle = document.getElementById('chatbot-toggle');
        const panel = document.getElementById('chatbot-panel');
        const closeBtn = document.getElementById('chatbot-close');
        const msgsEl = document.getElementById('chatbot-messages');
        const inputEl = document.getElementById('chatbot-input');
        const sendBtn = document.getElementById('chatbot-send');
        const typingEl = document.getElementById('chatbot-typing');
        const hintEl = document.getElementById('chatbot-hint');
        const hintTextEl = document.getElementById('chatbot-hint-text');
        const quickRepliesEl = document.getElementById('chatbot-quick-replies');

        let sessionId = sessionStorage.getItem('cbSession') || '';
        const hintMessages = [
            'Hỏi tôi về sản phẩm phù hợp',
            'Bấm để tư vấn nhanh',
            'Có mẫu câu hỏi sẵn bên trong'
        ];
        let hintIndex = 0;
        let hintTimer = null;

        function showChatHint() {
            if (!hintEl || panel.style.display !== 'none') return;

            if (hintTextEl) {
                hintTextEl.textContent = hintMessages[hintIndex % hintMessages.length];
            }
            hintIndex += 1;
            hintEl.style.display = 'block';

            requestAnimationFrame(() => hintEl.classList.add('show'));

            clearTimeout(hintTimer);
            hintTimer = setTimeout(() => {
                hintEl.classList.remove('show');
                setTimeout(() => { hintEl.style.display = 'none'; }, 220);
            }, 2100);
        }

        toggle.addEventListener('click', () => {
            const isHidden = panel.style.display === 'none';
            panel.style.display = isHidden ? 'block' : 'none';
            if (isHidden) {
                if (hintEl) {
                    hintEl.classList.remove('show');
                    hintEl.style.display = 'none';
                }
                inputEl.focus();
                document.getElementById('chatbot-badge').style.display = 'none';
            }
        });
        closeBtn.addEventListener('click', () => { panel.style.display = 'none'; });

        function appendBubble(role, text) {
            const safeText = (text || '').trim();
            const div = document.createElement('div');
            div.className = 'cb-bubble ' + (role === 'user' ? 'cb-user' : 'cb-assistant');
            div.innerHTML = safeText
                .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
                .replace(/\n/g,'<br>');
            msgsEl.appendChild(div);
            msgsEl.scrollTop = msgsEl.scrollHeight;
        }

        async function sendMessage(msg) {
            if (!msg.trim()) return;
            appendBubble('user', msg);
            inputEl.value = '';
            sendBtn.disabled = true;
            typingEl.classList.remove('d-none');

            try {
                const res = await fetch('/api/chatbot/message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg, sessionId })
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();
                sessionId = data.sessionId || sessionId;
                sessionStorage.setItem('cbSession', sessionId);
                appendBubble('assistant', data.reply || 'Xin lỗi, không nhận được phản hồi.');
            } catch {
                appendBubble('assistant', '❌ Lỗi kết nối. Vui lòng thử lại.');
            } finally {
                sendBtn.disabled = false;
                typingEl.classList.add('d-none');
            }
        }

        sendBtn.addEventListener('click', () => sendMessage(inputEl.value));
        inputEl.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(inputEl.value); }
        });

        quickRepliesEl?.addEventListener('click', (e) => {
            const btn = e.target.closest('.chatbot-chip');
            if (!btn) return;

            const text = btn.getAttribute('data-msg') || '';
            if (!text) return;

            sendMessage(text);
        });

        setTimeout(showChatHint, 1400);
        setInterval(showChatHint, 18000);
    })();
    </script>
    <!-- ===== END CHATBOT WIDGET ===== -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>
    <script src="~/js/wishlist.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        async function submitCallbackRequest() {
            const input = document.getElementById('footerCallbackPhone');
            const btn = document.getElementById('footerCallbackBtn');
            const msg = document.getElementById('footerCallbackMsg');
            const phone = input.value.trim();

            if (!phone) {
                msg.textContent = 'Vui lòng nhập số điện thoại.';
                msg.style.color = '#c00';
                msg.style.display = 'block';
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...';

            try {
                const token = document.querySelector('meta[name="__RequestVerificationToken"]')?.content
                    || document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                const form = new FormData();
                form.append('phone', phone);
                if (token) form.append('__RequestVerificationToken', token);

                const res = await fetch('/Home/CallbackRequest', { method: 'POST', body: form });
                const data = await res.json();

                if (res.ok) {
                    msg.textContent = '✅ ' + data.message;
                    msg.style.color = '#2E7D32';
                    input.value = '';
                } else {
                    msg.textContent = '⚠️ ' + (data.message || 'Có lỗi xảy ra.');
                    msg.style.color = '#c00';
                }
            } catch {
                msg.textContent = '⚠️ Không gửi được, vui lòng thử lại.';
                msg.style.color = '#c00';
            } finally {
                msg.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = 'GỌI LẠI<br>NGAY';
            }
        }

        document.getElementById('footerCallbackPhone')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') submitCallbackRequest();
        });
    </script>
</body>
</html>
