<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chính Nha</title>
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ChinhNha.Web.styles.css" asp-append-version="true" />

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FAFAFA; color: #333; }
        .navbar-brand { font-weight: 800; color: #2E7D32 !important; font-size: 1.5rem; letter-spacing: -0.5px; }
        .nav-link { font-weight: 500; color: #555; transition: color 0.3s; }
        .nav-link:hover, .nav-link.active { color: #2E7D32 !important; }
        
        .header-top { background: #1B5E20; color: white; font-size: 0.85rem; padding: 5px 0; }
        .cart-badge { position: absolute; top: 0; right: -5px; transform: translate(50%, -50%); background-color: #FFB300; color: #000; border-radius: 50%; padding: 0.2rem 0.5rem; font-size: 0.7rem; font-weight: bold; }
        
        .footer-agri { background: #fff; padding: 4rem 0 2rem; margin-top: 4rem; border-top: 1px solid #eaeaea; }
    </style>
</head>
<body>
    <div class="header-top d-none d-md-block">
        <div class="container d-flex justify-content-between">
            <span><i class="bi bi-geo-alt-fill me-1"></i> 123 Đường Nông Nghiệp, TP. HCM</span>
            <span><i class="bi bi-telephone-fill me-1"></i> Hotline: 1900 1234</span>
        </div>
    </div>

    <header class="bg-white shadow-sm sticky-top">
        <nav class="navbar navbar-expand-lg py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tree-fill me-2 fs-2"></i> CHÍNH NHA
                </a>
                
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-3">
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")" asp-area="" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="nav-item"><a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Blog" ? "active" : "")" href="/tin-tuc">Tin tức</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Liên hệ</a></li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3">
                        <a href="/Cart" class="text-dark position-relative text-decoration-none">
                            <i class="bi bi-cart3 fs-4"></i>
                            <span class="cart-badge">0</span>
                        </a>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-success rounded-pill px-3 fw-medium dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i> @User.Identity.Name?.Split('@').First()
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-2 text-success"></i>Quản trị</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-box-seam me-2"></i>Đơn hàng của tôi</a></li>
                                    <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-left me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-outline-success rounded-pill px-4 fw-medium">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-agri">
        <div class="container">
            <div class="row gy-4 mb-4">
                <div class="col-lg-4">
                    <h4 class="fw-bold text-success mb-3"><i class="bi bi-tree-fill"></i> CHÍNH NHA</h4>
                    <p class="text-muted">Cung cấp các loại phân bón và vật tư nông nghiệp chính hãng. Giải pháp tối ưu cho mùa màng bội thu.</p>
                </div>
                <div class="col-lg-2 offset-lg-2">
                    <h6 class="fw-bold mb-3">Liên kết</h6>
                    <ul class="list-unstyled text-muted">
                        <li class="mb-2"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
                        <li class="mb-2"><a href="/Product" class="text-decoration-none text-muted">Sản phẩm</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="fw-bold mb-3">Đăng ký nhận tin</h6>
                    <div class="input-group">
                        <input type="email" class="form-control bg-light" placeholder="Email của bạn..." style="border-radius: 10px 0 0 10px; border: none;">
                        <button class="btn btn-success" style="border-radius: 0 10px 10px 0;">Đăng ký</button>
                    </div>
                </div>
            </div>
            <div class="text-center text-muted border-top border-light pt-3 small">
                &copy; 2026 - VTNN Chính Nha. Mọi quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
