@{
    ViewData["Title"] = "Liên hệ chúng tôi";
}

<style>
    .contact-hero {
        background: linear-gradient(135deg, #2E7D32, #1B5E20);
        color: white;
        padding: 40px 20px;
        text-align: center;
        border-radius: 8px;
        margin-bottom: 40px;
    }
    
    .contact-hero h1 {
        font-size: clamp(1.8rem, 5vw, 2.8rem);
        font-weight: 900;
        margin-bottom: 10px;
        text-transform: uppercase;
    }
    
    .contact-hero p {
        font-size: clamp(1rem, 2.5vw, 1.3rem);
        margin-bottom: 0;
    }

    .contact-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        margin-bottom: 60px;
    }

    @@media (max-width: 768px) {
        .contact-container {
            grid-template-columns: 1fr;
            gap: 30px;
        }
    }

    .contact-form {
        background: white;
        border: 3px solid #2E7D32;
        border-radius: 8px;
        padding: 30px;
    }

    .contact-form h2 {
        color: #1B5E20;
        font-weight: 900;
        font-size: 1.6rem;
        margin-bottom: 25px;
        border-bottom: 3px solid #2E7D32;
        padding-bottom: 15px;
        text-transform: uppercase;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: #1B5E20;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 12px;
        font-size: 1rem;
        border: 2px solid #C8E6C9;
        border-radius: 6px;
        font-family: inherit;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #2E7D32;
        box-shadow: 0 0 5px rgba(46, 125, 50, 0.3);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 120px;
    }

    .required {
        color: #B71C1C;
        font-weight: bold;
    }

    .btn-submit {
        background-color: #E65100;
        color: white;
        width: 100%;
        padding: 15px;
        font-size: 1.2rem;
        font-weight: 900;
        border: 2px solid #BF360C;
        border-radius: 6px;
        cursor: pointer;
        text-transform: uppercase;
        transition: background-color 0.2s;
    }

    .btn-submit:hover {
        background-color: #BF360C;
    }

    .contact-info {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .info-box {
        background: #E8F5E9;
        border: 3px solid #2E7D32;
        border-radius: 8px;
        padding: 25px;
    }

    .info-box h3 {
        color: #1B5E20;
        font-weight: 900;
        font-size: 1.4rem;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
    }

    .info-box i {
        font-size: 1.8rem;
        color: #E65100;
    }

    .info-box p {
        color: #333;
        font-size: 1.1rem;
        margin: 0;
        line-height: 1.6;
    }

    .info-box a {
        color: #2E7D32;
        font-weight: 700;
        text-decoration: none;
    }

    .info-box a:hover {
        text-decoration: underline;
    }

    #map {
        width: 100%;
        height: 300px;
        border: 3px solid #2E7D32;
        border-radius: 8px;
        margin-top: 30px;
    }

    .alert {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 20px;
        padding: 15px 20px;
        border-radius: 6px;
    }

    .alert-success {
        background-color: #D1E7DD;
        border: 2px solid #0F5132;
        color: #0F5132;
    }

    .alert-danger {
        background-color: #F8D7DA;
        border: 2px solid #842029;
        color: #842029;
    }
</style>

<div class="contact-hero">
    <h1><i class="bi bi-envelope-open-fill me-3"></i>LIÊN HỆ CHÚNG TÔI</h1>
    <p>Chúng tôi luôn sẵn lòng hỗ trợ tư vấn phân bón và vật tư nông nghiệp cho bà con</p>
</div>

<div class="contact-container">
    <div class="contact-form">
        <h2><i class="bi bi-chat-left-text-fill me-2"></i>Gửi Tin Nhắn</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            </div>
        }

        <form method="post" action="/Home/Contact">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="name">Họ và Tên <span class="required">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Nhập tên của bạn">
            </div>

            <div class="form-group">
                <label for="email">Email <span class="required">*</span></label>
                <input type="email" id="email" name="email" required placeholder="example@gmail.com">
            </div>

            <div class="form-group">
                <label for="phone">Số điện thoại</label>
                <input type="tel" id="phone" name="phone" placeholder="0909.123.456">
            </div>

            <div class="form-group">
                <label for="message">Nội dung tin nhắn <span class="required">*</span></label>
                <textarea id="message" name="message" required placeholder="Nhập nội dung bình luận hoặc yêu cầu của bạn..."></textarea>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-send-fill me-2"></i>GỬI TIN NHẮN
            </button>
        </form>
    </div>

    <div class="contact-info">
        <div class="info-box">
            <h3><i class="bi bi-telephone-fill"></i>Điện Thoại</h3>
            <p>
                <strong>Tổng đài mua hàng:</strong><br>
                <a href="tel:0909123456">0909.123.456</a><br>
                <strong>Hỗ trợ kỹ thuật:</strong><br>
                <a href="tel:0989654321">0989.654.321</a>
            </p>
        </div>

        <div class="info-box">
            <h3><i class="bi bi-geo-alt-fill"></i>Địa Chỉ</h3>
            <p>
                <strong>Trụ sở chính:</strong><br>
                Số 123 Đường Hoà Hưng, Quận 10, TP.HCM, Việt Nam<br>
                <br>
                <strong>Chi nhánh An Giang:</strong><br>
                Số 456 Tỉnh Lộ 40, Long Xuyên, An Giang
            </p>
        </div>

        <div class="info-box">
            <h3><i class="bi bi-clock-fill"></i>Giờ Làm Việc</h3>
            <p>
                <strong>Thứ 2 - Thứ 6:</strong> 7:00 - 17:30<br>
                <strong>Thứ 7:</strong> 7:00 - 12:00<br>
                <strong>Chủ Nhật:</strong> Nghỉ (Gọi cấp cứu: 0909.123.456)<br>
                <strong>Lễ Tết:</strong> Xem thêm tại fanpage
            </p>
        </div>

        <div class="info-box">
            <h3><i class="bi bi-facebook"></i>Kênh Khác</h3>
            <p>
                <a href="https://facebook.com" target="_blank" class="me-3">
                    <i class="bi bi-facebook"></i> Facebook
                </a>
                <a href="https://zalo.me" target="_blank" class="me-3">
                    <i class="bi bi-chat-dots"></i> Zalo
                </a>
                <a href="https://wa.me" target="_blank">
                    <i class="bi bi-whatsapp"></i> WhatsApp
                </a>
            </p>
        </div>

        <div id="map"></div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize map (centered on Vietnam)
            var map = L.map('map').setView([10.8, 106.7], 12);
            
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Add markers for locations
            L.marker([10.7769, 106.6869]).addTo(map)
                .bindPopup('<strong>Trụ sở chính</strong><br>Số 123 Đường Hoà Hưng, Quận 10<br><a href="tel:0909123456">0909.123.456</a>')
                .openPopup();

            L.marker([10.3582, 105.4274]).addTo(map)
                .bindPopup('<strong>Chi nhánh An Giang</strong><br>Số 456 Tỉnh Lộ 40, Long Xuyên<br><a href="tel:0909123456">0909.123.456</a>');
        });
    </script>
}
