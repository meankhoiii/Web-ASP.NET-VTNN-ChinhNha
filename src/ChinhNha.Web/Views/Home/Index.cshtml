@using ChinhNha.Web.Models
@model HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
    /* === HOME PAGE STYLES - Bảng màu mới 2026 === */
    .hero-banner {
        background-color: #E8F5E9;
        border: 3px solid #2E7D32;
        border-radius: 10px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
    @@media (min-width: 768px) {
        .hero-banner { padding: 2.5rem; }
    }

    .hero-main-title {
        color: #1B5E20;
        font-weight: 900;
        font-size: clamp(1.5rem, 5vw, 2.5rem);
        text-transform: uppercase;
        line-height: 1.3;
    }
    
    .hero-sub {
        font-size: clamp(1rem, 2.5vw, 1.2rem);
        color: #333;
        font-weight: 500;
        line-height: 1.7;
    }

    .alert-box {
        background-color: #FFF8E1;
        border: 3px solid #F9A825;
        color: #4E3200;
        padding: 14px;
        border-radius: 8px;
        font-size: clamp(0.95rem, 2.5vw, 1.15rem);
        font-weight: bold;
        margin-bottom: 20px;
    }

    /* Product Card */
    .product-box {
        background: #fff;
        border: 2px solid #C8E6C9;
        border-radius: 8px;
        padding: 10px;
        text-align: center;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s;
    }
    .product-box:hover { border-color: #2E7D32; }
    
    .product-img {
        width: 100%;
        height: 160px;
        object-fit: contain;
        background: #f9f9f9;
        margin-bottom: 8px;
        border: 1px solid #E0E0E0;
        border-radius: 4px;
    }
    @@media (min-width: 576px) {
        .product-img { height: 200px; }
    }

    .product-name {
        font-size: clamp(0.9rem, 2.5vw, 1.1rem);
        font-weight: 700;
        color: #111;
        text-decoration: none;
        display: block;
        min-height: 44px;
        margin-bottom: 4px;
        line-height: 1.35;
    }
    .product-name:hover { color: #2E7D32; text-decoration: underline; }

    .product-price {
        color: #B71C1C;
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        font-weight: 900;
        margin: 8px 0;
        display: block;
        margin-top: auto;
    }

    .btn-buy-now {
        background-color: #E65100;
        color: #fff;
        font-size: clamp(0.85rem, 2vw, 1.05rem);
        font-weight: 700;
        padding: 12px 8px;
        width: 100%;
        border: 2px solid #BF360C;
        border-radius: 6px;
        text-transform: uppercase;
        cursor: pointer;
        min-height: 48px;
    }
    .btn-buy-now:hover { background-color: #BF360C; }

    .section-heading {
        background: linear-gradient(135deg, #2E7D32, #1B5E20);
        color: white;
        padding: 12px 18px;
        font-size: clamp(1.1rem, 3.5vw, 1.6rem);
        font-weight: 900;
        margin-bottom: 20px;
        border-radius: 6px;
        text-transform: uppercase;
        border-left: 6px solid #E65100;
    }

    /* Categories */
    .category-box {
        background-color: #fff;
        border: 3px solid #2E7D32;
        border-radius: 10px;
        padding: 16px 10px;
        text-align: center;
        display: block;
        text-decoration: none;
        transition: background-color 0.2s;
        height: 100%;
    }
    .category-box:hover { background-color: #E8F5E9; }
    .category-icon {
        font-size: clamp(2.5rem, 6vw, 4rem);
        margin-bottom: 8px;
        color: #2E7D32;
        display: block;
    }
    .category-name {
        font-size: clamp(0.85rem, 2.5vw, 1.2rem);
        font-weight: 900;
        color: #1A1A1A;
        text-transform: uppercase;
        line-height: 1.3;
    }

    /* Weather */
    .weather-container {
        background-color: #FFFDE7;
        border: 3px solid #2E7D32;
        border-radius: 10px;
        padding: 16px;
    }
    .weather-btn { white-space: normal; line-height: 1.5; }
    #map {
        height: 220px; /* Mobile */
        width: 100%;
        border: 3px solid #2E7D32;
        border-radius: 8px;
    }
    @@media (min-width: 768px) {
        #map { height: 380px; }
    }

    /* Blog */
    .blog-box {
        background: #fff;
        border: 2px solid #C8E6C9;
        border-radius: 10px;
        height: 100%;
        overflow: hidden;
    }
    .blog-box:hover { border-color: #2E7D32; }
    .blog-img { width: 100%; height: 180px; object-fit: cover; }
    .blog-date { font-size: 1rem; color: #B71C1C; font-weight: 700; margin-bottom: 4px; }
    .blog-title {
        font-size: clamp(1rem, 2.5vw, 1.3rem);
        font-weight: 900;
        color: #111;
        text-decoration: none;
        display: block;
        margin-bottom: 8px;
        line-height: 1.4;
    }
    .blog-title:hover { color: #2E7D32; text-decoration: underline; }
    .blog-excerpt { font-size: 1rem; color: #555; }

    .home-rec-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px;
    }

    .home-rec-card {
        background: #fff;
        border: 2px solid #dcedc8;
        border-radius: 10px;
        padding: 10px;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .home-rec-card img {
        width: 100%;
        height: 150px;
        object-fit: contain;
        border: 1px solid #ddd;
        border-radius: 6px;
        background: #f9f9f9;
        margin-bottom: 10px;
    }

    .home-rec-name {
        color: #1b5e20;
        font-weight: 800;
        text-decoration: none;
        min-height: 44px;
        line-height: 1.35;
    }

    .home-rec-price {
        color: #b71c1c;
        font-size: 1.1rem;
        font-weight: 900;
        margin: 8px 0;
    }
</style>

<div class="row mb-4">
    <div class="col-12">
        <div class="alert-box d-flex align-items-center">
            <i class="bi bi-megaphone-fill fs-2 me-3 text-danger"></i>
            <div>
                <strong>THÔNG BÁO:</strong> Đại lý đang có chương trình giảm giá 5% cho phân bón NPK mùa vụ Đông Xuân. Gọi <strong class="text-danger">0909.123.456</strong> để đặt hàng ngay!
            </div>
        </div>
    </div>
</div>

<div class="hero-banner text-center text-md-start">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="hero-main-title mb-3">TỔNG ĐẠI LÝ PHÂN BÓN & VẬT TƯ NÔNG NGHIỆP</h1>
            <p class="hero-sub mb-4">Chúng tôi cam kết 100% hàng chính hãng, giá gốc từ nhà máy. Đặc biệt nhận tư vấn liều lượng phân bón cho từng loại cây trồng để đạt năng suất cao nhất.</p>
            <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
                <a href="#danh-sach-san-pham" class="btn btn-primary py-3 px-4" style="font-size: clamp(1rem, 3vw, 1.3rem);"><i class="bi bi-cart-down-fill me-2"></i> XEM SP PHÂN BÓN</a>
                <a href="tel:0909123456" class="btn btn-cta py-3 px-4" style="font-size: clamp(1rem, 3vw, 1.3rem);"><i class="bi bi-telephone-outbound-fill me-2"></i> GỌI TƯ VẤN NGAY</a>
            </div>
        </div>
        <div class="col-md-4 d-none d-md-block text-center">
            <img src="https://via.placeholder.com/300x300.png?text=H%C3%8CNH+%E1%BA%A2NH+C%E1%BB%ACA+H%C3%80NG" alt="Cửa hàng Chính Nha" class="img-fluid border border-4 border-success rounded">
        </div>
    </div>
</div>

<div id="danh-sach-san-pham" class="mb-5 mt-5">
    <h2 class="section-heading"><i class="bi bi-star-fill text-warning me-2"></i> SẢN PHẨM BÁN CHẠY MÙA NÀY</h2>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-md-3 justify-content-center">
        @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
        {
            foreach (var product in Model.FeaturedProducts)
            {
                <div class="col mb-2 mb-md-3">
                    <div class="product-box h-100" style="cursor: pointer;" onclick="window.location.href='/san-pham/@product.Slug'">
                        @if (product.Images != null && product.Images.Any(i => i.IsPrimary))
                        {
                            <img src="@product.Images.First(i => i.IsPrimary).ImageUrl" alt="@product.Name" class="product-img" />
                        }
                        else
                        {
                            <div class="product-img d-flex align-items-center justify-content-center" style="background-color: #e9ecef; color: #888;">
                                <i class="bi bi-image" style="font-size: 2.5rem;"></i>
                            </div>
                        }
                        
                        <div class="px-1 pt-1 d-flex flex-column flex-grow-1">
                            <a href="/san-pham/@product.Slug" class="product-name">@product.Name</a>
                            <span class="product-price">@product.BasePrice.ToString("N0")₫</span>
                            <button onclick="event.stopPropagation(); addToCart(@product.Id)" class="btn-buy-now mt-auto">
                                <i class="bi bi-cart-plus-fill me-1"></i> MUA
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-secondary fs-4 text-center py-5 fw-bold">
                    HIỆN ĐANG CẬP NHẬT SẢN PHẨM. BÀ CON VUI LÒNG QUAY LẠI SAU!
                </div>
            </div>
        }
    </div>
    
    <div class="text-center mt-2">
        <a href="/Product" class="btn btn-outline-success fs-4 px-5 py-3 fw-bold border-3">
            XEM TẤT CẢ SẢN PHẨM KHÁC <i class="bi bi-arrow-right-circle-fill ms-2"></i>
        </a>
    </div>
</div>

<div class="mb-5 mt-5" id="goi-y-cho-ban">
    <h2 class="section-heading"><i class="bi bi-magic text-warning me-2"></i> GOI Y DANH CHO BAN</h2>
    <div class="p-3 bg-white border border-2 border-success rounded">
        <div id="homeRecLoading" class="text-muted">Dang tai danh sach goi y...</div>
        <div id="homeRecGrid" class="home-rec-grid" style="display:none;"></div>
        <div id="homeRecEmpty" class="text-muted" style="display:none;">Dang nhap de xem goi y ca nhan hoa cho tai khoan cua ban.</div>
    </div>
</div>

<div class="mb-5 mt-5">
    <h2 class="section-heading"><i class="bi bi-tags-fill text-warning me-2"></i> TRUY CẬP NHANH CÁC DÒNG SẢN PHẨM</h2>
    <div class="row justify-content-center">
        @if (Model.Categories != null && Model.Categories.Any())
        {
            foreach (var cat in Model.Categories.Take(4))
            {
                <div class="col-6 col-md-3 mb-4">
                    <a href="/Product?searchQuery=@cat.Name" class="category-box">
                        <i class="bi bi-box-seam-fill category-icon"></i>
                        <div class="category-name">@cat.Name</div>
                    </a>
                </div>
            }
        }
        else
        {
            <!-- Mock Categories if empty -->
            <div class="col-6 col-md-3 mb-4"><a href="/Product" class="category-box"><i class="bi bi-box-seam-fill category-icon" style="color:#FFCC00;"></i><div class="category-name">PHÂN BÓN NPK</div></a></div>
            <div class="col-6 col-md-3 mb-4"><a href="/Product" class="category-box"><i class="bi bi-tree-fill category-icon" style="color:#006400;"></i><div class="category-name">PHÂN HỮU CƠ</div></a></div>
            <div class="col-6 col-md-3 mb-4"><a href="/Product" class="category-box"><i class="bi bi-bug-fill category-icon" style="color:#CC0000;"></i><div class="category-name">THUỐC TRỪ SÂU</div></a></div>
            <div class="col-6 col-md-3 mb-4"><a href="/Product" class="category-box"><i class="bi bi-tools category-icon" style="color:#555;"></i><div class="category-name">VẬT TƯ KHÁC</div></a></div>
        }
    </div>
</div>

<div class="mb-5 mt-5">
    <h2 class="section-heading"><i class="bi bi-cloud-sun-fill text-warning me-2"></i> THÔNG TIN THỜI TIẾT TẠI RẪY NÀY</h2>
    <div class="weather-container row align-items-center">
        <div class="col-md-5 text-center mb-4 mb-md-0 border-end border-3 border-success">
            <div id="weather-loading" class="p-4">
                <div class="spinner-border text-success mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
                <h4 class="fw-bold text-success">Đang lấy vị trí rẫy...</h4>
                <p class="text-muted fs-5 mb-0">Nhớ bấm <b>Cho phép (Allow)</b> khi hộp thoại hỏi vị trí nha bà con!</p>
            </div>
            
            <div id="weather-result" style="display: none; padding: 20px;">
                <div id="weather-icon" style="font-size: 8rem; line-height: 1.2;"></div>
                <div id="weather-temp" style="font-size: 5rem; font-weight: 900; color: #CC0000;"></div>
                <div id="weather-desc" class="fs-1 fw-bold text-success mt-2"></div>
                <div class="text-muted mt-3 fw-bold fs-5">Dữ liệu thời tiết trực tiếp (Live)</div>
            </div>
        </div>
        <div class="col-md-7">
            <div id="map" style="height: 400px; width: 100%; border: 4px solid #006400; border-radius: 8px;"></div>
        </div>
    </div>
</div>

<div class="mb-5 mt-5">
    <h2 class="section-heading"><i class="bi bi-newspaper text-warning me-2"></i> THÔNG TIN KỸ THUẬT & MÙA MÀNG</h2>
    <div class="row">
        @if (Model.LatestBlogs != null && Model.LatestBlogs.Any())
        {
            foreach (var blog in Model.LatestBlogs)
            {
                <div class="col-md-4 mb-4">
                    <div class="blog-box flex-column d-flex">
                        <img src="@(string.IsNullOrEmpty(blog.FeaturedImageUrl) ? "https://via.placeholder.com/400x250.png?text=TIN+T%E1%BB%A8C" : blog.FeaturedImageUrl)" class="blog-img" alt="@blog.Title" loading="lazy">
                        <div class="p-3 d-flex flex-column flex-grow-1">
                            <div class="blog-date"><i class="bi bi-calendar-event me-1"></i> @(blog.PublishedAt?.ToString("dd/MM/yyyy") ?? "Mới nhất")</div>
                            <a href="/tin-tuc/@blog.Slug" class="blog-title">@blog.Title</a>
                            <p class="blog-excerpt mb-0 flex-grow-1">
                                @if(!string.IsNullOrEmpty(blog.Summary) && blog.Summary.Length > 100)
                                {
                                    @(blog.Summary.Substring(0, 100) + "...")
                                }
                                else
                                {
                                    @blog.Summary
                                }
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Mock blogs if empty -->
            <div class="col-md-4 mb-4">
                <div class="blog-box flex-column d-flex">
                    <img src="https://via.placeholder.com/400x250.png?text=KY+THUAT+LUA" class="blog-img" alt="Blog">
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <div class="blog-date"><i class="bi bi-calendar-event me-1"></i> 11/03/2026</div>
                        <a href="#" class="blog-title">Phòng trừ sâu cuốn lá và rầy nâu trên lúa Đông Xuân</a>
                        <p class="blog-excerpt mb-0 flex-grow-1">Hướng dẫn chi tiết dọn sạch sâu cuốn lá hiệu quả cho năng suất lúa...</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="blog-box flex-column d-flex">
                    <img src="https://via.placeholder.com/400x250.png?text=KY+THUAT+CAFE" class="blog-img" alt="Blog">
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <div class="blog-date"><i class="bi bi-calendar-event me-1"></i> 05/03/2026</div>
                        <a href="#" class="blog-title">Bí quyết ép sầu riêng ra mập trái, xanh gai bằng NPK</a>
                        <p class="blog-excerpt mb-0 flex-grow-1">Chia sẻ kinh nghiệm sử dụng đúng loại NPK để tránh rụng trái sinh lý...</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="blog-box flex-column d-flex">
                    <img src="https://via.placeholder.com/400x250.png?text=KY+THUAT+CANH+TAC" class="blog-img" alt="Blog">
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <div class="blog-date"><i class="bi bi-calendar-event me-1"></i> 01/03/2026</div>
                        <a href="#" class="blog-title">Liều dùng thuốc BVTV an toàn, tránh bị ngộ độc</a>
                        <p class="blog-excerpt mb-0 flex-grow-1">Bà con nhất định phải nhớ quy tắc 4 đúng khi phun thuốc bảo vệ thực vật...</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        function formatHomeRecPrice(value) {
            return new Intl.NumberFormat('vi-VN').format(value || 0) + 'đ';
        }

        async function recordRecommendationInteraction(recommendationId, interactionType) {
            if (!recommendationId || recommendationId <= 0) {
                return;
            }

            try {
                await fetch('/api/Recommendation/' + recommendationId + '/interaction', {
                    method: 'POST',
                    credentials: 'include',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ interactionType: interactionType })
                });
            } catch {
                // Keep UI responsive even if tracking fails.
            }
        }

        function onHomeRecommendationClick(event, recommendationId) {
            event.preventDefault();
            recordRecommendationInteraction(recommendationId, 'click');
            const targetUrl = event.currentTarget ? event.currentTarget.href : '/Product';
            window.location.href = targetUrl;
            return false;
        }

        function addRecommendedToCart(recommendedProductId, recommendationId) {
            recordRecommendationInteraction(recommendationId, 'cart');
            if (typeof addToCart === 'function') {
                addToCart(recommendedProductId, 1);
            }
        }

        function buildHomeRecCard(item) {
            const image = item.recommendedProductImage || '/images/no-image.png';
            const name = item.recommendedProductName || 'San pham';
            const price = item.recommendedProductSalePrice ?? item.recommendedProductPrice ?? 0;
            const link = '/Product?searchQuery=' + encodeURIComponent(name);
            const recommendationId = item.id || 0;
            const productId = item.recommendedProductId || 0;

            return '<div class="home-rec-card">'
                + '<img src="' + image + '" alt="' + name + '" onerror="this.src=\'/images/no-image.png\'" />'
                + '<a class="home-rec-name" href="' + link + '" onclick="return onHomeRecommendationClick(event, ' + recommendationId + ')">' + name + '</a>'
                + '<div class="small text-muted">' + (item.recommendationReason || 'De xuat cho ban') + '</div>'
                + '<div class="home-rec-price">' + formatHomeRecPrice(price) + '</div>'
                + '<div class="d-flex gap-2 mt-auto">'
                + '<button class="btn btn-outline-primary btn-sm" type="button" onclick="addRecommendedToCart(' + productId + ', ' + recommendationId + ')">Them gio</button>'
                + '<button class="btn btn-outline-danger btn-sm" type="button" onclick="addToWishlist(' + productId + ')">Yeu thich</button>'
                + '</div>'
                + '</div>';
        }

        async function loadHomeRecommendations() {
            const loading = document.getElementById('homeRecLoading');
            const grid = document.getElementById('homeRecGrid');
            const empty = document.getElementById('homeRecEmpty');

            try {
                const res = await fetch('/api/Recommendation/for-user?limit=8', { credentials: 'include' });
                if (res.status === 401) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                if (!res.ok) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                const data = await res.json();
                const items = data && data.recommendations ? data.recommendations : [];

                loading.style.display = 'none';
                if (!items.length) {
                    empty.style.display = 'block';
                    return;
                }

                grid.innerHTML = items.map(buildHomeRecCard).join('');
                grid.style.display = 'grid';

                items.forEach(function (item) {
                    recordRecommendationInteraction(item.id || 0, 'view');
                });
            } catch {
                loading.style.display = 'none';
                empty.style.display = 'block';
            }
        }

        var map = L.map('map').setView([10.762622, 106.660172], 10); // Default location
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);
        
        var marker = L.marker([10.762622, 106.660172]).addTo(map);

        function getLocationWeather() {
            if (navigator.geolocation) {
                // To avoid long timeout if slow
                navigator.geolocation.getCurrentPosition(showPositionWeather, showError, {timeout: 10000});
            } else {
                document.getElementById('weather-loading').innerHTML = '<h5 class="text-danger">Máy điện thoại không hỗ trợ dò vị trí!</h5>';
            }
        }

        // Tự động load ngay khi vô trang
        document.addEventListener("DOMContentLoaded", function () {
            getLocationWeather();
            loadHomeRecommendations();
        });

        function showPositionWeather(position) {
            document.getElementById('weather-loading').style.display = 'none';
            document.getElementById('weather-result').style.display = 'block';
            
            var lat = position.coords.latitude;
            var lon = position.coords.longitude;
            
            map.setView([lat, lon], 14);
            marker.setLatLng([lat, lon]);

            // Call to Open-Meteo for free weather data
            fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`)
                .then(res => res.json())
                .then(data => {
                    let temp = data.current_weather.temperature;
                    let code = data.current_weather.weathercode;
                    
                    document.getElementById('weather-result').style.display = 'block';
                    document.getElementById('weather-temp').innerText = temp + "°C";
                    
                    let icon = '☀️';
                    let desc = 'TRỜI NẮNG ĐẸP';
                    
                    // WMO Weather interpretation codes
                    if(code === 0) { icon = '☀️'; desc = 'TRỜI NẮNG ĐẸP, ÍT MÂY'; }
                    else if(code >= 1 && code <= 3) { icon = '⛅'; desc = 'NHIỀU MÂY / RÂM MÁT'; }
                    else if(code === 45 || code === 48) { icon = '🌫️'; desc = 'CÓ SƯƠNG MÙ DÀY'; }
                    else if(code >= 51 && code <= 67) { icon = '🌧️'; desc = 'CÓ MƯA LÂM RÂM TỚI VỪA'; }
                    else if(code >= 71 && code <= 77) { icon = '❄️'; desc = 'TRỜI RÉT LẠNH'; }
                    else if(code >= 80 && code <= 82) { icon = '☔'; desc = 'MƯA RÀO TỪNG CƠN'; }
                    else if(code >= 95 && code <= 99) { icon = '⛈️'; desc = 'MƯA TO CÓ SẤM CHỚP / GIÔNG'; }

                    document.getElementById('weather-icon').innerText = icon;
                    document.getElementById('weather-desc').innerText = desc;
                })
                .catch(err => {
                    if (typeof showToast === 'function') {
                        showToast('Canh bao', 'Khong lay duoc thong tin thoi tiet luc nay.', 'warning');
                    }
                });
        }

        function showError(error) {
            var loadBox = document.getElementById('weather-loading');
            if(loadBox) {
                loadBox.innerHTML = '<i class="bi bi-exclamation-triangle-fill text-danger fs-1"></i><h5 class="text-danger mt-3">Chưa lấy được vị trí</h5><p class="text-muted">Bà con mở quyền (Allow Location) rồi tải lại trang nhé.</p>';
            }
        }
    </script>
}
