@using ChinhNha.Web.Models
@model ProductListViewModel

@{
    ViewData["Title"] = "Gian hàng Vật Tư Nông Nghiệp";
}

<style>
    .filter-panel {
        background-color: #f4f6f2; /* Light earth color */
        border: 2px solid #006400; /* Dark green border */
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
    }
    
    .filter-title {
        color: #006400;
        font-weight: bold;
        font-size: 1.4rem;
        border-bottom: 3px solid #006400;
        padding-bottom: 10px;
        margin-bottom: 15px;
        text-transform: uppercase;
    }
    
    /* Big checkbox for farmers */
    .farmer-checkbox {
        width: 25px;
        height: 25px;
        cursor: pointer;
        accent-color: #006400;
    }
    .check-label {
        font-size: 1.3rem;
        font-weight: bold;
        color: #333;
        margin-left: 10px;
        cursor: pointer;
        display: inline-block;
        vertical-align: top;
        margin-top: 2px;
    }

    .shop-header {
        background-color: #006400;
        color: white;
        padding: 15px;
        font-size: 1.8rem;
        font-weight: 900;
        border-radius: 8px;
        margin-bottom: 20px;
        text-transform: uppercase;
    }

    /* Shop Product Card */
    .shop-product {
        background: #fff;
        border: 2px solid #C8E6C9;
        border-radius: 8px;
        padding: 10px;
        text-align: center;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: border-color 0.2s;
    }
    .shop-product:hover {
        border-color: #2E7D32;
    }
    
    .product-img {
        width: 100%;
        height: 160px;
        object-fit: contain;
        background: #f9f9f9;
        margin-bottom: 8px;
        border: 1px solid #E0E0E0;
        border-radius: 4px;
    }
    @@media (min-width: 576px) {
        .product-img { height: 200px; }
    }

    .product-name {
        font-size: clamp(0.9rem, 2.5vw, 1.1rem);
        font-weight: 700;
        color: #111;
        text-decoration: none;
        display: block;
        min-height: 44px;
        margin-bottom: 4px;
        line-height: 1.35;
    }
    .product-name:hover { color: #2E7D32; text-decoration: underline; }

    .product-price {
        color: #B71C1C;
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        font-weight: 900;
        margin: 8px 0;
        display: block;
        margin-top: auto;
    }

    .btn-buy-now {
        background-color: #E65100;
        color: #fff;
        font-size: clamp(0.85rem, 2vw, 1.05rem);
        font-weight: 700;
        padding: 12px 8px;
        width: 100%;
        border: 2px solid #BF360C;
        border-radius: 6px;
        text-transform: uppercase;
        cursor: pointer;
        min-height: 48px;
    }
    .btn-buy-now:hover { background-color: #BF360C; }

    .search-box {
        border: 3px solid #006400 !important;
        font-size: 1.2rem !important;
        padding: 15px !important;
        border-radius: 8px 0 0 8px !important;
    }

    .btn-search {
        background-color: #006400;
        color: white;
        font-weight: bold;
        font-size: 1.2rem;
        border: 3px solid #006400;
        border-radius: 0 8px 8px 0;
        padding: 0 30px;
    }

    .pagination-bar a {
        padding: 10px 20px;
        font-size: 1.2rem;
        font-weight: bold;
        margin: 0 5px;
        border: 2px solid #006400;
        color: #006400;
        text-decoration: none;
        border-radius: 4px;
    }
    .pagination-bar a.active {
        background-color: #006400;
        color: white;
    }
    .pagination-bar a:hover:not(.active) {
        background-color: #e6f0e6;
    }
</style>

<div class="row">
    <!-- Cột Lọc -->
    <div class="col-lg-3">
        <div class="filter-panel">
            <h3 class="filter-title"><i class="bi bi-funnel-fill"></i> Lọc Giá</h3>
            <div class="mb-4">
                <input type="range" class="form-range" min="0" max="5000000" step="50000" id="priceRange" oninput="document.getElementById('priceValue').innerText = parseInt(this.value).toLocaleString() + 'đ'">
                <div class="text-center fw-bold fs-4 text-danger mt-2">Dưới: <span id="priceValue">2,500,000đ</span></div>
            </div>

            <h3 class="filter-title"><i class="bi bi-tree-fill"></i> Loại Cây Trồng</h3>
            <div class="mb-3 d-flex align-items-center">
                <input class="farmer-checkbox" type="checkbox" id="plantRice" checked>
                <label class="check-label" for="plantRice">Lúa</label>
            </div>
            <div class="mb-3 d-flex align-items-center">
                <input class="farmer-checkbox" type="checkbox" id="plantVege">
                <label class="check-label" for="plantVege">Rau Màu</label>
            </div>
            <div class="mb-3 d-flex align-items-center">
                <input class="farmer-checkbox" type="checkbox" id="plantCoffee">
                <label class="check-label" for="plantCoffee">Cà Phê/Hồ Tiêu</label>
            </div>
            <div class="mb-3 d-flex align-items-center">
                <input class="farmer-checkbox" type="checkbox" id="plantFruit">
                <label class="check-label" for="plantFruit">Cây Ăn Trái</label>
            </div>
            
            <button class="btn btn-primary w-100 fs-4 py-2 mt-3"><i class="bi bi-search"></i> LỌC KẾT QUẢ</button>
        </div>
        
        <div class="filter-panel">
            <h3 class="filter-title"><i class="bi bi-tags-fill"></i> Danh Mục</h2>
            <ul class="list-unstyled">
                <li class="mb-3"><a href="/Product" class="fs-4 fw-bold">Tất Cả Sản Phẩm</a></li>
                <li class="mb-3"><a href="#" class="fs-4 text-dark">Phân NPK (Hóa học)</a></li>
                <li class="mb-3"><a href="#" class="fs-4 text-dark">Phân Hữu Cơ</a></li>
                <li class="mb-3"><a href="#" class="fs-4 text-dark">Thuốc Trừ Sâu Bệnh</a></li>
            </ul>
        </div>
    </div>

    <!-- Cột Sản phẩm -->
    <div class="col-lg-9">
        <div class="row mb-4">
            <div class="col-12">
                <form method="get" action="/Product" class="d-flex w-100 shadow-sm">
                    <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control search-box" placeholder="TIỂU HƯỚNG DẪN: Nhập tên phân bón hoặc mã số để tìm..." />
                    <button type="submit" class="btn btn-search">TÌM KIẾM</button>
                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center shop-header">
            <span>SẢN PHẨM HIỆN CÓ (@(Model.Products?.Count() ?? 0) MÓN)</span>
            <div class="d-flex align-items-center">
                <span class="fs-4 me-2">Xếp theo:</span>
                <select class="form-select fs-5 fw-bold text-dark border-0 p-2" style="width: auto; cursor: pointer;">
                    <option value="newest">Hàng mới về</option>
                    <option value="price_asc">Giá Rẻ nhất</option>
                    <option value="price_desc">Giá Cao nhất</option>
                </select>
            </div>
        </div>
        
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2 g-md-3">
            @if (Model.Products != null && Model.Products.Any())
            {
                foreach (var product in Model.Products)
                {
                    <div class="col mb-2 mb-md-3">
                        <div class="shop-product h-100" style="cursor: pointer;" onclick="window.location.href='/san-pham/@product.Slug'">
                            @if (product.Images != null && product.Images.Any(i => i.IsPrimary))
                            {
                                <img src="@product.Images.First(i => i.IsPrimary).ImageUrl" alt="@product.Name" class="product-img" loading="lazy" />
                            }
                            else
                            {
                                <div class="product-img d-flex align-items-center justify-content-center" style="background-color: #e9ecef; color: #888;">
                                    <i class="bi bi-image" style="font-size: 2.5rem;"></i>
                                </div>
                            }
                            
                            <div class="px-1 pt-1 d-flex flex-column flex-grow-1">
                                <a href="/san-pham/@product.Slug" class="product-name">@product.Name</a>
                                <span class="product-price">@product.BasePrice.ToString("N0")₫</span>
                                <button onclick="event.stopPropagation(); addToCart(@product.Id)" class="btn-buy-now mt-auto">
                                    <i class="bi bi-cart-plus-fill me-1"></i> MUA
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-warning fs-3 text-center py-5 fw-bold border-2 border-warning">
                        <i class="bi bi-search me-2"></i> KHÔNG TÌM THẤY SẢN PHẨM PHÙ HỢP CẦN TÌM.
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-5 pagination-bar">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?pageNumber=@(Model.CurrentPage - 1)&searchQuery=@Model.SearchQuery">TRƯỚC</a>
                }
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a href="?pageNumber=@i&searchQuery=@Model.SearchQuery" class="@(i == Model.CurrentPage ? "active" : "")">@i</a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="?pageNumber=@(Model.CurrentPage + 1)&searchQuery=@Model.SearchQuery">SAU</a>
                }
            </div>
        }
    </div>
</div>
