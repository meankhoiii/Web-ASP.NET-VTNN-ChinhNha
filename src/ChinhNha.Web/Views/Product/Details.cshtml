@using ChinhNha.Web.Models
@model ProductDetailsViewModel

@{
    ViewData["Title"] = Model.Product.Name;
    ViewData["MetaDescription"] = Model.Product.MetaDescription ?? Model.Product.ShortDescription ?? Model.Product.Description ?? Model.Product.Name;
    ViewData["OgImage"] = Model.Product.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl;
    var productUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/san-pham/{Model.Product.Slug}";
    var encodedProductUrl = Uri.EscapeDataString(productUrl);
    var activeVariants = Model.Product.Variants?
        .Where(v => v.IsActive)
        .OrderBy(v => v.DisplayOrder)
        .ThenBy(v => v.Id)
        .ToList() ?? new List<ChinhNha.Application.DTOs.Products.ProductVariantDto>();
    var defaultVariant = activeVariants.FirstOrDefault();
    var initialBasePrice = defaultVariant?.Price ?? Model.Product.BasePrice;
    var initialSalePrice = defaultVariant?.SalePrice ?? Model.Product.SalePrice;
    var initialHasDiscount = initialSalePrice.HasValue && initialSalePrice.Value > 0 && initialSalePrice.Value < initialBasePrice;
    var initialPrice = initialHasDiscount ? initialSalePrice!.Value : initialBasePrice;
    var initialDiscountPercent = initialHasDiscount && initialBasePrice > 0
        ? (int)Math.Round((initialBasePrice - initialSalePrice!.Value) * 100m / initialBasePrice)
        : 0;
    var initialStock = defaultVariant?.StockQuantity ?? Model.Product.StockQuantity;
    var initialSku = defaultVariant?.SKU ?? Model.Product.SKU;
    var initialUnit = defaultVariant != null ? defaultVariant.VariantName : Model.Product.Unit;
}

<style>
    .product-detail-img {
        width: 100%;
        border: 4px solid #006400;
        border-radius: 8px;
        background-color: #fff;
        object-fit: contain;
        aspect-ratio: 1;
        margin-bottom: 15px;
    }
    
    .thumbnail-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border: 2px solid #ccc;
        border-radius: 4px;
        cursor: pointer;
    }
    .thumbnail-img.active {
        border: 4px solid #006400;
    }

    .detail-title {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        font-weight: 900;
        color: var(--text-main);
        margin-bottom: 5px;
        text-transform: uppercase;
        line-height: 1.3;
    }

    .detail-sku {
        font-size: 1.3rem;
        color: #555;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .detail-price {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
        color: var(--price-red);
        font-weight: 900;
        background-color: #fce4e4;
        padding: 10px 20px;
        display: inline-block;
        border-radius: 8px;
        border: 2px solid var(--price-red);
    }

    .detail-price-wrap {
        margin-bottom: 20px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
    }

    .detail-price-old {
        font-size: clamp(1.05rem, 3vw, 1.3rem);
        color: #6c757d;
        text-decoration: line-through;
        font-weight: 700;
    }

    .detail-discount-badge {
        background: #1b5e20;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 800;
        border-radius: 999px;
        padding: 4px 10px;
        white-space: nowrap;
    }

    .variant-picker {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .variant-option {
        border: 2px solid #c8e6c9;
        border-radius: 10px;
        background: #fff;
        padding: 0.85rem 0.9rem;
        text-align: left;
        font-weight: 700;
        color: #1b1b1b;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .variant-option small {
        display: block;
        margin-top: 0.3rem;
        color: #666;
        font-weight: 600;
    }

    .variant-option.active {
        border-color: #2e7d32;
        box-shadow: 0 0 0 3px rgba(46, 125, 50, 0.15);
        background: #f5fff5;
    }

    .variant-focus-highlight {
        animation: variantFocusPulse 1.2s ease-in-out 1;
    }

    #chon-bien-the {
        scroll-margin-top: 140px;
    }

    @@keyframes variantFocusPulse {
        0% { box-shadow: 0 0 0 0 rgba(46, 125, 50, 0.55); }
        100% { box-shadow: 0 0 0 14px rgba(46, 125, 50, 0); }
    }

    .info-block {
        background-color: var(--bg-main);
        border: 2px solid var(--green-main);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: clamp(1rem, 3vw, 1.2rem);
        line-height: 1.6;
        color: var(--text-main);
    }
    .info-block strong { color: var(--green-main); }

    .qty-input-large {
        width: 80px;
        font-size: clamp(1.2rem, 4vw, 1.6rem);
        text-align: center;
        font-weight: bold;
        border: 2px solid var(--green-main);
        padding: 8px 5px;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .btn-qty {
        font-size: clamp(1.2rem, 4vw, 1.6rem);
        font-weight: bold;
        padding: 8px 15px;
        border: 2px solid var(--green-main);
        background: #e6e6e6;
        color: #000;
        flex-shrink: 0;
    }

    .btn-buy-large {
        background-color: var(--orange-cta);
        color: #fff;
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        font-weight: 900;
        padding: 15px 20px;
        border: 2px solid #BF360C;
        border-radius: 8px;
        text-transform: uppercase;
        width: 100%;
        margin-top: 15px;
    }
    .btn-buy-large:hover { background-color: #BF360C; color: #fff; }

    .section-header {
        background: linear-gradient(135deg, var(--green-main), var(--green-dark));
        color: white;
        padding: 12px 18px;
        font-size: clamp(1.2rem, 3.5vw, 1.6rem);
        font-weight: bold;
        border-radius: 6px;
        text-transform: uppercase;
        margin-top: 30px;
        margin-bottom: 20px;
        border-left: 6px solid var(--orange-cta);
    }

    .text-content-large {
        font-size: clamp(1.05rem, 3vw, 1.25rem);
        line-height: 1.7;
        color: var(--text-main);
    }

    /* Reviews */
    .review-box {
        border-bottom: 2px dashed #ccc;
        padding-bottom: 20px;
        margin-bottom: 20px;
    }
    .reviewer-name {
        font-size: clamp(1.1rem, 3vw, 1.3rem);
        font-weight: bold;
        color: var(--green-main);
    }
    .review-text {
        font-size: clamp(1rem, 3vw, 1.2rem);
        color: var(--text-main);
        margin-top: 5px;
    }

    .rec-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
    }

    .rec-card {
        border: 2px solid #c8e6c9;
        border-radius: 10px;
        background: #fff;
        padding: 10px;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .rec-card img {
        width: 100%;
        height: 150px;
        object-fit: contain;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        background: #fafafa;
        margin-bottom: 10px;
    }

    .rec-name {
        font-weight: 800;
        color: #1b5e20;
        line-height: 1.35;
        min-height: 44px;
        text-decoration: none;
    }

    .rec-price {
        color: #b71c1c;
        font-weight: 900;
        font-size: 1.1rem;
        margin: 8px 0;
    }

    .detail-actions-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .share-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .share-actions .btn {
        white-space: nowrap;
    }

    @@media (max-width: 767.98px) {
        .detail-sku {
            font-size: 1rem;
            margin-bottom: 12px;
        }

        .detail-price {
            display: block;
            width: 100%;
            text-align: center;
            padding: 12px;
        }

        .detail-price-wrap {
            justify-content: center;
        }

        .detail-actions-row {
            flex-direction: column;
            align-items: stretch;
        }

        .detail-actions-row > * {
            width: 100%;
        }

        .share-actions {
            grid-template-columns: 1fr;
        }

        .share-actions .btn {
            width: 100%;
        }

        .thumbnail-img {
            width: 72px;
            height: 72px;
        }
    }
</style>

<div class="mb-4">
    <a href="/Product" class="btn btn-outline-dark fs-4 fw-bold"><i class="bi bi-arrow-left-circle-fill me-2"></i> QUAY LẠI CỬA HÀNG</a>
</div>

<div class="row">
    <!-- Hình Ảnh -->
    <div class="col-lg-5 mb-4">
        @if (Model.Product.Images != null && Model.Product.Images.Any())
        {
            var primaryImage = Model.Product.Images.FirstOrDefault(i => i.IsPrimary) ?? Model.Product.Images.First();
            <img id="mainProductImage" src="@primaryImage.ImageUrl" alt="@Model.Product.Name" class="product-detail-img" />

            @if (Model.Product.Images.Count > 1)
            {
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var img in Model.Product.Images.Take(6))
                    {
                        <img src="@img.ImageUrl"
                             class="thumbnail-img @(img.ImageUrl == primaryImage.ImageUrl ? "active" : string.Empty)"
                             alt="@Model.Product.Name"
                             onclick="setMainImage('@img.ImageUrl', this)" />
                    }
                </div>
            }
        }
        else
        {
            <div class="product-detail-img d-flex align-items-center justify-content-center" style="background-color: #e9ecef;">
                <i class="bi bi-card-image text-secondary" style="font-size: 6rem;"></i>
            </div>
        }
    </div>
    
    <!-- Thông Tin Chốt Mua -->
    <div class="col-lg-7">
        <h1 class="detail-title">@Model.Product.Name</h1>
        <div class="detail-sku">Mã hàng: <span id="productSku">SP-@initialSku</span></div>
        
        <div class="detail-price-wrap">
            <div class="detail-price"><span id="productPrice">@initialPrice.ToString("N0")</span> VNĐ</div>
            <span id="productPriceOld" class="detail-price-old" style="@(initialHasDiscount ? string.Empty : "display:none;")">@initialBasePrice.ToString("N0") VNĐ</span>
            <span id="productDiscountBadge" class="detail-discount-badge" style="@(initialHasDiscount ? string.Empty : "display:none;")">-@initialDiscountPercent%</span>
        </div>
        
        <div class="info-block">
            <p><strong><i class="bi bi-tags-fill me-2"></i> Danh mục:</strong> @(Model.Product.CategoryName ?? "Đang cập nhật")</p>
            <p><strong><i class="bi bi-building me-2"></i> Nhà cung cấp:</strong> @(Model.Product.SupplierName ?? "Đang cập nhật")</p>
            <p><strong><i class="bi bi-box-seam me-2"></i> Quy cách:</strong> <span id="productUnit">@(!string.IsNullOrWhiteSpace(initialUnit) ? initialUnit : "Đang cập nhật")</span></p>
            <p class="mb-0"><strong><i class="bi bi-clipboard-data me-2"></i> Tóm tắt:</strong> @(Model.Product.ShortDescription ?? Model.Product.Description ?? "Đang cập nhật")</p>
        </div>

        <div class="p-3 p-md-4 border border-3 border-warning rounded" style="background-color: #fff9e6; overflow: visible;">
            @if (activeVariants.Any())
            {
                <div id="chon-bien-the">
                    <div class="fs-4 fw-bold mb-3">CHỌN BIẾN THỂ:</div>
                    <div class="variant-picker">
                    @foreach (var variant in activeVariants)
                    {
                        var variantEffectivePrice = variant.SalePrice ?? variant.Price;
                        <button type="button"
                                class="variant-option"
                                data-variant-id="@variant.Id"
                            data-price="@variantEffectivePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                            data-base-price="@variant.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                            data-sale-price="@(variant.SalePrice?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)"
                                data-stock="@variant.StockQuantity"
                                data-sku="@variant.SKU"
                                data-name="@variant.VariantName"
                                onclick="selectVariant(this)">
                            @variant.VariantName
                            <small>@variantEffectivePrice.ToString("N0") VNĐ</small>
                        </button>
                    }
                    </div>
                </div>
            }

            <div class="fs-4 fw-bold mb-3">CHỌN SỐ LƯỢNG MUA:</div>
            <div class="detail-actions-row mb-3">
                <div class="d-flex align-items-center flex-nowrap justify-content-center justify-content-md-start">
                    <button class="btn btn-qty" type="button" onclick="updateQty(-1)">-</button>
                    <input type="number" id="qty" class="qty-input-large mx-1" value="1" min="1" max="@initialStock">
                    <button class="btn btn-qty" type="button" onclick="updateQty(1)">+</button>
                </div>
                <span class="fs-5 fw-bold text-success mt-1 mt-md-0 text-center text-md-start">Sẵn hàng: <span id="productStock">@initialStock</span></span>
            </div>

            <button class="btn-buy-large" onclick="addToCartDetails(@Model.Product.Id)">
                <i class="bi bi-cart-plus-fill me-2"></i> BỎ VÀO GIỎ / MUA NGAY
            </button>

            <div class="share-actions mt-3">
                <a class="btn btn-outline-primary" target="_blank" rel="noopener noreferrer" href="https://www.facebook.com/sharer/sharer.php?u=@encodedProductUrl">
                    <i class="bi bi-facebook me-1"></i> Chia sẻ Facebook
                </a>
                <a class="btn btn-outline-info" target="_blank" rel="noopener noreferrer" href="https://zalo.me/share?url=@encodedProductUrl">
                    <i class="bi bi-chat-dots-fill me-1"></i> Chia sẻ Zalo
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Nội dung kéo dài dạng cuộn (Scroll) thay vì Tab ẩn dẽ gây bối rối cho người lớn tuổi -->
<div class="row">
    <div class="col-12">
        <h2 class="section-header"><i class="bi bi-stars me-2"></i> SẢN PHẨM TƯƠNG TỰ</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white mb-4">
            <div id="similarProductsLoading" class="text-muted">Đang tải gợi ý tương tự...</div>
            <div id="similarProductsList" class="rec-grid" style="display:none;"></div>
            <div id="similarProductsEmpty" class="text-muted" style="display:none;">Chưa có gợi ý tương tự cho sản phẩm này.</div>
        </div>

        <h2 class="section-header"><i class="bi bi-link-45deg me-2"></i> THƯỜNG MUA KÈM</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white mb-4">
            <div id="fbtLoading" class="text-muted">Đang tải danh sách mua kèm...</div>
            <div id="fbtList" class="rec-grid" style="display:none;"></div>
            <div id="fbtEmpty" class="text-muted" style="display:none;">Chưa có dữ liệu mua kèm.</div>
        </div>

        <h2 class="section-header"><i class="bi bi-card-heading me-2"></i> THÔNG TIN CHI TIẾT SẢN PHẨM</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
            {
                <p class="mb-0">@Model.Product.Description</p>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Product.ShortDescription))
            {
                <p class="mb-0">@Model.Product.ShortDescription</p>
            }
            else
            {
                <p class="mb-0 text-muted">Nội dung chi tiết đang được cập nhật từ nhà cung cấp.</p>
            }
        </div>

        <h2 class="section-header"><i class="bi bi-droplet-half me-2"></i> THÀNH PHẦN HÓA HỌC / HỮU CƠ</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            @if (!string.IsNullOrWhiteSpace(Model.Product.TechnicalInfo))
            {
                <p class="mb-0">@Model.Product.TechnicalInfo</p>
            }
            else
            {
                <p class="mb-0 text-muted">Chưa có thông tin thành phần kỹ thuật cho sản phẩm này.</p>
            }
        </div>

        <h2 class="section-header"><i class="bi bi-book-half me-2"></i> HƯỚNG DẪN CÁCH SỬ DỤNG</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            @if (!string.IsNullOrWhiteSpace(Model.Product.UsageInstructions))
            {
                <p class="mb-0">@Model.Product.UsageInstructions</p>
            }
            else
            {
                <p class="mb-0 text-muted">Chưa có hướng dẫn sử dụng cụ thể cho sản phẩm này.</p>
            }
        </div>

        <h2 class="section-header"><i class="bi bi-chat-quote-fill me-2"></i> NHẬN XÉT CỦA BÀ CON ĐÃ MUA</h2>
        <div class="text-content-large p-4 border border-2 border-success rounded bg-white">
            @if (Model.ReviewStats != null)
            {
                <div class="mb-3 p-3 rounded border bg-light">
                    <strong>Đánh giá trung bình:</strong> @Model.ReviewStats.AverageRating.ToString("0.0")/5
                    <span class="text-muted">(@Model.ReviewStats.TotalReviews lượt đánh giá)</span>
                </div>
            }

            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                foreach (var review in Model.Reviews)
                {
                    <div class="review-box">
                        <div class="reviewer-name">
                            @review.UserName
                            <span class="text-warning ms-2">
                                @for (var i = 0; i < review.Rating; i++)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                            </span>
                        </div>
                        <div class="text-success fw-bold fs-6">
                            @if (review.IsVerifiedPurchase)
                            {
                                <span><i class="bi bi-check-circle-fill"></i> Đã mua hàng</span>
                            }
                        </div>
                        <div class="review-text">@review.Content</div>
                        <div class="text-muted small mt-1">@review.CreatedAt.ToString("dd/MM/yyyy")</div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted">Chưa có đánh giá cho sản phẩm này.</div>
            }

            <div class="mt-3">
                <a class="btn btn-outline-success" href="/ProductReview/ProductReviews?productId=@Model.Product.Id">
                    Xem tất cả đánh giá
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const productId = @Model.Product.Id;
        let selectedVariantId = null;
        const hasVariantOptions = @activeVariants.Count > 0;
        const productBasePrice = @(Model.Product.BasePrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
        const productBaseStock = @Model.Product.StockQuantity;
        const productBaseSku = '@(Model.Product.SKU ?? string.Empty)';
        const productBaseUnit = '@(Model.Product.Unit ?? string.Empty)';

        function focusVariantSelection() {
            const variantSection = document.getElementById('chon-bien-the');
            if (!variantSection) {
                return;
            }

            const header = document.querySelector('.main-navbar.sticky-top');
            const headerOffset = header ? header.getBoundingClientRect().height + 16 : 96;
            const top = Math.max(0, window.scrollY + variantSection.getBoundingClientRect().top - headerOffset);

            window.scrollTo({ top: top, behavior: 'smooth' });
            variantSection.classList.add('variant-focus-highlight');
            setTimeout(function () {
                variantSection.classList.remove('variant-focus-highlight');
            }, 1400);
        }

        function setMainImage(imageUrl, thumbEl) {
            const mainImage = document.getElementById('mainProductImage');
            if (!mainImage) return;

            mainImage.src = imageUrl;
            document.querySelectorAll('.thumbnail-img').forEach(function (img) {
                img.classList.remove('active');
            });
            if (thumbEl) {
                thumbEl.classList.add('active');
            }
        }

        function updateQty(change) {
            let input = document.getElementById('qty');
            let val = parseInt(input.value) + change;
            if(val >= 1 && val <= parseInt(input.max)) {
                input.value = val;
            }
        }

        function parseVariantPrice(rawValue, fallbackValue = 0) {
            if (rawValue === undefined || rawValue === null || rawValue === '') {
                return Number(fallbackValue) || 0;
            }

            const normalized = String(rawValue).replace(/\s/g, '').replace(',', '.');
            const parsed = Number(normalized);
            return Number.isNaN(parsed) ? (Number(fallbackValue) || 0) : parsed;
        }

        function resolvePriceState(basePrice, salePrice) {
            const safeBase = Number(basePrice) > 0 ? Number(basePrice) : 0;
            const safeSale = Number(salePrice) > 0 ? Number(salePrice) : 0;
            const hasDiscount = safeSale > 0 && safeSale < safeBase;
            const effective = hasDiscount ? safeSale : safeBase;
            const discountPercent = hasDiscount && safeBase > 0
                ? Math.round(((safeBase - safeSale) * 100) / safeBase)
                : 0;

            return {
                base: safeBase,
                effective: effective,
                hasDiscount: hasDiscount,
                discountPercent: discountPercent
            };
        }

        function renderPriceState(priceState) {
            document.getElementById('productPrice').textContent = new Intl.NumberFormat('vi-VN').format(priceState.effective);

            const priceOld = document.getElementById('productPriceOld');
            const discountBadge = document.getElementById('productDiscountBadge');

            if (priceState.hasDiscount) {
                priceOld.textContent = new Intl.NumberFormat('vi-VN').format(priceState.base) + ' VNĐ';
                discountBadge.textContent = '-' + priceState.discountPercent + '%';
                priceOld.style.display = '';
                discountBadge.style.display = '';
            } else {
                priceOld.style.display = 'none';
                discountBadge.style.display = 'none';
            }
        }

        function selectVariant(button) {
            document.querySelectorAll('.variant-option').forEach(function (item) {
                item.classList.remove('active');
            });

            button.classList.add('active');
            selectedVariantId = parseInt(button.dataset.variantId || '0');

            const basePrice = parseVariantPrice(button.dataset.basePrice, Number(productBasePrice) || 0);
            const salePrice = parseVariantPrice(button.dataset.salePrice, 0);
            const stock = parseInt(button.dataset.stock || productBaseStock, 10);
            const sku = button.dataset.sku || productBaseSku;
            const name = button.dataset.name || productBaseUnit;

            renderPriceState(resolvePriceState(basePrice, salePrice));
            document.getElementById('productStock').textContent = stock;
            document.getElementById('productSku').textContent = 'SP-' + sku;
            document.getElementById('productUnit').textContent = name;

            const qtyInput = document.getElementById('qty');
            qtyInput.max = stock;
            if (parseInt(qtyInput.value, 10) > stock) {
                qtyInput.value = stock > 0 ? stock : 1;
            }
        }

        function addToCartDetails(productId) {
            if (hasVariantOptions && !selectedVariantId) {
                focusVariantSelection();
                if (typeof showToast === 'function') {
                    showToast('Lưu ý', 'Vui lòng chọn biến thể trước khi thêm vào giỏ hàng.', 'warning');
                }
                return;
            }

            let qty = parseInt(document.getElementById('qty').value);
            if (typeof addToCartAndGoCart === "function") {
                addToCartAndGoCart(productId, qty, selectedVariantId || null);
            } else if (typeof addToCart === "function") {
                addToCart(productId, qty, selectedVariantId || null);
                window.location.href = '/Cart';
            }
        }

        function formatPriceVn(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + 'đ';
        }

        function buildRecCardHtml(item, type) {
            const image = item.imageUrl || item.recommendedProductImage || '/images/no-image.png';
            const name = item.name || item.recommendedProductName || 'Sản phẩm';
            const price = (item.salePrice ?? item.basePrice ?? item.recommendedProductSalePrice ?? item.recommendedProductPrice ?? 0);
            const slug = item.slug || null;
            const detailUrl = slug ? '/san-pham/' + slug : '/Product?searchQuery=' + encodeURIComponent(name);

            return '<div class="rec-card">'
                + '<img src="' + image + '" alt="' + name + '" onerror="this.src=\'/images/no-image.png\'" />'
                + '<a class="rec-name" href="' + detailUrl + '">' + name + '</a>'
                + '<div class="rec-price">' + formatPriceVn(price) + '</div>'
                + '<div class="d-flex flex-wrap gap-2 mt-auto">'
                + '<a class="btn btn-outline-success btn-sm" href="' + detailUrl + '">Xem</a>'
                + '<button class="btn btn-outline-primary btn-sm" type="button" onclick="addToCart(' + (item.id || item.recommendedProductId) + ', 1)">Thêm giỏ</button>'
                + '</div>'
                + '</div>';
        }

        async function loadSimilarProducts() {
            try {
                const res = await fetch('/api/Recommendation/similar/' + productId + '?limit=8');
                const loading = document.getElementById('similarProductsLoading');
                const list = document.getElementById('similarProductsList');
                const empty = document.getElementById('similarProductsEmpty');

                if (!res.ok) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                const data = await res.json();
                const items = (data && data.similarProducts) ? data.similarProducts : [];

                loading.style.display = 'none';
                if (!items.length) {
                    empty.style.display = 'block';
                    return;
                }

                list.innerHTML = items.map(x => buildRecCardHtml(x, 'similar')).join('');
                list.style.display = 'grid';
            } catch {
                document.getElementById('similarProductsLoading').style.display = 'none';
                document.getElementById('similarProductsEmpty').style.display = 'block';
            }
        }

        async function loadFrequentlyBoughtTogether() {
            try {
                const res = await fetch('/api/Recommendation/frequently-bought-together/' + productId + '?limit=6');
                const loading = document.getElementById('fbtLoading');
                const list = document.getElementById('fbtList');
                const empty = document.getElementById('fbtEmpty');

                if (!res.ok) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                const data = await res.json();
                const items = Array.isArray(data) ? data : [];

                loading.style.display = 'none';
                if (!items.length) {
                    empty.style.display = 'block';
                    return;
                }

                list.innerHTML = items.map(x => buildRecCardHtml(x, 'fbt')).join('');
                list.style.display = 'grid';
            } catch {
                document.getElementById('fbtLoading').style.display = 'none';
                document.getElementById('fbtEmpty').style.display = 'block';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadSimilarProducts();
            loadFrequentlyBoughtTogether();

            const params = new URLSearchParams(window.location.search);
            const focusVariant = params.get('focus') === 'variant' || window.location.hash === '#chon-bien-the';
            if (focusVariant) {
                focusVariantSelection();
            }
        });
    </script>
}
