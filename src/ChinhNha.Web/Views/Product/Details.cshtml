@using ChinhNha.Web.Models
@model ProductDetailsViewModel

@{
    ViewData["Title"] = Model.Product.Name;
    ViewData["MetaDescription"] = Model.Product.MetaDescription ?? Model.Product.ShortDescription ?? Model.Product.Description ?? Model.Product.Name;
    ViewData["OgImage"] = Model.Product.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl;
    var productUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/san-pham/{Model.Product.Slug}";
    var encodedProductUrl = Uri.EscapeDataString(productUrl);
    var encodedProductTitle = Uri.EscapeDataString(Model.Product.Name);
}

<style>
    .product-detail-img {
        width: 100%;
        border: 4px solid #006400;
        border-radius: 8px;
        background-color: #fff;
        object-fit: contain;
        aspect-ratio: 1;
        margin-bottom: 15px;
    }
    
    .thumbnail-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border: 2px solid #ccc;
        border-radius: 4px;
        cursor: pointer;
    }
    .thumbnail-img.active {
        border: 4px solid #006400;
    }

    .detail-title {
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        font-weight: 900;
        color: var(--text-main);
        margin-bottom: 5px;
        text-transform: uppercase;
        line-height: 1.3;
    }

    .detail-sku {
        font-size: 1.3rem;
        color: #555;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .detail-price {
        font-size: clamp(1.8rem, 5vw, 2.5rem);
        color: var(--price-red);
        font-weight: 900;
        margin-bottom: 20px;
        background-color: #fce4e4;
        padding: 10px 20px;
        display: inline-block;
        border-radius: 8px;
        border: 2px solid var(--price-red);
    }

    .info-block {
        background-color: var(--bg-main);
        border: 2px solid var(--green-main);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: clamp(1rem, 3vw, 1.2rem);
        line-height: 1.6;
        color: var(--text-main);
    }
    .info-block strong { color: var(--green-main); }

    .qty-input-large {
        width: 80px;
        font-size: clamp(1.2rem, 4vw, 1.6rem);
        text-align: center;
        font-weight: bold;
        border: 2px solid var(--green-main);
        padding: 8px 5px;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .btn-qty {
        font-size: clamp(1.2rem, 4vw, 1.6rem);
        font-weight: bold;
        padding: 8px 15px;
        border: 2px solid var(--green-main);
        background: #e6e6e6;
        color: #000;
        flex-shrink: 0;
    }

    .btn-buy-large {
        background-color: var(--orange-cta);
        color: #fff;
        font-size: clamp(1.2rem, 3vw, 1.6rem);
        font-weight: 900;
        padding: 15px 20px;
        border: 2px solid #BF360C;
        border-radius: 8px;
        text-transform: uppercase;
        width: 100%;
        margin-top: 15px;
    }
    .btn-buy-large:hover { background-color: #BF360C; color: #fff; }
    .btn-wishlist-large {
        background-color: #fff;
        color: #ad1457;
        font-size: clamp(1.05rem, 2.8vw, 1.3rem);
        font-weight: 800;
        padding: 12px 20px;
        border: 2px solid #f8bbd0;
        border-radius: 8px;
        text-transform: uppercase;
        width: 100%;
        margin-top: 10px;
    }
    .btn-wishlist-large:hover { border-color: #ec407a; color: #880e4f; }

    .section-header {
        background: linear-gradient(135deg, var(--green-main), var(--green-dark));
        color: white;
        padding: 12px 18px;
        font-size: clamp(1.2rem, 3.5vw, 1.6rem);
        font-weight: bold;
        border-radius: 6px;
        text-transform: uppercase;
        margin-top: 30px;
        margin-bottom: 20px;
        border-left: 6px solid var(--orange-cta);
    }

    .text-content-large {
        font-size: clamp(1.05rem, 3vw, 1.25rem);
        line-height: 1.7;
        color: var(--text-main);
    }

    /* Reviews */
    .review-box {
        border-bottom: 2px dashed #ccc;
        padding-bottom: 20px;
        margin-bottom: 20px;
    }
    .reviewer-name {
        font-size: clamp(1.1rem, 3vw, 1.3rem);
        font-weight: bold;
        color: var(--green-main);
    }
    .review-text {
        font-size: clamp(1rem, 3vw, 1.2rem);
        color: var(--text-main);
        margin-top: 5px;
    }

    .rec-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
    }

    .rec-card {
        border: 2px solid #c8e6c9;
        border-radius: 10px;
        background: #fff;
        padding: 10px;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .rec-card img {
        width: 100%;
        height: 150px;
        object-fit: contain;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        background: #fafafa;
        margin-bottom: 10px;
    }

    .rec-name {
        font-weight: 800;
        color: #1b5e20;
        line-height: 1.35;
        min-height: 44px;
        text-decoration: none;
    }

    .rec-price {
        color: #b71c1c;
        font-weight: 900;
        font-size: 1.1rem;
        margin: 8px 0;
    }
</style>

<div class="mb-4">
    <a href="/Product" class="btn btn-outline-dark fs-4 fw-bold"><i class="bi bi-arrow-left-circle-fill me-2"></i> QUAY LẠI CỬA HÀNG</a>
</div>

<div class="row">
    <!-- Hình Ảnh -->
    <div class="col-lg-5 mb-4">
        @if (Model.Product.Images != null && Model.Product.Images.Any(i => i.IsPrimary))
        {
            <img src="@Model.Product.Images.First(i => i.IsPrimary).ImageUrl" alt="@Model.Product.Name" class="product-detail-img" />
            <div class="d-flex gap-2">
                <img src="@Model.Product.Images.First(i => i.IsPrimary).ImageUrl" class="thumbnail-img active" />
                <div class="thumbnail-img d-flex align-items-center justify-content-center bg-light">
                    <i class="bi bi-image text-muted fs-3"></i>
                </div>
                <div class="thumbnail-img d-flex align-items-center justify-content-center bg-light">
                    <i class="bi bi-image text-muted fs-3"></i>
                </div>
            </div>
        }
        else
        {
            <div class="product-detail-img d-flex align-items-center justify-content-center" style="background-color: #e9ecef;">
                <i class="bi bi-card-image text-secondary" style="font-size: 6rem;"></i>
            </div>
        }
    </div>
    
    <!-- Thông Tin Chốt Mua -->
    <div class="col-lg-7">
        <h1 class="detail-title">@Model.Product.Name</h1>
        <div class="detail-sku">Mã hàng: SP-@Model.Product.SKU</div>
        
        <div class="detail-price">@Model.Product.BasePrice.ToString("N0") VNĐ</div>
        
        <div class="info-block">
            <p><strong><i class="bi bi-check-circle-fill me-2"></i> 100% Phân bón chính hãng, chuẩn xuất xứ.</strong></p>
            <p><strong><i class="bi bi-telephone-fill me-2"></i> Tư vấn cách pha, cách rải: 0909.123.456 (Gặp kỹ sư Nông nghiệp)</strong></p>
            <hr>
            <p class="mb-0"><strong>Tóm tắt công dụng:</strong> @Model.Product.Description</p>
        </div>

        <div class="p-3 p-md-4 border border-3 border-warning rounded" style="background-color: #fff9e6; overflow: visible;">
            <div class="fs-4 fw-bold mb-3">CHỌN SỐ LƯỢNG MUA:</div>
            <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                <div class="d-flex align-items-center flex-nowrap">
                    <button class="btn btn-qty" type="button" onclick="updateQty(-1)">-</button>
                    <input type="number" id="qty" class="qty-input-large mx-1" value="1" min="1" max="@Model.Product.StockQuantity">
                    <button class="btn btn-qty" type="button" onclick="updateQty(1)">+</button>
                </div>
                <span class="fs-5 fw-bold text-success mt-1 mt-md-0">Sẵn hàng: @Model.Product.StockQuantity bao/chai</span>
            </div>

            <button class="btn-buy-large" onclick="addToCartDetails(@Model.Product.Id)">
                <i class="bi bi-cart-plus-fill me-2"></i> BỎ VÀO GIỎ / MUA NGAY
            </button>
            <button class="btn-wishlist-large" onclick="addToWishlistDetails(@Model.Product.Id)">
                <i class="bi bi-heart-fill me-2"></i> THÊM VÀO YÊU THÍCH
            </button>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <a class="btn btn-outline-primary" target="_blank" rel="noopener noreferrer" href="https://www.facebook.com/sharer/sharer.php?u=@encodedProductUrl">
                    <i class="bi bi-facebook me-1"></i> Chia se Facebook
                </a>
                <a class="btn btn-outline-info" target="_blank" rel="noopener noreferrer" href="https://zalo.me/share?url=@encodedProductUrl">
                    <i class="bi bi-chat-dots-fill me-1"></i> Chia se Zalo
                </a>
                <a class="btn btn-outline-secondary" target="_blank" rel="noopener noreferrer" href="https://twitter.com/intent/tweet?url=@encodedProductUrl&text=@encodedProductTitle">
                    <i class="bi bi-share-fill me-1"></i> Chia se X
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Nội dung kéo dài dạng cuộn (Scroll) thay vì Tab ẩn dẽ gây bối rối cho người lớn tuổi -->
<div class="row">
    <div class="col-12">
        <h2 class="section-header"><i class="bi bi-stars me-2"></i> SẢN PHẨM TƯƠNG TỰ</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white mb-4">
            <div id="similarProductsLoading" class="text-muted">Dang tai goi y tuong tu...</div>
            <div id="similarProductsList" class="rec-grid" style="display:none;"></div>
            <div id="similarProductsEmpty" class="text-muted" style="display:none;">Chua co goi y tuong tu cho san pham nay.</div>
        </div>

        <h2 class="section-header"><i class="bi bi-link-45deg me-2"></i> THƯỜNG MUA KÈM</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white mb-4">
            <div id="fbtLoading" class="text-muted">Dang tai danh sach mua kem...</div>
            <div id="fbtList" class="rec-grid" style="display:none;"></div>
            <div id="fbtEmpty" class="text-muted" style="display:none;">Chua co du lieu mua kem.</div>
        </div>

        <h2 class="section-header"><i class="bi bi-card-heading me-2"></i> THÔNG TIN CHI TIẾT SẢN PHẨM</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            <p>Sản phẩm này được sản xuất trên dây chuyền công nghệ hiện đại, đảm bảo chất lượng và an toàn. Phù hợp cho nhiều loại cây trồng khác nhau, giúp cây phát triển mạnh, ra rễ nhanh, đánh bật đọt non, tăng năng suất mủ/quả vượt trội.</p>
        </div>

        <h2 class="section-header"><i class="bi bi-droplet-half me-2"></i> THÀNH PHẦN HÓA HỌC / HỮU CƠ</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            <ul class="list-unstyled mb-0">
                <li class="mb-2"><i class="bi bi-dot text-success fs-2"></i> Đạm (N): 15% (Giúp bung đọt, xanh lá)</li>
                <li class="mb-2"><i class="bi bi-dot text-success fs-2"></i> Lân (P2O5): 15% (Phát triển rễ, mập thân)</li>
                <li class="mb-2"><i class="bi bi-dot text-success fs-2"></i> Kali (K2O): 15% (Nuôi trái, chắc hạt)</li>
                <li class="mb-2"><i class="bi bi-dot text-success fs-2"></i> Bổ sung vi lượng: TE (Bo, Kẽm, Magie...) giúp hạn chế rụng trái.</li>
            </ul>
        </div>

        <h2 class="section-header"><i class="bi bi-book-half me-2"></i> HƯỚNG DẪN CÁCH SỬ DỤNG</h2>
        <div class="text-content-large p-3 border border-2 border-success rounded bg-white">
            <p><strong>1. Đối với cây ăn trái (Sầu riêng, Mít, Cam...):</strong></p>
            <p>Bón 0.5 - 1kg/cây/lần. Bón 3 lần/năm (sau thu hoạch, trước ra hoa, nuôi trái). Nên cuốc rãnh quanh tán rồi lấp đất.</p>
            <br>
            <p><strong>2. Đối với Lúa / Rau màu:</strong></p>
            <p>Bón 10-15kg/1000m2. Bón lót trước khi gieo và bón thúc khi cây vươn lóng.</p>
        </div>

        <h2 class="section-header"><i class="bi bi-chat-quote-fill me-2"></i> NHẬN XÉT CỦA BÀ CON ĐÃ MUA</h2>
        <div class="text-content-large p-4 border border-2 border-success rounded bg-white">
            <div class="review-box">
                <div class="reviewer-name">Anh Hoàng (Nông dân trồng lúa) <span class="text-warning ms-2"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i></span></div>
                <div class="text-success fw-bold fs-5"><i class="bi bi-check-circle-fill"></i> Đã mua và bón thử nghiệm</div>
                <div class="review-text">"Phân hạt đều, dễ rải. Lúa nhà tôi bón xong 3 ngày là thấy nở bụi mạnh, lá xanh bền tới lúc trổ. Đại lý Chính Nha giao hàng cũng mau lẹ."</div>
            </div>
            
            <div class="review-box">
                <div class="reviewer-name">Chị Thu (Trồng tiêu) <span class="text-warning ms-2"><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i></span></div>
                <div class="text-success fw-bold fs-5"><i class="bi bi-check-circle-fill"></i> Đã mua 20 bao</div>
                <div class="review-text">"Giá tốt hơn ngoài chợ đại lý huyện. Đỡ tốn công chở vì có xe giao tới tận rẫy."</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const productId = @Model.Product.Id;

        function updateQty(change) {
            let input = document.getElementById('qty');
            let val = parseInt(input.value) + change;
            if(val >= 1 && val <= parseInt(input.max)) {
                input.value = val;
            }
        }

        function addToCartDetails(productId) {
            let qty = parseInt(document.getElementById('qty').value);
            if (typeof addToCart === "function") {
                addToCart(productId, qty);
                if (typeof showToast === "function") {
                    showToast("Thanh cong", "Da them " + qty + " san pham vao gio hang.");
                }
            }
        }

        async function addToWishlistDetails(productId) {
            if (typeof addToWishlist !== "function") {
                if (typeof showToast === "function") {
                    showToast("Thong bao", "Chuc nang wishlist chua san sang.", "warning");
                }
                return;
            }

            const result = await addToWishlist(productId);
            if (result && result.success) {
                const btn = document.querySelector('.btn-wishlist-large');
                if (btn) {
                    btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> ĐÃ THÊM VÀO YÊU THÍCH';
                    btn.disabled = true;
                }
            }
        }

        function formatPriceVn(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + 'đ';
        }

        function buildRecCardHtml(item, type) {
            const image = item.imageUrl || item.recommendedProductImage || '/images/no-image.png';
            const name = item.name || item.recommendedProductName || 'San pham';
            const price = (item.salePrice ?? item.basePrice ?? item.recommendedProductSalePrice ?? item.recommendedProductPrice ?? 0);
            const slug = item.slug || null;
            const detailUrl = slug ? '/san-pham/' + slug : '/Product?searchQuery=' + encodeURIComponent(name);

            return '<div class="rec-card">'
                + '<img src="' + image + '" alt="' + name + '" onerror="this.src=\'/images/no-image.png\'" />'
                + '<a class="rec-name" href="' + detailUrl + '">' + name + '</a>'
                + '<div class="rec-price">' + formatPriceVn(price) + '</div>'
                + '<div class="d-flex flex-wrap gap-2 mt-auto">'
                + '<a class="btn btn-outline-success btn-sm" href="' + detailUrl + '">Xem</a>'
                + '<button class="btn btn-outline-primary btn-sm" type="button" onclick="addToCart(' + (item.id || item.recommendedProductId) + ', 1)">Them gio</button>'
                + '<button class="btn btn-outline-danger btn-sm" type="button" onclick="addToWishlist(' + (item.id || item.recommendedProductId) + ')">Yeu thich</button>'
                + '</div>'
                + '</div>';
        }

        async function loadSimilarProducts() {
            try {
                const res = await fetch('/api/Recommendation/similar/' + productId + '?limit=8');
                const loading = document.getElementById('similarProductsLoading');
                const list = document.getElementById('similarProductsList');
                const empty = document.getElementById('similarProductsEmpty');

                if (!res.ok) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                const data = await res.json();
                const items = (data && data.similarProducts) ? data.similarProducts : [];

                loading.style.display = 'none';
                if (!items.length) {
                    empty.style.display = 'block';
                    return;
                }

                list.innerHTML = items.map(x => buildRecCardHtml(x, 'similar')).join('');
                list.style.display = 'grid';
            } catch {
                document.getElementById('similarProductsLoading').style.display = 'none';
                document.getElementById('similarProductsEmpty').style.display = 'block';
            }
        }

        async function loadFrequentlyBoughtTogether() {
            try {
                const res = await fetch('/api/Recommendation/frequently-bought-together/' + productId + '?limit=6');
                const loading = document.getElementById('fbtLoading');
                const list = document.getElementById('fbtList');
                const empty = document.getElementById('fbtEmpty');

                if (!res.ok) {
                    loading.style.display = 'none';
                    empty.style.display = 'block';
                    return;
                }

                const data = await res.json();
                const items = Array.isArray(data) ? data : [];

                loading.style.display = 'none';
                if (!items.length) {
                    empty.style.display = 'block';
                    return;
                }

                list.innerHTML = items.map(x => buildRecCardHtml(x, 'fbt')).join('');
                list.style.display = 'grid';
            } catch {
                document.getElementById('fbtLoading').style.display = 'none';
                document.getElementById('fbtEmpty').style.display = 'block';
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            loadSimilarProducts();
            loadFrequentlyBoughtTogether();
        });
    </script>
}
