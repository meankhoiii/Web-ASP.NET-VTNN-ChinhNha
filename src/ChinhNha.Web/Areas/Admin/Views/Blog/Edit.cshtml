@model ChinhNha.Web.Areas.Admin.Models.BlogFormViewModel
@{
    ViewData["Title"] = "Sửa bài viết";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Chỉnh sửa bài viết <span class="text-muted fs-5">#@Model.Id</span></h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Excerpt" class="form-label fw-bold"></label>
                        <textarea asp-for="Excerpt" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-bold"></label>
                        <textarea asp-for="Content" class="form-control" rows="15"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body">
                            <h5 class="card-title fw-bold border-bottom pb-2">Thông tin Đăng bài</h5>
                            
                            <div class="mb-3 mt-3">
                                <label asp-for="CategoryId" class="form-label fw-bold"></label>
                                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                                    <option value="">-- Chọn danh mục --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="ImageFile" class="form-label fw-bold">Ảnh đại diện</label>
                                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                                <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                <div class="d-flex gap-2 mt-2">
                                    <button type="button" class="btn btn-outline-secondary" onclick="CNMediaPicker.open('ImageUrl')">
                                        <i class="bi bi-images me-1"></i> Chọn từ media
                                    </button>
                                </div>
                                <input asp-for="ImageUrl" type="hidden" />
                                <div class="form-text">Upload ảnh mới hoặc chọn ảnh từ thư viện media.</div>
                                <img id="ImageUrl-preview" src="@Model.ImageUrl" alt="Preview" class="img-thumbnail mt-2 @(string.IsNullOrEmpty(Model.ImageUrl) ? "d-none" : string.Empty)" style="max-height:120px;" />
                            </div>

                            <div class="form-check form-switch mb-3 mt-3">
                                <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                                <label class="form-check-label fw-bold" for="IsPublished">Xuất bản bài viết (Hiển thị on-site)</label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 mt-2">
                                <i class="bi bi-save me-1"></i> Lưu Thay Đổi
                            </button>
                        </div>
                    </div>

                    <div class="card bg-light border-0">
                        <div class="card-body">
                            <h5 class="card-title fw-bold border-bottom pb-2">SEO Options</h5>
                            
                            <div class="mb-3 mt-3">
                                <label asp-for="MetaTitle" class="form-label"></label>
                                <input asp-for="MetaTitle" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label asp-for="MetaDescription" class="form-label"></label>
                                <textarea asp-for="MetaDescription" class="form-control" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
    <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var easyMDE = new EasyMDE({ element: document.getElementById('Content') });
        });

        window.CNMediaPicker = {
            open: function (fieldId) {
                const url = '/Admin/Media/Picker?fieldId=' + encodeURIComponent(fieldId);
                window.open(url, 'cn-media-picker', 'width=1100,height=760');
            },
            pick: function (fieldId, value) {
                const input = document.getElementById(fieldId);
                if (input) {
                    input.value = value;
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                    updatePreview(value);
                }
            }
        };

        function updatePreview(imageUrl) {
            const preview = document.getElementById('ImageUrl-preview');
            if (!preview) return;

            if (imageUrl) {
                preview.src = imageUrl;
                preview.classList.remove('d-none');
            } else {
                preview.src = '';
                preview.classList.add('d-none');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const imageUrlInput = document.getElementById('ImageUrl');
            if (imageUrlInput) {
                updatePreview(imageUrlInput.value);
            }
        });
    </script>
}
