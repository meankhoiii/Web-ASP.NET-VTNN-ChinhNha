@model ChinhNha.Web.Areas.Admin.Models.MediaLibraryViewModel
@{
    ViewData["Title"] = Model.IsPicker ? "Chọn ảnh" : "Thư viện media";
    Layout = Model.IsPicker ? null : "_AdminLayout";
}

@if (Model.IsPicker)
{
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}

<style>
    .media-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
    }

    .media-card {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
    }

    .media-thumb {
        width: 100%;
        height: 140px;
        object-fit: cover;
        background: #f8f9fa;
    }

    .media-meta {
        padding: 10px;
        font-size: 0.85rem;
    }

    .media-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .page-shell {
        padding: 16px;
    }
</style>

<div class="@(Model.IsPicker ? "page-shell" : string.Empty)">
    @if (!Model.IsPicker)
    {
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
            <h1 class="h2">Thư viện media</h1>
        </div>
    }
    else
    {
        <div class="mb-3">
            <h5 class="mb-1">Chọn ảnh cho trường: <code>@(Model.FieldId ?? "ImageUrl")</code></h5>
            <small class="text-muted">Tải ảnh lên rồi bấm "Chọn" để tự điền URL.</small>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="isPicker" value="@Model.IsPicker" />
                <input type="hidden" name="fieldId" value="@Model.FieldId" />
                <div class="col-md-8">
                    <label class="form-label fw-bold">Tải ảnh mới</label>
                    <input type="file" name="file" class="form-control" accept="image/*" required />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload me-1"></i> Upload
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="media-grid">
        @foreach (var file in Model.Files)
        {
            <div class="media-card">
                <img class="media-thumb" src="@file.Url" alt="@file.FileName" />
                <div class="media-meta">
                    <div class="fw-semibold text-truncate" title="@file.FileName">@file.FileName</div>
                    <div class="text-muted mb-2">@((file.SizeBytes / 1024.0).ToString("N1")) KB</div>
                    <div class="media-actions">
                        @if (Model.IsPicker)
                        {
                            <button type="button" class="btn btn-sm btn-success" onclick="pickFile('@file.Url')">
                                <i class="bi bi-check2"></i> Chọn
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyUrl('@file.Url')">
                                <i class="bi bi-clipboard"></i> Copy URL
                            </button>
                        }
                        <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa ảnh này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="fileName" value="@file.FileName" />
                            <input type="hidden" name="isPicker" value="@Model.IsPicker" />
                            <input type="hidden" name="fieldId" value="@Model.FieldId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    function copyUrl(url) {
        navigator.clipboard.writeText(url)
            .then(() => alert('Đã copy URL: ' + url));
    }

    function pickFile(url) {
        const fieldId = '@(Model.FieldId ?? "ImageUrl")';
        if (window.opener && window.opener.CNMediaPicker) {
            window.opener.CNMediaPicker.pick(fieldId, url);
            window.close();
            return;
        }

        alert('Không tìm thấy cửa sổ nguồn để trả dữ liệu.');
    }
</script>
