@using System.Text.Json
@model ChinhNha.Web.Areas.Admin.Models.RecommendationAnalyticsViewModel
@{
    ViewData["Title"] = "Phân tích gợi ý sản phẩm";
    Layout = "_AdminLayout";

    var reasonLabelsJson = JsonSerializer.Serialize(Model.ReasonDistribution.Keys);
    var reasonValuesJson = JsonSerializer.Serialize(Model.ReasonDistribution.Values);

    string TranslateReason(string? reason)
    {
        return reason switch
        {
            null or "" => "Khác",
            "Category" => "Cùng danh mục",
            "Trending" => "Xu hướng",
            "TopRated" => "Đánh giá cao",
            "NewArrivals" => "Hàng mới",
            "OnSale" => "Đang giảm giá",
            "FrequentlyBoughtTogether" => "Thường mua kèm",
            _ => reason
        };
    }
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h1 class="h3 mb-1">Phân tích gợi ý sản phẩm</h1>
        <small class="text-muted">Cập nhật lúc @Model.GeneratedAt.ToString("dd/MM/yyyy HH:mm")</small>
    </div>
    <form method="get" class="d-flex align-items-center gap-2">
        <label class="form-label mb-0">Khoảng thời gian (ngày)</label>
        <input type="number" class="form-control" name="days" value="@Model.Days" min="1" max="365" style="width:100px;" />
        <label class="form-label mb-0">Số lượng mỗi nhóm</label>
        <input type="number" class="form-control" name="previewLimit" value="@Model.PreviewLimit" min="1" max="20" style="width:90px;" />
        <button type="submit" class="btn btn-primary btn-sm">Tải lại</button>
    </form>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted text-uppercase small">CTR</div>
                <div class="display-6 fw-bold text-primary">@Model.ClickThroughRate.ToString("F2")%</div>
                <small class="text-muted">Tỷ lệ nhấp trên các gợi ý đã hiển thị</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted text-uppercase small">Tỉ lệ chuyển đổi</div>
                <div class="display-6 fw-bold text-success">@Model.ConversionRate.ToString("F2")%</div>
                <small class="text-muted">Tỉ lệ mua hàng phát sinh từ gợi ý</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted text-uppercase small">Điểm trung bình</div>
                <div class="display-6 fw-bold text-warning">@Model.AverageScore</div>
                <small class="text-muted">Điểm trung bình của các gợi ý</small>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-lightbulb-fill me-2"></i>Danh sách gợi ý theo tài khoản hiện tại</h5>
    </div>
    <div class="card-body">

        <div class="row g-3">
            <div class="col-lg-6">
                <h6 class="fw-bold">Gợi ý cá nhân hóa</h6>
                @if (Model.PersonalizedRecommendations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Lý do</th>
                                    <th class="text-end">Điểm</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.PersonalizedRecommendations)
                                {
                                    <tr>
                                        <td>@item.RecommendedProductName</td>
                                        <td><span class="badge text-bg-light">@TranslateReason(item.RecommendationReason)</span></td>
                                        <td class="text-end fw-semibold">@item.RecommendationScore</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Chưa có dữ liệu gợi ý cá nhân hóa.</div>
                }
            </div>
            <div class="col-lg-6">
                <h6 class="fw-bold">Gợi ý xu hướng</h6>
                @if (Model.TrendingRecommendations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Lý do</th>
                                    <th class="text-end">Điểm</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.TrendingRecommendations)
                                {
                                    <tr>
                                        <td>@item.RecommendedProductName</td>
                                        <td><span class="badge text-bg-light">@TranslateReason(item.RecommendationReason)</span></td>
                                        <td class="text-end fw-semibold">@item.RecommendationScore</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-muted">Chưa có dữ liệu gợi ý xu hướng.</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-pie-chart-fill me-2"></i>Phân bố lý do gợi ý</h5>
        <small class="text-muted">Tổng hợp từ dữ liệu gợi ý hiện có</small>
    </div>
    <div class="card-body">
        @if (Model.ReasonDistribution.Any())
        {
            <div style="height: 320px;">
                <canvas id="reasonChart"></canvas>
            </div>
        }
        else
        {
            <div class="text-muted">Chưa có dữ liệu phân bố lý do gợi ý.</div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const labels = @Html.Raw(reasonLabelsJson);
            const values = @Html.Raw(reasonValuesJson);
            if (!labels || labels.length === 0) {
                return;
            }

            const ctx = document.getElementById('reasonChart');
            if (!ctx) {
                return;
            }

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: ['#198754', '#0d6efd', '#ffc107', '#dc3545', '#6f42c1', '#20c997', '#fd7e14']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        })();
    </script>
}
