@model IEnumerable<ChinhNha.Domain.Entities.Supplier>
@{
    ViewData["Title"] = "Nhà cung cấp";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Nhà cung cấp</h1>
    <a asp-action="Create" class="btn btn-sm btn-success">
        <i class="bi bi-plus-circle me-1"></i> Thêm nhà cung cấp
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên nhà cung cấp</th>
                <th>Liên hệ</th>
                <th>Lead time</th>
                <th>Trạng thái</th>
                <th class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var supplier in Model)
            {
                <tr>
                    <td class="fw-bold">@supplier.Id</td>
                    <td>
                        <div class="fw-bold">@supplier.Name</div>
                        <small class="text-muted">@(supplier.Address ?? "-")</small>
                    </td>
                    <td>
                        <div>@(supplier.ContactPerson ?? "-")</div>
                        <small class="text-muted">@(supplier.Phone ?? "-") - @(supplier.Email ?? "-")</small>
                    </td>
                    <td>@supplier.LeadTimeDays ngày</td>
                    <td>
                        @if (supplier.IsActive)
                        {
                            <span class="badge bg-success">Kích hoạt</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ẩn</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-primary" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@supplier.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa nhà cung cấp này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
