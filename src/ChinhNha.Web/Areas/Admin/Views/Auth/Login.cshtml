@model ChinhNha.Web.Areas.Admin.Models.AdminLoginViewModel

@{
    ViewData["Title"] = "Đăng nhập Quản trị";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chính Nha</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        * { font-family: 'Roboto', sans-serif; }

        body {
            background-color: #1a2e1a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .login-card {
            background: #ffffff;
            border: 4px solid #006400;
            border-top: 8px solid #FFCC00;
            border-radius: 10px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            padding: 2.5rem;
            width: 100%;
            max-width: 460px;
        }

        .admin-badge {
            background: #006400;
            color: #FFCC00;
            font-weight: 900;
            font-size: 0.85rem;
            letter-spacing: 2px;
            padding: 4px 14px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .logo-icon { font-size: 3rem; color: #006400; }

        h1 {
            font-size: 2rem;
            font-weight: 900;
            color: #111;
            text-transform: uppercase;
        }

        .form-label {
            font-weight: 700;
            color: #006400;
            font-size: 1.1rem;
        }

        .input-wrap {
            position: relative;
        }
        .input-wrap > i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #006400;
            font-size: 1.3rem;
            z-index: 10;
        }
        .input-wrap .form-control {
            padding-left: 44px;
            height: 52px;
            border: 2px solid #c8e6c9;
            border-radius: 8px;
            font-size: 1.05rem;
            font-weight: 600;
            background: #f9fef9;
        }
        .input-wrap .form-control:focus {
            border-color: #006400;
            box-shadow: 0 0 0 3px rgba(0,100,0,0.15);
            outline: none;
        }

        .toggle-pw-btn {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #666;
            font-size: 1.3rem;
            z-index: 10;
            padding: 4px;
        }

        .btn-login {
            background: #006400;
            border: none;
            color: #FFCC00;
            font-weight: 900;
            font-size: 1.2rem;
            height: 56px;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: background 0.2s;
        }
        .btn-login:hover { background: #004d00; color: #FFCC00; }

        .back-link {
            color: #666;
            font-size: 0.95rem;
            text-decoration: none;
        }
        .back-link:hover { color: #006400; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-3">
            <i class="bi bi-shop-window logo-icon"></i>
            <div class="admin-badge">
                <i class="bi bi-shield-lock-fill me-1"></i> Khu vực quản trị
            </div>
            <h1>Đăng nhập</h1>
            <p class="text-muted">Chính Nha — Hệ thống quản lý cửa hàng</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold" role="alert"></div>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email quản trị</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope-fill"></i>
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="admin@chinhnha.id.vn" />
                </div>
                <span asp-validation-for="Email" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="Password" id="adminPwInput" class="form-control" placeholder="Nhập mật khẩu..." autocomplete="current-password" style="padding-right: 48px;" />
                    <button type="button" class="toggle-pw-btn" onclick="toggleAdminPw()">
                        <i class="bi bi-eye-slash-fill" id="adminEyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="d-flex align-items-center mb-4">
                <input asp-for="RememberMe" class="form-check-input mt-0 me-2" id="rememberMe" style="width:20px;height:20px;" />
                <label class="form-check-label fw-bold" for="rememberMe">Ghi nhớ đăng nhập</label>
            </div>

            <button type="submit" class="btn btn-login w-100 mb-3">
                <i class="bi bi-box-arrow-in-right me-2"></i>VÀO TRANG QUẢN TRỊ
            </button>
        </form>

        <div class="text-center">
            <a href="/" class="back-link">
                <i class="bi bi-arrow-left me-1"></i>Quay về trang khách hàng
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function toggleAdminPw() {
            const inp = document.getElementById('adminPwInput');
            const eye = document.getElementById('adminEyeIcon');
            if (inp.type === 'password') {
                inp.type = 'text';
                eye.className = 'bi bi-eye-fill text-success';
            } else {
                inp.type = 'password';
                eye.className = 'bi bi-eye-slash-fill';
            }
        }
    </script>
</body>
</html>
