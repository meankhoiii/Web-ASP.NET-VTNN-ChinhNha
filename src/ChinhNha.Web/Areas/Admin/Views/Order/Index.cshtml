@using ChinhNha.Domain.Enums
@model IEnumerable<ChinhNha.Application.DTOs.Orders.OrderDto>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    Layout = "_AdminLayout";
    OrderStatus? currentStatus = ViewBag.CurrentStatus as OrderStatus?;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Đơn hàng</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <form method="get" class="d-flex align-items-center">
            <label class="me-2 fw-bold text-nowrap">Lọc trạng thái:</label>
            <select name="status" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                <option value="">-- Tất cả --</option>
                @foreach (var val in Enum.GetValues(typeof(OrderStatus)).Cast<OrderStatus>())
                {
                    if (currentStatus == val)
                    {
                        <option value="@val" selected>@val.ToString()</option>
                    }
                    else
                    {
                        <option value="@val">@val.ToString()</option>
                    }
                }
            </select>
        </form>
    </div>
</div>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" width="80">Mã đơn</th>
                <th scope="col">Ngày đặt</th>
                <th scope="col">Khách hàng</th>
                <th scope="col">Số điện thoại</th>
                <th scope="col" class="text-end">Tổng tiền</th>
                <th scope="col" class="text-center">Thanh toán</th>
                <th scope="col" class="text-center">Trạng thái</th>
                <th scope="col" class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td class="fw-bold">#@o.Id</td>
                    <td>@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@o.ShippingName</td>
                    <td>@o.ShippingPhone</td>
                    <td class="text-end fw-bold text-danger">@o.TotalAmount.ToString("N0")₫</td>
                    <td class="text-center">
                        @if (o.PaymentStatus == PaymentStatus.Paid)
                        {
                            <span class="badge bg-success">Đã thanh toán</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Chưa TT</span>
                        }
                    </td>
                    <td class="text-center">
                        @switch (o.Status)
                        {
                            case OrderStatus.Pending:
                                <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                break;
                            case OrderStatus.Processing:
                                <span class="badge bg-primary">Đang xử lý</span>
                                break;
                            case OrderStatus.Shipping:
                                <span class="badge bg-info text-dark">Đang giao</span>
                                break;
                            case OrderStatus.Delivered:
                                <span class="badge bg-success">Đã giao</span>
                                break;
                            case OrderStatus.Cancelled:
                                <span class="badge bg-danger">Đã huỷ</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@o.Status</span>
                                break;
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">
                            Chi tiết
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">Không tìm thấy đơn hàng nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
