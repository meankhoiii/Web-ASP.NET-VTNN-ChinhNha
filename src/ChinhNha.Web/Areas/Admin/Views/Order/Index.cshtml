@using ChinhNha.Domain.Enums
@model IEnumerable<ChinhNha.Application.DTOs.Orders.OrderDto>
@{
    ViewData["Title"] = "Quản lý Đơn hàng Dành Cho Đại Lý";
    Layout = "_AdminLayout";
    OrderStatus? currentStatus = ViewBag.CurrentStatus as OrderStatus?;
    string currentSearchTerm = ViewBag.CurrentSearchTerm as string ?? string.Empty;

    string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Mới vào - chờ gọi",
        OrderStatus.Processing => "Đang soạn hàng",
        OrderStatus.Shipping => "Đang giao hàng",
        OrderStatus.Delivered => "Đã giao xong",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Returned => "Hoàn trả",
        _ => status.ToString()
    };
}

<style>
    .order-table th {
        background-color: #006400 !important;
        color: white !important;
        font-size: 1rem;
        font-weight: bold;
        padding: 12px 10px !important;
        border: 2px solid #004d00;
    }
    .order-table td {
        font-size: 1rem;
        padding: 12px 10px !important;
        border: 2px solid #ccc;
        vertical-align: middle;
        background-color: #fff;
    }

    .order-header-box {
        gap: 1rem;
    }

    .order-header-box h1 {
        font-size: 1.9rem;
    }

    .order-filter-label {
        font-size: 1rem;
    }
    
    .phone-number {
        font-size: 1rem;
        font-weight: 900;
        color: #CC0000;
    }
    
    .status-badge {
        font-size: 0.92rem !important;
        padding: 6px 10px !important;
        border-radius: 4px !important;
        font-weight: bold !important;
        text-transform: uppercase;
    }

    .order-action-btn {
        font-size: 0.95rem;
        padding: 0.55rem 0.8rem;
    }

    @@media (max-width: 991.98px) {
        .order-table th,
        .order-table td {
            font-size: 0.92rem;
            padding: 10px 8px !important;
        }

        .order-header-box h1 {
            font-size: 1.4rem;
        }
    }
</style>

<div class="order-header-box d-flex justify-content-between align-items-center flex-wrap mb-4 bg-white p-3 border border-3 border-success rounded">
    <h1 class="h2 fw-bold text-success mb-0"><i class="bi bi-cart-check-fill me-2"></i> DANH SÁCH ĐƠN ĐẶT HÀNG MỚI</h1>
    <form method="get" class="d-flex align-items-center flex-wrap gap-2">
        <label class="order-filter-label fw-bold text-nowrap mb-0">Lọc trạng thái:</label>
        <select name="status" class="form-select border-3 border-success fw-bold p-2" style="width: auto; min-width: 280px;">
            <option value="">-- Tất cả trạng thái --</option>
            @foreach (var val in Enum.GetValues(typeof(OrderStatus)).Cast<OrderStatus>())
            {
                if (currentStatus == val)
                {
                    <option value="@val" selected>@GetStatusLabel(val)</option>
                }
                else
                {
                    <option value="@val">@GetStatusLabel(val)</option>
                }
            }
        </select>

        <input
            type="text"
            name="searchTerm"
            class="form-control border-3 border-success fw-semibold"
            style="min-width: 280px;"
            placeholder="Tìm theo mã đơn, tên người nhận, số điện thoại"
            value="@currentSearchTerm" />

        <button type="submit" class="btn btn-success fw-bold px-3">
            <i class="bi bi-search me-1"></i>Tìm
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-3">Đặt lại</a>
    </form>
</div>

<div class="table-responsive">
    <table class="table order-table table-bordered mb-0">
        <thead>
            <tr>
                <th scope="col" class="text-center" width="100">Mã Số</th>
                <th scope="col" width="150">Ngày Khách Đặt</th>
                <th scope="col">Tên Bà Con Nhận Hàng</th>
                <th scope="col" width="180">Số Điện Thoại (Gọi chốt)</th>
                <th scope="col" class="text-end">Lấy Tiền (Tổng)</th>
                <th scope="col" class="text-center">Tình Trạng Tiền</th>
                <th scope="col" class="text-center">Tình Trạng Giao</th>
                <th scope="col" class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var o in Model)
                {
                    <tr>
                        <td class="fw-bold text-center fs-5">#@o.Id</td>
                        <td class="fw-bold text-muted">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="fw-bold text-dark">@o.ShippingName</td>
                        <td class="text-center">
                            <span class="phone-number">@o.ShippingPhone</span>
                        </td>
                        <td class="text-end fw-bold text-danger fs-4">@o.TotalAmount.ToString("N0")₫</td>
                        <td class="text-center">
                            @if (string.Equals(o.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="badge bg-success status-badge w-100">@o.PaymentStatusDisplay</div>
                            }
                            else if (string.Equals(o.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="badge bg-warning text-dark status-badge w-100">@o.PaymentStatusDisplay</div>
                            }
                            else if (string.Equals(o.PaymentStatus, "Refunded", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="badge bg-info text-dark status-badge w-100">@o.PaymentStatusDisplay</div>
                            }
                            else
                            {
                                <div class="badge bg-danger status-badge w-100">@o.PaymentStatusDisplay</div>
                            }
                        </td>
                        <td class="text-center">
                            @switch (o.Status)
                            {
                                case OrderStatus.Pending:
                                    <div class="badge bg-warning text-dark status-badge w-100">MỚI VÔ - CHỜ GỌI</div>
                                    break;
                                case OrderStatus.Processing:
                                    <div class="badge bg-primary status-badge w-100">ĐANG SOẠN HÀNG</div>
                                    break;
                                case OrderStatus.Shipping:
                                    <div class="badge bg-info text-dark status-badge w-100">GIAO CHO NHÀ XE</div>
                                    break;
                                case OrderStatus.Delivered:
                                    <div class="badge bg-success status-badge w-100">ĐÃ GIAO XONG</div>
                                    break;
                                case OrderStatus.Cancelled:
                                    <div class="badge bg-secondary status-badge w-100">KHÁCH HỦY KÈO</div>
                                    break;
                                default:
                                    <div class="badge bg-dark status-badge w-100">@o.Status</div>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@o.Id" class="order-action-btn btn btn-outline-success border-3 fw-bold">
                                <i class="bi bi-eye-fill me-1"></i> XEM KỸ & GHI CHÚ
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-5">
                        <div class="alert alert-secondary fs-5 fw-bold mb-0">
                            Không có đơn hàng nào vào lúc này!
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
