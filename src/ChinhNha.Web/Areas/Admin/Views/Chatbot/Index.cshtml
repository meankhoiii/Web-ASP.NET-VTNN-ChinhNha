@{
    ViewData["Title"] = "Trợ lý AI Admin";
    Layout = "_AdminLayout";
}

<style>
    .chat-container {
        height: calc(100vh - 220px);
        min-height: 420px;
        display: flex;
        flex-direction: column;
    }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        border: 1px solid #dee2e6;
        margin-bottom: 1rem;
        scroll-behavior: smooth;
    }
    .chat-bubble {
        max-width: 80%;
        padding: 0.6rem 1rem;
        border-radius: 12px;
        margin-bottom: 0.6rem;
        font-size: 0.92rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .bubble-user {
        background: #0d6efd;
        color: #fff;
        margin-left: auto;
        border-bottom-right-radius: 4px;
    }
    .bubble-assistant {
        background: #fff;
        color: #212529;
        border: 1px solid #dee2e6;
        border-bottom-left-radius: 4px;
    }
    .bubble-assistant pre {
        background: #f4f4f4;
        padding: 0.5rem;
        border-radius: 6px;
        font-size: 0.85rem;
        overflow-x: auto;
    }
    .chat-typing {
        display: none;
        align-items: center;
        gap: 6px;
        color: #6c757d;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }
    .typing-dot {
        width: 7px;
        height: 7px;
        background: #adb5bd;
        border-radius: 50%;
        animation: typing 1.2s infinite;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typing {
        0%, 80%, 100% { transform: scale(1); opacity: .5; }
        40% { transform: scale(1.3); opacity: 1; }
    }
    .quick-actions .btn { font-size: 0.8rem; }
</style>

<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div>
        <h1 class="h2 mb-0"><i class="bi bi-robot text-primary me-2"></i> Trợ lý AI Admin</h1>
        <p class="text-muted mb-0 mt-1 small">Hỏi báo cáo, kiểm tra kho, tra cứu đơn hàng bằng ngôn ngữ tự nhiên.</p>
    </div>
    <button class="btn btn-sm btn-outline-secondary" id="clearChatBtn">
        <i class="bi bi-trash me-1"></i> Xoá lịch sử
    </button>
</div>

<!-- Quick action prompts -->
<div class="quick-actions d-flex flex-wrap gap-2 mb-3">
    <button class="btn btn-outline-success btn-sm quick-btn" data-prompt="Doanh thu 7 ngày gần đây là bao nhiêu?">
        <i class="bi bi-graph-up me-1"></i>Doanh thu 7 ngày
    </button>
    <button class="btn btn-outline-warning btn-sm quick-btn" data-prompt="Những sản phẩm nào đang sắp hết hàng?">
        <i class="bi bi-exclamation-triangle me-1"></i>Sắp hết hàng
    </button>
    <button class="btn btn-outline-primary btn-sm quick-btn" data-prompt="Top 5 sản phẩm bán chạy nhất hiện tại?">
        <i class="bi bi-trophy me-1"></i>Top bán chạy
    </button>
    <button class="btn btn-outline-info btn-sm quick-btn" data-prompt="Có bao nhiêu đơn hàng trong 30 ngày qua?">
        <i class="bi bi-receipt me-1"></i>Đơn hàng 30 ngày
    </button>
</div>

<div class="chat-container">
    <div class="chat-messages" id="chatMessages">
        <!-- Initial greeting -->
        <div class="d-flex">
            <div class="chat-bubble bubble-assistant">
                👋 Xin chào Admin! Tôi là trợ lý AI của Chính Nha.<br>
                Hãy hỏi tôi về: doanh thu, đơn hàng, tồn kho, sản phẩm bán chạy hoặc bất kỳ thông tin kinh doanh nào.
            </div>
        </div>
    </div>

    <!-- Typing indicator -->
    <div class="chat-typing" id="typingIndicator">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <span>Đang xử lý...</span>
    </div>

    <!-- Input area -->
    <div class="input-group">
        <input type="text" id="chatInput" class="form-control" 
               placeholder="Nhập câu hỏi, ví dụ: Doanh thu hôm nay?" maxlength="500" />
        <button class="btn btn-primary" id="sendBtn">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const msgsEl = document.getElementById('chatMessages');
    const inputEl = document.getElementById('chatInput');
    const sendBtn = document.getElementById('sendBtn');
    const typingEl = document.getElementById('typingIndicator');

    let sessionId = localStorage.getItem('adminChatSession') || '';
    const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    function appendBubble(role, text) {
        const wrap = document.createElement('div');
        wrap.className = role === 'user' ? 'd-flex justify-content-end' : 'd-flex';
        const bubble = document.createElement('div');
        bubble.className = 'chat-bubble ' + (role === 'user' ? 'bubble-user' : 'bubble-assistant');
        // Simple markdown-like rendering
        bubble.innerHTML = text
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\n/g, '<br>');
        wrap.appendChild(bubble);
        msgsEl.appendChild(wrap);
        msgsEl.scrollTop = msgsEl.scrollHeight;
    }

    async function sendMessage(msg) {
        if (!msg.trim()) return;
        appendBubble('user', msg);
        inputEl.value = '';
        sendBtn.disabled = true;
        typingEl.style.display = 'flex';

        try {
            const headers = { 'Content-Type': 'application/json' };
            if (antiForgeryToken) headers['RequestVerificationToken'] = antiForgeryToken;

            const res = await fetch('/Admin/Chatbot/Send', {
                method: 'POST',
                headers,
                body: JSON.stringify({ message: msg, sessionId })
            });

            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            sessionId = data.sessionId || sessionId;
            localStorage.setItem('adminChatSession', sessionId);
            appendBubble('assistant', data.reply || 'Không nhận được phản hồi.');
        } catch (err) {
            appendBubble('assistant', '❌ Lỗi kết nối. Vui lòng thử lại.');
            console.error(err);
        } finally {
            sendBtn.disabled = false;
            typingEl.style.display = 'none';
            inputEl.focus();
        }
    }

    sendBtn.addEventListener('click', () => sendMessage(inputEl.value));
    inputEl.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(inputEl.value); } });

    document.querySelectorAll('.quick-btn').forEach(btn => {
        btn.addEventListener('click', () => sendMessage(btn.dataset.prompt));
    });

    document.getElementById('clearChatBtn').addEventListener('click', () => {
        if (confirm('Xoá toàn bộ lịch sử chat?')) {
            msgsEl.querySelectorAll('.d-flex:not(:first-child)').forEach(el => el.remove());
            sessionId = '';
            localStorage.removeItem('adminChatSession');
        }
    });
})();
</script>
}
