<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Cửa Hàng</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --sidebar-width: 240px;
            --header-height: 60px;
            --green-dark: #004d00;
            --green-main: #006400;
            --green-light: #e8f5e9;
            --gold: #FFCC00;
            --red: #CC0000;
        }

        * { font-family: 'Inter', sans-serif; }

        body {
            background-color: #f0f2f0;
            min-height: 100vh;
        }

        /* ── HEADER ── */
        .admin-header {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: var(--header-height);
            background: var(--green-dark);
            border-bottom: 3px solid var(--gold);
            z-index: 1000;
            display: flex;
            align-items: center;
            padding: 0 1rem;
            gap: 1rem;
        }

        .admin-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #fff !important;
            font-weight: 900;
            font-size: 1.15rem;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 1px;
            white-space: nowrap;
            width: var(--sidebar-width);
            flex-shrink: 0;
        }
        .admin-brand .brand-icon {
            background: var(--gold);
            color: var(--green-dark);
            width: 36px; height: 36px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .header-title {
            flex: 1;
            color: rgba(255,255,255,0.85);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }

        .header-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: 6px;
            font-weight: 700;
            font-size: 0.85rem;
            text-decoration: none;
            white-space: nowrap;
            border: none;
            cursor: pointer;
            transition: all 0.15s;
        }
        .header-btn-ghost {
            background: rgba(255,255,255,0.12);
            color: #fff;
            border: 1.5px solid rgba(255,255,255,0.3);
        }
        .header-btn-ghost:hover {
            background: rgba(255,255,255,0.22);
            color: #fff;
        }
        .header-btn-danger {
            background: var(--red);
            color: #fff;
        }
        .header-btn-danger:hover {
            background: #a50000;
            color: #fff;
        }

        /* ── SIDEBAR ── */
        .admin-sidebar {
            position: fixed;
            top: var(--header-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--header-height));
            background: #fff;
            border-right: 2px solid #d4e8d4;
            overflow-y: auto;
            z-index: 900;
            display: flex;
            flex-direction: column;
        }

        .sidebar-section-label {
            font-size: 0.7rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #999;
            padding: 16px 20px 6px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 20px;
            color: #444;
            font-weight: 600;
            font-size: 0.92rem;
            text-decoration: none;
            border-left: 3px solid transparent;
            transition: all 0.15s;
        }
        .sidebar-link i {
            font-size: 1.15rem;
            width: 22px;
            text-align: center;
            flex-shrink: 0;
        }
        .sidebar-link:hover {
            background: var(--green-light);
            color: var(--green-main);
            border-left-color: var(--green-main);
        }
        .sidebar-link.active {
            background: var(--green-light);
            color: var(--green-main);
            border-left-color: var(--green-main);
            font-weight: 700;
        }

        .sidebar-divider {
            border: none;
            border-top: 1px solid #eee;
            margin: 6px 0;
        }

        /* ── MAIN ── */
        .admin-main {
            margin-left: var(--sidebar-width);
            margin-top: var(--header-height);
            padding: 28px 32px;
            min-height: calc(100vh - var(--header-height));
        }

        /* ── MOBILE ── */
        @@media (max-width: 767px) {
            .admin-sidebar {
                transform: translateX(-100%);
                transition: transform 0.25s;
            }
            .admin-sidebar.open {
                transform: translateX(0);
            }
            .admin-main {
                margin-left: 0;
            }
            .header-title { display: none; }
        }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="admin-header">
        <button class="header-btn header-btn-ghost d-md-none px-2" id="sidebarToggle">
            <i class="bi bi-list fs-5"></i>
        </button>

        <div class="header-title d-none d-md-flex align-items-center">
            <i class="bi bi-shield-check me-2 text-warning"></i>
            He thong quan tri cua hang
        </div>

        <div class="header-actions">
            <span class="d-none d-lg-flex align-items-center gap-2 text-white me-2" style="font-size:0.85rem;opacity:0.8;">
                <i class="bi bi-person-circle fs-5"></i>
                @User.Identity?.Name
            </span>

            <a class="header-btn header-btn-ghost" href="/" title="Xem trang khách hàng">
                <i class="bi bi-eye-fill"></i>
                <span class="d-none d-sm-inline">Trang web</span>
            </a>

            <form action="/Admin/Auth/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="header-btn header-btn-danger" title="Đăng xuất khỏi trang quản trị">
                    <i class="bi bi-box-arrow-right"></i>
                    <span class="d-none d-sm-inline">Đăng xuất</span>
                </button>
            </form>
        </div>
    </header>

    <!-- SIDEBAR -->
    <aside class="admin-sidebar" id="adminSidebar">
        <span class="sidebar-section-label">Tổng quan</span>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Admin/Dashboard">
            <i class="bi bi-speedometer2 text-success"></i> Bảng điều khiển
        </a>

        <hr class="sidebar-divider" />
        <span class="sidebar-section-label">Kinh doanh</span>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")" href="/Admin/Order">
            <i class="bi bi-receipt-cutoff text-danger"></i> Đơn đặt hàng
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")" href="/Admin/Product">
            <i class="bi bi-boxes text-primary"></i> Sản phẩm phân bón
        </a>

        <hr class="sidebar-divider" />
        <span class="sidebar-section-label">Kho hàng</span>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "InventoryManagement" ? "active" : "")" href="/Admin/InventoryManagement">
            <i class="bi bi-truck text-warning"></i> Nhập / Trả kho
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Inventory" ? "active" : "")" href="/Admin/Inventory">
            <i class="bi bi-robot" style="color:#6f42c1;"></i> Dự báo AI
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AiSettings" ? "active" : "")" href="/Admin/AiSettings">
            <i class="bi bi-cpu text-secondary"></i> Cài đặt mô hình AI
        </a>

        <hr class="sidebar-divider" />
        <span class="sidebar-section-label">Nội dung</span>
        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Blog" ? "active" : "")" href="/Admin/Blog">
            <i class="bi bi-journal-richtext text-info"></i> Bài viết kỹ thuật
        </a>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function () {
            document.getElementById('adminSidebar').classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
