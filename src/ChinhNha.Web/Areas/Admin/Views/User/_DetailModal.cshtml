@model UserDetailViewModel

<div class="modal fade" id="detailUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fa-solid fa-id-card me-2"></i>Chi tiết người dùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-3 text-center">
                            <img src="@(string.IsNullOrWhiteSpace(Model.Detail.AvatarUrl) ? "/images/logo.png" : Model.Detail.AvatarUrl)"
                             alt="Avatar"
                             class="img-thumbnail rounded-circle"
                             style="width:110px;height:110px;object-fit:cover;" />
                    </div>
                    <div class="col-md-9">
                        <h4 class="mb-1">@Model.Detail.FullName</h4>
                        <p class="mb-1 text-muted">@Model.Detail.Email</p>
                        <p class="mb-2">SĐT: @(string.IsNullOrWhiteSpace(Model.Detail.Phone) ? "-" : Model.Detail.Phone)</p>
                        <span class="badge bg-primary">@Model.Detail.Role</span>
                        @if (Model.Detail.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>
                </div>

                <hr />

                <div class="row g-3 mb-3">
                    <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Tổng đơn hàng</small><div class="fw-bold">@Model.Detail.TotalOrders</div></div></div>
                    <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Tổng chi tiêu</small><div class="fw-bold text-danger">@Model.Detail.TotalSpent.ToString("N0") đ</div></div></div>
                    <div class="col-md-4"><div class="border rounded p-2"><small class="text-muted">Đơn gần nhất</small><div class="fw-bold">@(Model.Detail.LastOrderDate?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-2"><small class="text-muted">Ngày tạo</small><div class="fw-bold">@Model.Detail.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div></div></div>
                    <div class="col-md-6"><div class="border rounded p-2"><small class="text-muted">Đăng nhập cuối</small><div class="fw-bold">@(Model.Detail.LastLoginAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</div></div></div>
                </div>

                <h6 class="fw-bold mb-2">5 đơn gần nhất</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Detail.RecentOrders.Any())
                            {
                                @foreach (var order in Model.Detail.RecentOrders)
                                {
                                    <tr>
                                        <td>#@order.OrderId</td>
                                        <td>@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@order.TotalAmount.ToString("N0") đ</td>
                                        <td>@order.Status</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted">Chưa có đơn hàng</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>