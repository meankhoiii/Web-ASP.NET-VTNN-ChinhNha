@using ChinhNha.Domain.Enums
@model IEnumerable<ChinhNha.Application.DTOs.Inventory.InventoryTransactionDto>
@{
    var product = (ViewBag.Product as ChinhNha.Application.DTOs.Products.ProductDto)!;
    ViewData["Title"] = $"Nhập xuất kho: {product.Name}";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Kho: <span class="text-primary">@product.Name</span></h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white fw-bold py-3"><i class="bi bi-box-arrow-in-down me-2"></i> Phiếu Nhập / Xuất tay</div>
            <div class="card-body">
                <form asp-action="RecordStock" method="post">
                    <input type="hidden" name="productId" value="@product.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Loại giao dịch</label>
                        <select name="type" class="form-select">
                            <option value="@TransactionType.Import">Nhập kho (Thêm hàng)</option>
                            <option value="@TransactionType.Adjustment">Điều chỉnh (-/+) (Xuất kho, hao hụt)</option>
                            <option value="@TransactionType.Return">Khách trả hàng (Thêm hàng)</option>
                        </select>
                        <div class="form-text mt-1 text-muted">Lưu ý: "Điều chỉnh" thường dùng khi trừ kho do hao hụt hoặc kiểm kê. Số lượng vẫn nhập số dương. Logic Service sẽ lo việc trừ hoặc tuỳ theo type. \nThực tế: Adjustment là +/-. Nhưng chuẩn nhất: Chọn "Nhập kho" để cộng kho.</div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số lượng</label>
                        <div class="input-group">
                            <input type="number" name="quantity" class="form-control" required min="1" />
                            <span class="input-group-text">@product.Unit</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi chú</label>
                        <textarea name="note" class="form-control" rows="2" placeholder="Ví dụ: Lô hàng mới từ NSX..."></textarea>
                    </div>

                    <p class="mb-3 text-primary fw-bold">Tồn hiện tại: @product.StockQuantity @product.Unit</p>

                    <button type="submit" class="btn btn-success w-100">Xác nhận Lưu Giao dịch</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-bold py-3"><i class="bi bi-card-list me-2"></i> Lịch sử giao dịch gần đây</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Thời gian</th>
                            <th>Loại</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-center">Tồn trước</th>
                            <th class="text-center">Tồn sau</th>
                            <th>Ghi chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.OrderByDescending(x => x.TransactionDate))
                        {
                            <tr>
                                <td class="text-nowrap text-muted">@t.TransactionDate.ToString("dd/MM/yy HH:mm")</td>
                                <td>
                                    @switch(t.Type)
                                    {
                                        case TransactionType.Import: <span class="badge bg-success">Nhập hàng</span>; break;
                                        case TransactionType.Export: <span class="badge bg-danger">Bán hàng</span>; break;
                                        case TransactionType.Return: <span class="badge bg-warning text-dark">Trả hàng</span>; break;
                                        case TransactionType.Adjustment: <span class="badge bg-secondary">Điều chỉnh</span>; break;
                                        default: <span class="badge bg-dark">@t.Type</span>; break;
                                    }
                                </td>
                                <td class="text-center fw-bold @(t.Type == TransactionType.Export ? "text-danger" : "text-success")">
                                    @(t.Type == TransactionType.Export ? "-" : "+")@t.Quantity
                                </td>
                                <td class="text-center text-muted">@t.StockBefore</td>
                                <td class="text-center fw-bold text-primary">@t.StockAfter</td>
                                <td><small>@t.Note</small></td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr><td colspan="6" class="text-center py-4 text-muted">Chưa có giao dịch.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
