@model IEnumerable<ChinhNha.Application.DTOs.Products.ProductDto>
@{
    ViewData["Title"] = "Quản lý Nhập Xuất Kho";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Nhập Xuất Kho</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" width="60">Mã</th>
                <th scope="col">Tên sản phẩm</th>
                <th scope="col" class="text-center">Tồn kho hiện tại</th>
                <th scope="col" class="text-center">Tối thiểu</th>
                <th scope="col" class="text-center">Trạng thái</th>
                <th scope="col" class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-bold">@p.SKU</td>
                    <td>
                        <div class="fw-bold">@p.Name</div>
                    </td>
                    <td class="text-center text-primary fw-bold fs-5">
                        @p.StockQuantity <small class="text-muted fw-normal fs-6">@p.Unit</small>
                    </td>
                    <td class="text-center">@p.MinStockLevel</td>
                    <td class="text-center">
                        @if (p.StockQuantity <= 0)
                        {
                            <span class="badge bg-danger">Hết hàng</span>
                        }
                        else if (p.StockQuantity <= p.MinStockLevel)
                        {
                            <span class="badge bg-warning text-dark">Sắp hết</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Đủ hàng</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Transactions" asp-route-productId="@p.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-clock-history"></i> Lịch sử & Nhập xuất
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
