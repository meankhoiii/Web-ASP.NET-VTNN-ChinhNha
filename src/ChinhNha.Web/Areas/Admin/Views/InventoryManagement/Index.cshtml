@model IEnumerable<ChinhNha.Application.DTOs.Products.ProductDto>
@{
    ViewData["Title"] = "Quản lý Nhập Xuất Kho";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Nhập Xuất Kho</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group" role="group">
            <!-- Import Button -->
            <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="bi bi-upload"></i> Nhập từ Excel
            </button>
            <!-- Export Button -->
            <a href="@Url.Action("ExportInventory")" class="btn btn-outline-info">
                <i class="bi bi-download"></i> Xuất Excel
            </a>
            <!-- Download Template -->
            <a href="@Url.Action("DownloadImportTemplate")" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-file-earmark-arrow-down"></i> Template
            </a>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @Html.Raw((TempData["WarningMessage"]?.ToString() ?? string.Empty).Replace("\n", "<br>"))
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th scope="col" width="60">Mã</th>
                <th scope="col">Tên sản phẩm</th>
                <th scope="col" class="text-center">Tồn kho hiện tại</th>
                <th scope="col" class="text-center">Tối thiểu</th>
                <th scope="col" class="text-center">Trạng thái</th>
                <th scope="col" class="text-end">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-bold">@p.SKU</td>
                    <td>
                        <div class="fw-bold">@p.Name</div>
                    </td>
                    <td class="text-center text-primary fw-bold fs-5">
                        @p.StockQuantity <small class="text-muted fw-normal fs-6">@p.Unit</small>
                    </td>
                    <td class="text-center">@p.MinStockLevel</td>
                    <td class="text-center">
                        @if (p.StockQuantity <= 0)
                        {
                            <span class="badge bg-danger">Hết hàng</span>
                        }
                        else if (p.StockQuantity <= p.MinStockLevel)
                        {
                            <span class="badge bg-warning text-dark">Sắp hết</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Đủ hàng</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Transactions" asp-route-productId="@p.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-clock-history"></i> Lịch sử & Nhập xuất
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importModalLabel">
                    <i class="bi bi-upload"></i> Nhập dữ liệu từ Excel
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" enctype="multipart/form-data" asp-action="ImportInventory">
                <div class="modal-body">
                    <div class="alert alert-info" role="alert">
                        <small>
                            <strong>Định dạng Excel:</strong><br>
                            Cột 1: Tên sản phẩm<br>
                            Cột 2: Loại giao dịch (Import/Export/Return/Adjustment/Loss)<br>
                            Cột 3: Số lượng<br>
                            Cột 4: Đơn giá (tùy chọn)<br>
                            Cột 5: Ghi chú (tùy chọn)
                        </small>
                    </div>
                    <div class="mb-3">
                        <label for="importFile" class="form-label">Chọn file Excel:</label>
                        <input class="form-control" type="file" id="importFile" name="file" accept=".xlsx" required>
                        <small class="text-muted">Chỉ hỗ trợ file .xlsx</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-upload"></i> Nhập dữ liệu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
